<!DOCTYPE html>

<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Category Management - Urban Football</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
            },
            fontFamily: {
              display: ["Inter"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
    <style>
      body {
        font-family: "Inter", sans-serif;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .active-link {
        background-color: #137fec;
        color: white;
      }
    </style>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen"
  >
    <div class="flex h-screen overflow-hidden">
      <!-- Side Navigation Sidebar -->
      <aside
        class="w-64 flex-shrink-0 bg-white dark:bg-[#111418] border-r border-slate-200 dark:border-slate-800 flex flex-col h-full"
      >
        <div class="p-6">
          <div class="flex items-center gap-3">
            <div class="bg-primary rounded-lg p-1.5">
              <span class="material-symbols-outlined text-white text-2xl"
                >sports_soccer</span
              >
            </div>
            <div class="flex flex-col">
              <h1
                class="text-slate-900 dark:text-white text-lg font-bold leading-tight"
              >
                Urban Football
              </h1>
              <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-medium">
                Football Admin
              </p>
            </div>
          </div>
        </div>
        <nav class="flex-1 px-4 space-y-1">
          <a
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-[#283039] transition-colors"
            href="/admin/dashboard"
          >
            <span class="material-symbols-outlined">dashboard</span>
            <span class="text-sm font-medium">Dashboard</span>
          </a>
          <a
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-[#283039] transition-colors"
            href="#"
          >
            <span class="material-symbols-outlined">shopping_bag</span>
            <span class="text-sm font-medium">Orders</span>
          </a>
          <a
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-[#283039] transition-colors"
            href="/admin/products"
          >
            <span class="material-symbols-outlined">inventory_2</span>
            <span class="text-sm font-medium">Products</span>
          </a>
          <a
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-[#283039] transition-colors"
            href="/admin/userManagement"
          >
            <span class="material-symbols-outlined">group</span>
            <span class="text-sm font-medium">Users</span>
          </a>
          <a
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg active-link shadow-sm"
            href="/admin/categories"
          >
            <span class="material-symbols-outlined">category</span>
            <span class="text-sm font-medium">Categories</span>
          </a>

          
        </nav>
        
      </aside>
      <!-- Main Content Area -->
      <main class="flex-1 overflow-y-auto flex flex-col">
        <!-- Page Heading Section -->
        <header class="p-8 pb-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="space-y-1">
              <h2
                class="text-3xl font-black tracking-tight text-slate-900 dark:text-white"
              >
                Category Management
              </h2>
              <p class="text-slate-500 dark:text-slate-400 text-sm">
                Organize and manage your product hierarchy for the football
                store.
              </p>
            </div>
            <button
              onclick="openAddCategoryModal()"
              class="flex items-center gap-2 px-5 h-11 bg-primary text-white rounded-lg hover:bg-primary/90 transition-all font-bold text-sm shadow-lg shadow-primary/20"
            >
              <span class="material-symbols-outlined text-[20px]">add</span>
              <span>Add New Category</span>
            </button>
          </div>
        </header>
        <!-- Filters and Search -->
        <section class="px-8 py-4 space-y-4">
          <div class="flex flex-col md:flex-row gap-4 items-center">
            <!-- Search Bar -->
            <form action="/admin/categories" method="GET" class="flex-1 w-full flex items-center gap-2">
              <div class="relative flex-1">
                <div
                  class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-slate-400 dark:text-[#9dabb9]"
                >
                  <span class="material-symbols-outlined">search</span>
                </div>
                <input
                  name="search"
                  id="searchInput"
                  value="<%= typeof search !== 'undefined' ? search : '' %>"
                  class="block w-full h-11 pl-12 bg-white dark:bg-[#283039] border border-slate-200 dark:border-transparent rounded-lg text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] focus:ring-2 focus:ring-primary focus:border-transparent text-sm transition-all"
                  placeholder="Search categories by name..."
                  type="text"
                />
              </div>
              <button type="submit" class="bg-primary hover:bg-primary/90 text-white rounded-lg h-11 px-4 text-sm font-bold transition-all">Search</button>
              <button type="button" onclick="document.getElementById('searchInput').value=''" class="bg-slate-200 hover:bg-slate-300 dark:bg-slate-700 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg h-11 px-4 text-sm font-bold flex items-center transition-all">Cancel</button>
              <% if (typeof search !== 'undefined' && search) { %>
                <a href="/admin/categories" class="bg-red-500 hover:bg-red-600 text-white rounded-lg h-11 px-4 text-sm font-bold flex items-center transition-all">Clear</a>
              <% } %>
            </form>
            <!-- Chips/Filters -->
            <div
              class="flex gap-2 w-full md:w-auto overflow-x-auto pb-1 md:pb-0"
            >
              
            </div>
          </div>
        </section>
        <!-- Table Section -->
        <section class="px-8 py-4 flex-1">
          <div
            class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm"
          >
            <div class="overflow-x-auto @container">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr
                    class="bg-slate-50 dark:bg-[#1c2127] border-b border-slate-200 dark:border-[#3b4754]"
                  >
                    <th
                      class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 w-1/3"
                    >
                      Category Name
                    </th>
                    <th
                      class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400"
                    >
                      Total Products
                    </th>
                    <th
                      class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400"
                    >
                      Visibility
                    </th>
                    <th
                      class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right"
                    >
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#3b4754]">

  <% if(categories.length === 0) { %>
    <tr>
      <td colspan="4" class="text-center py-6 text-slate-500">
        No categories found
      </td>
    </tr>
  <% } %>

  <% categories.forEach(category => { %>
    <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors group">
      
      <!-- Category Name -->
      <td class="px-6 py-5">
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center border">
            <span class="material-symbols-outlined text-primary">category</span>
          </div>
          <div>
            <p class="text-sm font-bold text-slate-900 dark:text-white">
              <%= category.name %>
            </p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
              <%= category.description %>
            </p>
          </div>
        </div>
      </td>

      <!-- Total Products -->
      <td class="px-6 py-5">
        <span class="text-sm font-medium text-slate-900 dark:text-white">
          <%= category.productCount || 0 %>
        </span>
      </td>

      <!-- Status -->
      <td class="px-6 py-5">
        <% if(category.isListed) { %>
          <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700">
            Active
          </span>
        <% } else { %>
          <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-bold bg-slate-200 text-slate-600">
            Hidden
          </span>
        <% } %>
      </td>

      <!-- Actions -->
      <td class="px-6 py-5 text-right">
        <div class="flex justify-end gap-1">
          
          <button 
            onclick="openEditCategoryModal('<%= category._id %>', '<%= category.name %>', '<%= category.description %>', '<%= category.isListed %>')"
            class="p-2 text-slate-400 hover:text-primary">
            <span class="material-symbols-outlined text-[20px]">edit</span>
          </button>

          

        </div>
      </td>

    </tr>
  <% }) %>

</tbody>
              </table>
            </div>
            <!-- Pagination Footer -->
            <div
              class="px-6 py-4 bg-slate-50 dark:bg-[#1c2127] border-t border-slate-200 dark:border-[#3b4754] flex items-center justify-between"
            >
              <p class="text-xs font-medium text-slate-500 dark:text-slate-400">
                Showing <%= (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, totalCategories) %> of <%= totalCategories %> categories
              </p>
              <div class="flex gap-1 items-center">

                <%# Previous button %>
                <% if (currentPage > 1) { %>
                  <a href="/admin/categories?page=<%= currentPage - 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500 hover:bg-white dark:hover:bg-slate-800 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                  </a>
                <% } else { %>
                  <span class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-300 dark:text-slate-600 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                  </span>
                <% } %>

                <%# Page number buttons with smart ellipsis %>
                <%
                  let pagesToShow = [];
                  if (totalPages <= 7) {
                    for (let i = 1; i <= totalPages; i++) pagesToShow.push(i);
                  } else {
                    pagesToShow.push(1);
                    if (currentPage > 3) pagesToShow.push('...');
                    let start = Math.max(2, currentPage - 1);
                    let end   = Math.min(totalPages - 1, currentPage + 1);
                    for (let i = start; i <= end; i++) pagesToShow.push(i);
                    if (currentPage < totalPages - 2) pagesToShow.push('...');
                    pagesToShow.push(totalPages);
                  }
                %>

                <% pagesToShow.forEach(p => { %>
                  <% if (p === '...') { %>
                    <span class="px-1 text-slate-400 dark:text-slate-500 text-sm">…</span>
                  <% } else if (p === currentPage) { %>
                    <span class="h-8 w-8 rounded-lg bg-primary text-white text-sm font-bold flex items-center justify-center"><%= p %></span>
                  <% } else { %>
                    <a href="/admin/categories?page=<%= p %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="h-8 w-8 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium flex items-center justify-center hover:bg-white dark:hover:bg-slate-800 transition-colors"><%= p %></a>
                  <% } %>
                <% }) %>

                <%# Next button %>
                <% if (currentPage < totalPages) { %>
                  <a href="/admin/categories?page=<%= currentPage + 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>" class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500 hover:bg-white dark:hover:bg-slate-800 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                  </a>
                <% } else { %>
                  <span class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-300 dark:text-slate-600 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                  </span>
                <% } %>

              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <!-- Add Category Modal -->
    <div
      id="addCategoryModal"
      class="fixed inset-0 z-50 hidden flex items-center justify-center overflow-y-auto overflow-x-hidden bg-black/50 backdrop-blur-sm transition-opacity"
    >
      <div class="relative w-full max-w-md p-4">
        <div
          class="relative bg-white dark:bg-[#1c2127] rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800"
        >
          <!-- Modal header -->
          <div
            class="flex items-center justify-between p-5 border-b border-slate-200 dark:border-[#3b4754] rounded-t-xl"
          >
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">
              Add New Category
            </h3>
            <button
              type="button"
              onclick="closeAddCategoryModal()"
              class="text-slate-400 bg-transparent hover:bg-slate-200 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
          </div>
          <!-- Modal body -->
          <form id="addCategoryForm" class="p-5" novalidate>
            <div class="space-y-4">
              <div>
                <label
                  for="addCategoryName"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Category Name</label
                >
                <input
                  type="text"
                  name="name"
                  id="addCategoryName"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                  placeholder="e.g. Boots"
                  required
                />
                <p
                  id="addCategoryNameError"
                  class="mt-1 text-xs text-red-500 hidden"
                ></p>
              </div>
              <div>
                <label
                  for="addCategoryDescription"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Description</label
                >
                <textarea
                  id="addCategoryDescription"
                  name="description"
                  rows="3"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                  placeholder="Brief description of the category..."
                  required
                ></textarea>
                <p
                  id="addCategoryDescriptionError"
                  class="mt-1 text-xs text-red-500 hidden"
                ></p>
              </div>
              <div>
                <label
                  for="addCategoryStatus"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Status</label
                >
                <select
                  id="addCategoryStatus"
                  name="isListed"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                >
                  <option value="true">Active (Listed)</option>
                  <option value="false">Hidden (Unlisted)</option>
                </select>
              </div>
            </div>
            <!-- Modal footer -->
            <div
              class="flex items-center justify-end space-x-3 mt-6 pt-5 border-t border-slate-200 dark:border-[#3b4754]"
            >
              <button
                type="button"
                onclick="closeAddCategoryModal()"
                class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 focus:ring-4 focus:outline-none focus:ring-slate-200 dark:bg-transparent dark:text-slate-300 dark:border-[#3b4754] dark:hover:bg-[#283039] dark:hover:text-white dark:focus:ring-slate-700 transition-colors"
              >
                Cancel
              </button>
              <button
                type="submit"
                class="px-5 py-2.5 text-sm font-bold text-white bg-primary rounded-lg hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/50 transition-colors shadow-lg shadow-primary/20"
              >
                Add Category
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Edit Category Modal -->
    <div
      id="editCategoryModal"
      class="fixed inset-0 z-50 hidden flex items-center justify-center overflow-y-auto overflow-x-hidden bg-black/50 backdrop-blur-sm transition-opacity"
    >
      <div class="relative w-full max-w-md p-4">
        <div
          class="relative bg-white dark:bg-[#1c2127] rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800"
        >
          <!-- Modal header -->
          <div
            class="flex items-center justify-between p-5 border-b border-slate-200 dark:border-[#3b4754] rounded-t-xl"
          >
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">
              Edit Category
            </h3>
            <button
              type="button"
              onclick="closeEditCategoryModal()"
              class="text-slate-400 bg-transparent hover:bg-slate-200 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
          </div>
          <!-- Modal body -->
          <form id="editCategoryForm" class="p-5" novalidate>
            <input type="hidden" id="editCategoryId" name="id" />
            <div class="space-y-4">
              <div>
                <label
                  for="editCategoryName"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Category Name</label
                >
                <input
                  type="text"
                  name="name"
                  id="editCategoryName"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                  placeholder="e.g. Boots"
                  required
                />
                <p
                  id="editCategoryNameError"
                  class="mt-1 text-xs text-red-500 hidden"
                ></p>
              </div>
              <div>
                <label
                  for="editCategoryDescription"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Description</label
                >
                <textarea
                  id="editCategoryDescription"
                  name="description"
                  rows="3"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                  placeholder="Brief description of the category..."
                  required
                ></textarea>
                <p
                  id="editCategoryDescriptionError"
                  class="mt-1 text-xs text-red-500 hidden"
                ></p>
              </div>
              <div>
                <label
                  for="editCategoryStatus"
                  class="block mb-2 text-sm font-semibold text-slate-900 dark:text-white"
                  >Status</label
                >
                <select
                  id="editCategoryStatus"
                  name="isListed"
                  class="bg-slate-50 border border-slate-300 text-slate-900 text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-[#111418] dark:border-[#3b4754] dark:placeholder-slate-400 dark:text-white dark:focus:ring-primary dark:focus:border-primary transition-colors"
                >
                  <option value="true">Active (Listed)</option>
                  <option value="false">Hidden (Unlisted)</option>
                </select>
              </div>
            </div>
            <!-- Modal footer -->
            <div
              class="flex items-center justify-end space-x-3 mt-6 pt-5 border-t border-slate-200 dark:border-[#3b4754]"
            >
              <button
                type="button"
                onclick="closeEditCategoryModal()"
                class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 focus:ring-4 focus:outline-none focus:ring-slate-200 dark:bg-transparent dark:text-slate-300 dark:border-[#3b4754] dark:hover:bg-[#283039] dark:hover:text-white dark:focus:ring-slate-700 transition-colors"
              >
                Cancel
              </button>
              <button
                type="submit"
                class="px-5 py-2.5 text-sm font-bold text-white bg-primary rounded-lg hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/50 transition-colors shadow-lg shadow-primary/20"
              >
                Save Changes
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/adminJs/categoryValidation.js"></script>
  </body>
</html>
