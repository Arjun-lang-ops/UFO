<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Add New Coupon - Admin Panel</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .material-symbols-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .toggle-checkbox:checked {
            right: 0;
            border-color: #137fec;
        }

        .toggle-checkbox:checked+.toggle-label {
            background-color: #137fec;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased">
    <div class="flex min-h-screen">
        <aside
            class="w-72 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark flex flex-col shrink-0">
            <div class="p-6 flex flex-col h-full">
                <div class="flex items-center gap-3 mb-10">
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 border-2 border-primary"
                        data-alt="Football store professional brand logo"
                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCk3wqgFU9wWwRMWzUs480IpZlOBTjl_Els-wMkVB0gVBclDEl-octXQBJRSl8oLKjSBuDnB5b1Yni42xYvCWy5uOdji9YS9bTw96Bwow1KrhS613OKtYgqfdU34HL9DLTg-652U_mM4_4jllHip8HMi22H8m7MBe1OyNjUKU_DfHI9TE9Eur7VwvceJuLfU_Nk2G-lIJnFJpkZ0HqPi_LgvdlaGwuUF2bkKSTzSnD0n7Z--jHB2Hu3MpaOZhpQXJigX2vXIYOp6Rc");'>
                    </div>
                    <div class="flex flex-col">
                        <h1 class="text-slate-900 dark:text-white text-base font-bold leading-tight">Admin Panel</h1>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-normal">Football Accessories</p>
                    </div>
                </div>
                <nav class="flex flex-col gap-2 flex-1">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">dashboard</span>
                        <p class="text-sm font-medium">Dashboard</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">inventory_2</span>
                        <p class="text-sm font-medium">Products</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <p class="text-sm font-medium">Orders</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary text-white shadow-lg shadow-primary/20"
                        href="#">
                        <span class="material-symbols-outlined material-symbols-fill">confirmation_number</span>
                        <p class="text-sm font-medium">Coupons</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">analytics</span>
                        <p class="text-sm font-medium">Analytics</p>
                    </a>
                </nav>
                <div class="mt-auto pt-6 border-t border-slate-200 dark:border-slate-800">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">settings</span>
                        <p class="text-sm font-medium">Settings</p>
                    </a>
                    <div class="flex items-center gap-3 px-4 py-4 mt-2">
                        <div
                            class="size-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-xs font-bold">
                            JD</div>
                        <div class="flex flex-col">
                            <p class="text-xs font-bold">John Doe</p>
                            <p class="text-[10px] text-slate-500">Store Manager</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
        <main class="flex-1 overflow-y-auto">
            <div class="max-w-4xl mx-auto p-8">
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Admin</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Marketing</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Coupons</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-slate-900 dark:text-white text-sm font-bold">Add New Coupon</span>
                </div>
                <div class="mb-8">
                    <h2 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight">Add New
                        Coupon</h2>
                    <p class="text-slate-500 dark:text-[#9dabb9] mt-1">Configure a new promotional discount for your
                        customers.</p>
                </div>
                <form class="space-y-6" id="couponForm">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <div class="md:col-span-2 space-y-6">
                            <div
                                class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                                <h3
                                    class="text-lg font-bold mb-6 flex items-center gap-2 text-slate-900 dark:text-white">
                                    <span class="material-symbols-outlined text-primary">info</span>
                                    General Information
                                </h3>
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="coupon_code">Coupon Code</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all uppercase font-mono tracking-widest"
                                            id="coupon_code" name="coupon_code" placeholder="e.g. SUMMER24"
                                            type="text" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="description">Description</label>
                                        <textarea
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="description" name="description"
                                            placeholder="Describe the purpose of this coupon..." rows="3"></textarea>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                                <h3
                                    class="text-lg font-bold mb-6 flex items-center gap-2 text-slate-900 dark:text-white">
                                    <span class="material-symbols-outlined text-primary">sell</span>
                                    Discount Configuration
                                </h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="discount_type">Discount Type</label>
                                        <select
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="discount_type" name="discount_type">
                                            <option value="PERCENTAGE">Percentage (%)</option>
                                            <option value="FLAT">Flat Discount ($)</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="discount_value">Discount Value</label>
                                        <div class="relative">
                                            <input
                                                class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                                id="discount_value" name="discount_value" placeholder="0"
                                                type="number" />
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="min_purchase">Minimum Purchase Amount ($)</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="min_purchase" name="min_purchase" placeholder="0.00" type="number" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="max_discount">Maximum Discount Value ($)</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="max_discount" name="maximum_discount" placeholder="0.00" type="number" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="expiry_date">Expiry Date</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="expiry_date" name="expiry_date" type="date" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <div
                                class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                                <h3
                                    class="text-lg font-bold mb-6 flex items-center gap-2 text-slate-900 dark:text-white">
                                    <span class="material-symbols-outlined text-primary">settings_suggest</span>
                                    Usage Limits
                                </h3>
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="total_limit">Total Usage Limit</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="total_limit" name="total_limit" placeholder="Unlimited" type="number" />
                                        <p class="mt-1 text-[10px] text-slate-500 italic">Leave empty for no limit</p>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2"
                                            for="user_limit">Usage Limit Per User</label>
                                        <input
                                            class="w-full px-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                            id="user_limit" name="user_limit" type="number" value="1" />
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                                <h3
                                    class="text-lg font-bold mb-6 flex items-center gap-2 text-slate-900 dark:text-white">
                                    <span class="material-symbols-outlined text-primary">toggle_on</span>
                                    Status
                                </h3>
                                <div
                                    class="flex items-center justify-between p-3 bg-slate-50 dark:bg-[#283039]/30 rounded-lg">
                                    <div>
                                        <p class="text-sm font-bold text-slate-900 dark:text-white">Coupon Status</p>
                                        <p class="text-xs text-slate-500 dark:text-slate-400">Enable or disable coupon
                                        </p>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input checked="" name="is_active" class="sr-only peer" type="checkbox" />
                                        <div
                                            class="w-11 h-6 bg-slate-300 dark:bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary">
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="pt-4 flex flex-col gap-3">
                                <button
                                    class="w-full px-6 py-4 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2"
                                    type="submit">
                                    <span class="material-symbols-outlined">save</span>
                                    Save Coupon
                                </button>
                                <a href="/admin/coupon">
                                    <button
                                        class="w-full px-6 py-4 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-700 dark:text-white rounded-xl font-bold transition-all"
                                        type="button">
                                        Cancel
                                    </button>
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

</body>
<script>
    document
        .getElementById("couponForm")
        .addEventListener("submit", async (e) => {

            e.preventDefault();

            const formData = {
                coupon_code: document.getElementById("coupon_code").value,
                description: document.getElementById("description").value,
                discount_type: document.getElementById("discount_type").value,
                discount_value: document.getElementById("discount_value").value,
                min_purchase: document.getElementById("min_purchase").value,
                expiry_date: document.getElementById("expiry_date").value,
                total_limit: document.getElementById("total_limit").value,
                maximum_discount:
                    document.getElementById("max_discount")?.value || "",
                is_active: document.querySelector(
                    'input[name="is_active"]'
                )?.checked,
            };

            try {

                const response = await fetch(
                    "/admin/coupons/add",
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify(formData),
                    }
                );

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(
                        result.message || "Failed to create coupon"
                    );
                }

                await Swal.fire({
                    icon: "success",
                    title: "Success!",
                    text: result.message,
                    confirmButtonColor: "#137fec",
                });

                window.location.href = "/admin/coupon";

            } catch (error) {
                Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: error.message,
                    confirmButtonColor: "#d33",
                });
                console.error(error);
            }
        });
</script>


</html>