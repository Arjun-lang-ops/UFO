<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Edit Coupon Details - Football Accessories Store</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .material-symbols-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased">
    <div class="flex min-h-screen">
        <aside
            class="w-72 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark flex flex-col shrink-0">
            <div class="p-6 flex flex-col h-full">
                <div class="flex items-center gap-3 mb-10">
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 border-2 border-primary"
                        data-alt="Football store professional brand logo"
                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCk3wqgFU9wWwRMWzUs480IpZlOBTjl_Els-wMkVB0gVBclDEl-octXQBJRSl8oLKjSBuDnB5b1Yni42xYvCWy5uOdji9YS9bTw96Bwow1KrhS613OKtYgqfdU34HL9DLTg-652U_mM4_4jllHip8HMi22H8m7MBe1OyNjUKU_DfHI9TE9Eur7VwvceJuLfU_Nk2G-lIJnFJpkZ0HqPi_LgvdlaGwuUF2bkKSTzSnD0n7Z--jHB2Hu3MpaOZhpQXJigX2vXIYOp6Rc");'>
                    </div>
                    <div class="flex flex-col">
                        <h1 class="text-slate-900 dark:text-white text-base font-bold leading-tight">Admin Panel</h1>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-normal">Football Accessories</p>
                    </div>
                </div>
                <nav class="flex flex-col gap-2 flex-1">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">dashboard</span>
                        <p class="text-sm font-medium">Dashboard</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">inventory_2</span>
                        <p class="text-sm font-medium">Products</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <p class="text-sm font-medium">Orders</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary text-white shadow-lg shadow-primary/20"
                        href="#">
                        <span class="material-symbols-outlined material-symbols-fill">confirmation_number</span>
                        <p class="text-sm font-medium">Coupons</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">analytics</span>
                        <p class="text-sm font-medium">Analytics</p>
                    </a>
                </nav>
                <div class="mt-auto pt-6 border-t border-slate-200 dark:border-slate-800">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">settings</span>
                        <p class="text-sm font-medium">Settings</p>
                    </a>
                    <div class="flex items-center gap-3 px-4 py-4 mt-2">
                        <div
                            class="size-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-xs font-bold">
                            JD</div>
                        <div class="flex flex-col">
                            <p class="text-xs font-bold">John Doe</p>
                            <p class="text-[10px] text-slate-500">Store Manager</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
        <main class="flex-1 overflow-y-auto">
            <div class="max-w-4xl mx-auto p-8">
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Admin</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="/admin/coupon">Coupons</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-slate-900 dark:text-white text-sm font-bold">Edit Coupon</span>
                </div>
                <div class="flex items-center gap-4 mb-8">
                    <a href="/admin/coupon"><button
                        class="size-10 flex items-center justify-center rounded-lg bg-white dark:bg-[#1a232e] border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">arrow_back</span>
                    </button></a>
                    <div>
                        <h2 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight">Edit
                            Coupon</h2>
                        <p class="text-slate-500 dark:text-[#9dabb9] mt-1">Modify details for <span
                                class="text-primary font-bold"><%= coupon.code %></span> promo code.</p>
                    </div>
                </div>
                <form class="space-y-6" id="couponEditForm">
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">General Information</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Coupon Code</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all font-mono uppercase"
                                    id="coupon_code" name="coupon_code" placeholder="e.g. SUMMER20" type="text" value="<%= coupon.code %>" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Coupon
                                    Status</label>
                                <select id="coupon_status" name="coupon_status"
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all">
                                    <option value="active" <%= coupon.isActive && coupon.expiryDate >= new Date() ? "selected" : "" %>>Active</option>
                                    <option value="expired" <%= coupon.expiryDate < new Date() ? "selected" : "" %>>Expired</option>
                                    <option value="disabled" <%= !coupon.isActive ? "selected" : "" %>>Disabled</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-2 md:col-span-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Description</label>
                                <textarea
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    placeholder="Enter coupon description..."
                                    id="description" name="description" rows="3"><%= coupon.description || "" %></textarea>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">Discount &amp; Logic</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Discount
                                    Type</label>
                                <select id="discount_type" name="discount_type"
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all">
                                    <option value="PERCENTAGE" <%= coupon.discountType === "PERCENTAGE" ? "selected" : "" %>>Percentage (%)</option>
                                    <option value="FLAT" <%= coupon.discountType === "FLAT" ? "selected" : "" %>>Flat Discount ($)</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Discount
                                    Value</label>
                                <div class="relative">
                                    <input
                                        class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all pr-12"
                                        id="discount_value" name="discount_value" type="number" value="<%= coupon.discountValue %>" />
                                    <span
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold"><%= coupon.discountType === "PERCENTAGE" ? "%" : "Rs" %></span>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Minimum Spend
                                    (Rs.)</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="min_purchase" name="min_purchase" type="number" value="<%= coupon.minimumPurchase || 0 %>" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Maximum Discount
                                    (Rs.)</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="maximum_discount" name="maximum_discount" placeholder="No limit" type="number" value="<%= coupon.maximumDiscount || "" %>" />
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">Usage &amp; Expiry</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Usage Limit</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="total_limit" name="total_limit" placeholder="Unlimited" type="number" value="<%= coupon.usageLimit || "" %>" />
                                <p class="text-xs text-slate-500 mt-1"><%= coupon.usedCount || 0 %>/<%= coupon.usageLimit || 0 %> uses redeemed so far.</p>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Limit Per
                                    Customer</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    type="number" value="1" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Start Date</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    type="date" value="<%= coupon.createdAt ? coupon.createdAt.toISOString().split('T')[0] : "" %>" disabled />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Expiry Date</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="expiry_date" name="expiry_date" type="date" value="<%= coupon.expiryDate ? coupon.expiryDate.toISOString().split('T')[0] : "" %>" />
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-4 pb-12">
                        <button
                            class="px-8 py-3 bg-white dark:bg-[#283039] text-slate-700 dark:text-white border border-slate-200 dark:border-slate-700 rounded-xl font-bold hover:bg-slate-50 dark:hover:bg-[#323b46] transition-all"
                            type="button" onclick="window.location.href='/admin/coupon'">
                            Cancel
                        </button>
                        <button
                            class="px-8 py-3 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold transition-all shadow-lg shadow-primary/20"
                            type="submit">
                            Update Coupon
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>

</body>
<script>
    document
        .getElementById("couponEditForm")
        .addEventListener("submit", async (e) => {
            e.preventDefault();

            const submitButton = e.target.querySelector('button[type="submit"]');
            const couponStatus = document.getElementById("coupon_status").value;

            const formData = {
                coupon_code: document.getElementById("coupon_code").value,
                description: document.getElementById("description").value,
                discount_type: document.getElementById("discount_type").value,
                discount_value: document.getElementById("discount_value").value,
                min_purchase: document.getElementById("min_purchase").value,
                maximum_discount: document.getElementById("maximum_discount").value,
                total_limit: document.getElementById("total_limit").value,
                expiry_date: document.getElementById("expiry_date").value,
                is_active: couponStatus === "active",
            };

            try {
                submitButton.disabled = true;
                submitButton.textContent = "Updating...";

                const response = await fetch("/admin/coupon-edit-success/<%= coupon._id %>", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify(formData),
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || "Failed to update coupon");
                }

                await Swal.fire({
                    icon: "success",
                    title: "Updated!",
                    text: result.message,
                    confirmButtonColor: "#137fec",
                });

                window.location.href = "/admin/coupon";
            } catch (error) {
                Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: error.message,
                    confirmButtonColor: "#d33",
                });
            } finally {
                submitButton.disabled = false;
                submitButton.textContent = "Update Coupon";
            }
        });
</script>

</html>
