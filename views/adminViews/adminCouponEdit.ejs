<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Edit Coupon Details - Football Accessories Store</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .material-symbols-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased">
    <div class="flex min-h-screen">
        <%- include('partials/sidebar', { activePage: 'coupons' }) %>
        <main class="ml-64 flex-1 overflow-y-auto">
            <div class="max-w-4xl mx-auto p-8">
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Admin</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="/admin/coupon">Coupons</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-slate-900 dark:text-white text-sm font-bold">Edit Coupon</span>
                </div>
                <div class="flex items-center gap-4 mb-8">
                    <a href="/admin/coupon"><button
                        class="size-10 flex items-center justify-center rounded-lg bg-white dark:bg-[#1a232e] border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">arrow_back</span>
                    </button></a>
                    <div>
                        <h2 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight">Edit
                            Coupon</h2>
                        <p class="text-slate-500 dark:text-[#9dabb9] mt-1">Modify details for <span
                                class="text-primary font-bold"><%= coupon.code %></span> promo code.</p>
                    </div>
                </div>
                <form class="space-y-6" id="couponEditForm">
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">General Information</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Coupon Code</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all font-mono uppercase"
                                    id="coupon_code" name="coupon_code" placeholder="e.g. SUMMER20" type="text" value="<%= coupon.code %>" />
                                <span id="coupon_code_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Coupon
                                    Status</label>
                                <select id="coupon_status" name="coupon_status"
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all">
                                    <option value="active" <%= coupon.isActive && coupon.expiryDate >= new Date() ? "selected" : "" %>>Active</option>
                                    <option value="expired" <%= coupon.expiryDate < new Date() ? "selected" : "" %>>Expired</option>
                                    <option value="disabled" <%= !coupon.isActive ? "selected" : "" %>>Disabled</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-2 md:col-span-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Description</label>
                                <textarea
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    placeholder="Enter coupon description..."
                                    id="description" name="description" rows="3"><%= coupon.description || "" %></textarea>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">Discount &amp; Logic</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Discount
                                    Type</label>
                                <select id="discount_type" name="discount_type"
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all">
                                    <option value="PERCENTAGE" <%= coupon.discountType === "PERCENTAGE" ? "selected" : "" %>>Percentage (%)</option>
                                    <option value="FLAT" <%= coupon.discountType === "FLAT" ? "selected" : "" %>>Flat Discount ($)</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Discount
                                    Value</label>
                                <div class="relative">
                                    <input
                                        class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all pr-12"
                                        id="discount_value" name="discount_value" type="number" value="<%= coupon.discountValue %>" />
                                    <span id="discount_symbol"
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold"><%= coupon.discountType === "PERCENTAGE" ? "%" : "Rs" %></span>
                                </div>
                                <span id="discount_value_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Minimum Spend
                                    (Rs.)</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="min_purchase" name="min_purchase" type="number" value="<%= coupon.minimumPurchase || 0 %>" />
                                <span id="min_purchase_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div class="flex flex-col gap-2 hidden" id="maximum_discount_container">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Maximum Discount
                                    (Rs.) <span class="text-red-500">*</span></label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="maximum_discount" name="maximum_discount" placeholder="e.g. 500" type="number" min="1" value="<%= coupon.maximumDiscount || "" %>" />
                                <p class="text-[10px] text-slate-500 italic mt-1">Maximum rupee value the percentage discount can reach</p>
                                <span id="maximum_discount_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div
                            class="p-6 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#283039]/20">
                            <h3 class="text-slate-900 dark:text-white font-bold text-lg">Usage &amp; Expiry</h3>
                        </div>
                        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Usage Limit</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="total_limit" name="total_limit" placeholder="Unlimited" type="number" value="<%= coupon.usageLimit || "" %>" />
                                <p class="text-xs text-slate-500 mt-1"><%= coupon.usedCount || 0 %>/<%= coupon.usageLimit || 0 %> uses redeemed so far.</p>
                                <span id="total_limit_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Limit Per
                                    Customer</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    type="number" value="1" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Start Date</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    type="date" value="<%= coupon.createdAt ? coupon.createdAt.toISOString().split('T')[0] : "" %>" disabled />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Expiry Date</label>
                                <input
                                    class="w-full px-4 py-3 rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-[#283039] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 transition-all"
                                    id="expiry_date" name="expiry_date" type="date" value="<%= coupon.expiryDate ? coupon.expiryDate.toISOString().split('T')[0] : "" %>" />
                                <span id="expiry_date_err" class="hidden text-xs text-red-500 mt-1 block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-4 pb-12">
                        <button
                            class="px-8 py-3 bg-white dark:bg-[#283039] text-slate-700 dark:text-white border border-slate-200 dark:border-slate-700 rounded-xl font-bold hover:bg-slate-50 dark:hover:bg-[#323b46] transition-all"
                            type="button" onclick="window.location.href='/admin/coupon'">
                            Cancel
                        </button>
                        <button
                            class="px-8 py-3 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold transition-all shadow-lg shadow-primary/20"
                            type="submit">
                            Update Coupon
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>

</body>
<script>
    // ─── Error helpers ────────────────────────────────────────────────────────
    function showError(id, msg) {
        const el = document.getElementById(id + "_err");
        if (el) {
            el.textContent = msg;
            el.classList.remove("hidden");
        }
    }

    function clearError(id) {
        const el = document.getElementById(id + "_err");
        if (el) {
            el.textContent = "";
            el.classList.add("hidden");
        }
    }

    function clearAllErrors() {
        document.querySelectorAll("[id$='_err']").forEach(el => {
            el.textContent = "";
            el.classList.add("hidden");
        });
    }

    // ─── Live error clearing and symbol updates ──────────────────────────────
    [
        "coupon_code",
        "discount_value",
        "min_purchase",
        "maximum_discount",
        "expiry_date",
        "total_limit"
    ].forEach(id => {
        document.getElementById(id)?.addEventListener("input", () => clearError(id));
    });

    function toggleMaxDiscount() {
        const isPercent = document.getElementById("discount_type").value === "PERCENTAGE";
        const container = document.getElementById("maximum_discount_container");
        if (container) {
            if (isPercent) {
                container.classList.remove("hidden");
            } else {
                container.classList.add("hidden");
                const input = document.getElementById("maximum_discount");
                if (input) input.value = "";
                clearError("maximum_discount");
            }
        }
    }

    // Run once on page load
    toggleMaxDiscount();

    document.getElementById("discount_type")?.addEventListener("change", (e) => {
        const symbol = e.target.value === "PERCENTAGE" ? "%" : "Rs";
        const symbolEl = document.getElementById("discount_symbol");
        if (symbolEl) symbolEl.textContent = symbol;
        toggleMaxDiscount();
        clearError("discount_value");
        clearError("min_purchase");
    });

    // ─── Validation ───────────────────────────────────────────────────────────
    function validate() {
        clearAllErrors();
        let valid = true;

        // Coupon code
        const code = document.getElementById("coupon_code").value.trim();
        if (!code) {
            showError("coupon_code", "Coupon code is required.");
            valid = false;
        } else if (!/^[A-Z0-9]+$/i.test(code)) {
            showError("coupon_code", "Only letters and numbers are allowed — no spaces or symbols.");
            valid = false;
        }

        // Discount type + value
        const discountType  = document.getElementById("discount_type").value;
        const discountValue = parseFloat(document.getElementById("discount_value").value);

        if (isNaN(discountValue) || discountValue <= 0) {
            showError("discount_value", "Enter a discount value greater than 0.");
            valid = false;
        } else if (discountType === "PERCENTAGE" && discountValue > 100) {
            showError("discount_value", "Percentage discount cannot exceed 100%.");
            valid = false;
        }

        // Minimum purchase
        const minPurchaseRaw = document.getElementById("min_purchase").value;
        const minPurchase    = parseFloat(minPurchaseRaw);

        if (minPurchaseRaw === "" || isNaN(minPurchase) || minPurchase < 0) {
            showError("min_purchase", "Enter a valid minimum purchase amount (0 or more).");
            valid = false;
        } else if (discountType === "FLAT" && !isNaN(discountValue) && discountValue > 0) {
            // For FLAT coupons: cart value must exceed the discount, otherwise the
            // customer pays zero or negative — business rule enforced here.
            if (minPurchase <= discountValue) {
                showError(
                    "min_purchase",
                    `Minimum purchase (Rs.${minPurchase}) must be greater than the flat discount amount (Rs.${discountValue}).`
                );
                valid = false;
            }
        }

        // Max discount cap (only relevant for PERCENTAGE)
        if (discountType === "PERCENTAGE") {
            const maxDiscountRaw = document.getElementById("maximum_discount").value.trim();
            const maxDiscount = parseFloat(maxDiscountRaw);
            if (maxDiscountRaw === "" || isNaN(maxDiscount) || maxDiscount <= 0) {
                showError("maximum_discount", "Maximum discount cap is required for percentage coupons (must be > 0).");
                valid = false;
            } else if (!isNaN(minPurchase) && minPurchase > 0 && maxDiscount >= minPurchase) {
                showError("maximum_discount", "Max discount cap must be less than the minimum purchase amount (Rs." + minPurchase + ").");
                valid = false;
            }
        }

        // Expiry date
        const expiry = document.getElementById("expiry_date").value;
        if (!expiry) {
            showError("expiry_date", "Expiry date is required.");
            valid = false;
        } else {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (new Date(expiry) <= today) {
                showError("expiry_date", "Expiry date must be a future date.");
                valid = false;
            }
        }

        // Total usage limit (optional field)
        const totalLimit = document.getElementById("total_limit").value;
        if (totalLimit !== "" && (isNaN(Number(totalLimit)) || Number(totalLimit) < 1)) {
            showError("total_limit", "Usage limit must be at least 1, or leave empty for unlimited.");
            valid = false;
        }

        return valid;
    }

    document
        .getElementById("couponEditForm")
        .addEventListener("submit", async (e) => {
            e.preventDefault();

            if (!validate()) return;

            const submitButton = e.target.querySelector('button[type="submit"]');
            const couponStatus = document.getElementById("coupon_status").value;

            const formData = {
                coupon_code: document.getElementById("coupon_code").value,
                description: document.getElementById("description").value,
                discount_type: document.getElementById("discount_type").value,
                discount_value: document.getElementById("discount_value").value,
                min_purchase: document.getElementById("min_purchase").value,
                maximum_discount: document.getElementById("maximum_discount").value,
                total_limit: document.getElementById("total_limit").value,
                expiry_date: document.getElementById("expiry_date").value,
                is_active: couponStatus === "active",
            };

            try {
                submitButton.disabled = true;
                submitButton.textContent = "Updating...";

                const response = await fetch("/admin/coupon-edit-success/<%= coupon._id %>", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify(formData),
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || "Failed to update coupon");
                }

                await Swal.fire({
                    icon: "success",
                    title: "Updated!",
                    text: result.message,
                    confirmButtonColor: "#137fec",
                });

                window.location.href = "/admin/coupon";
            } catch (error) {
                Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: error.message,
                    confirmButtonColor: "#d33",
                });
            } finally {
                submitButton.disabled = false;
                submitButton.textContent = "Update Coupon";
            }
        });
</script>

</html>
