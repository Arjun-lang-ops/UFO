<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Coupon Management - Football Accessories Store</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .material-symbols-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased">
    <div class="flex min-h-screen">
        <!-- SideNavBar -->
        <aside
            class="w-72 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark flex flex-col shrink-0">
            <div class="p-6 flex flex-col h-full">
                <div class="flex items-center gap-3 mb-10">
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 border-2 border-primary"
                        data-alt="Football store professional brand logo"
                        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCk3wqgFU9wWwRMWzUs480IpZlOBTjl_Els-wMkVB0gVBclDEl-octXQBJRSl8oLKjSBuDnB5b1Yni42xYvCWy5uOdji9YS9bTw96Bwow1KrhS613OKtYgqfdU34HL9DLTg-652U_mM4_4jllHip8HMi22H8m7MBe1OyNjUKU_DfHI9TE9Eur7VwvceJuLfU_Nk2G-lIJnFJpkZ0HqPi_LgvdlaGwuUF2bkKSTzSnD0n7Z--jHB2Hu3MpaOZhpQXJigX2vXIYOp6Rc");'>
                    </div>
                    <div class="flex flex-col">
                        <h1 class="text-slate-900 dark:text-white text-base font-bold leading-tight">Admin Panel</h1>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-normal">Football Accessories</p>
                    </div>
                </div>
                <nav class="flex flex-col gap-2 flex-1">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="/admin/dashboard">
                        <span class="material-symbols-outlined">dashboard</span>
                        <p class="text-sm font-medium">Dashboard</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">inventory_2</span>
                        <p class="text-sm font-medium">Products</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <p class="text-sm font-medium">Orders</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary text-white shadow-lg shadow-primary/20"
                        href="#">
                        <span class="material-symbols-outlined material-symbols-fill">confirmation_number</span>
                        <p class="text-sm font-medium">Coupons</p>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">analytics</span>
                        <p class="text-sm font-medium">Analytics</p>
                    </a>
                </nav>
                <div class="mt-auto pt-6 border-t border-slate-200 dark:border-slate-800">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        href="#">
                        <span class="material-symbols-outlined">settings</span>
                        <p class="text-sm font-medium">Settings</p>
                    </a>
                    <div class="flex items-center gap-3 px-4 py-4 mt-2">
                        <div
                            class="size-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-xs font-bold">
                            JD</div>
                        <div class="flex flex-col">
                            <p class="text-xs font-bold">John Doe</p>
                            <p class="text-[10px] text-slate-500">Store Manager</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto">
            <div class="max-w-6xl mx-auto p-8">
                <!-- Breadcrumbs -->
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Admin</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <a class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary transition-colors"
                        href="#">Marketing</a>
                    <span
                        class="text-slate-400 dark:text-[#9dabb9] material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-slate-900 dark:text-white text-sm font-bold">Coupons</span>
                </div>
                <!-- PageHeading -->
                <div class="flex flex-wrap justify-between items-center gap-4 mb-8">
                    <div>
                        <h2 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight">
                            Coupon Management</h2>
                        <p class="text-slate-500 dark:text-[#9dabb9] mt-1">Create and manage promotional offers for your
                            store.</p>
                    </div>
                    <a href="/admin/add-coupon">
                        <button
                        class="flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold transition-all shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add_circle</span>
                        <span>Add New Coupon</span>
                    </button>
                    </a>
                </div>
                <!-- Stats Overview -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-2 bg-blue-100 dark:bg-primary/20 rounded-lg">
                                <span class="material-symbols-outlined text-primary">sell</span>
                            </div>
                            <span
                                class="text-green-500 dark:text-[#0bda5b] text-xs font-bold bg-green-500/10 px-2 py-1 rounded">+2.4%</span>
                        </div>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium">Total Active Coupons</p>
                        <p class="text-slate-900 dark:text-white text-3xl font-bold mt-1"><%= coupons.filter(coupon => coupon.isActive && coupon.expiryDate >= new Date()).length %></p>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-2 bg-green-100 dark:bg-green-500/20 rounded-lg">
                                <span
                                    class="material-symbols-outlined text-green-600 dark:text-green-400">group_work</span>
                            </div>
                            <span
                                class="text-green-500 dark:text-[#0bda5b] text-xs font-bold bg-green-500/10 px-2 py-1 rounded">+15%</span>
                        </div>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium">Total Redeemed</p>
                        <p class="text-slate-900 dark:text-white text-3xl font-bold mt-1"><%= coupons.reduce((total, coupon) => total + (coupon.usedCount || 0), 0) %></p>
                    </div>
                    <div
                        class="bg-white dark:bg-[#1a232e] rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-2 bg-amber-100 dark:bg-amber-500/20 rounded-lg">
                                <span
                                    class="material-symbols-outlined text-amber-600 dark:text-amber-400">payments</span>
                            </div>
                            <span
                                class="text-green-500 dark:text-[#0bda5b] text-xs font-bold bg-green-500/10 px-2 py-1 rounded">+8%</span>
                        </div>
                        <p class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium">Total Coupons</p>
                        <p class="text-slate-900 dark:text-white text-3xl font-bold mt-1"><%= coupons.length %></p>
                    </div>
                </div>
                <!-- Search and Filters -->
                <div
                    class="bg-white dark:bg-[#1a232e] rounded-t-xl border-x border-t border-slate-200 dark:border-slate-800 p-4">
                    <div class="flex flex-col md:flex-row gap-4 items-center">
                        <div class="relative flex-1 w-full">
                            <span
                                class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 dark:text-[#9dabb9]">search</span>
                            <input
                                class="w-full pl-12 pr-4 py-3 rounded-lg border-none bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] text-sm focus:ring-2 focus:ring-primary/50 transition-all"
                                placeholder="Search promo codes (e.g. KICKOFF20)..." />
                        </div>
                        <div class="flex items-center gap-2 w-full md:w-auto">
                            <button
                                class="flex items-center gap-2 px-4 py-3 bg-slate-100 dark:bg-[#283039] text-slate-700 dark:text-white rounded-lg text-sm font-medium border-none hover:bg-slate-200 dark:hover:bg-[#323b46] transition-all">
                                <span class="material-symbols-outlined text-lg">filter_list</span>
                                <span>Filter</span>
                            </button>
                            <button
                                class="flex items-center gap-2 px-4 py-3 bg-slate-100 dark:bg-[#283039] text-slate-700 dark:text-white rounded-lg text-sm font-medium border-none hover:bg-slate-200 dark:hover:bg-[#323b46] transition-all">
                                <span class="material-symbols-outlined text-lg">export_notes</span>
                                <span>Export</span>
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Coupon Table -->
                <div
                    class="bg-white dark:bg-[#1a232e] border border-slate-200 dark:border-slate-800 rounded-b-xl overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-50 dark:bg-[#283039]/30 text-slate-500 dark:text-[#9dabb9] text-xs font-bold uppercase tracking-wider">
                                    <th class="px-6 py-4">Code &amp; Description</th>
                                    <th class="px-6 py-4">Type</th>
                                    <th class="px-6 py-4">Usage</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4">Expiry Date</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                <% if (coupons && coupons.length) { %>
                                    <% coupons.forEach((coupon) => {
                                        const isExpired = coupon.expiryDate && coupon.expiryDate < new Date();
                                        const isActive = coupon.isActive && !isExpired;
                                        const statusText = isExpired ? "Expired" : (coupon.isActive ? "Active" : "Inactive");
                                        const usageLimit = coupon.usageLimit || 0;
                                        const usedCount = coupon.usedCount || 0;
                                        const usagePercent = usageLimit > 0 ? Math.min(Math.round((usedCount / usageLimit) * 100), 100) : 0;
                                        const discountText = coupon.discountType === "PERCENTAGE" ? `${coupon.discountValue}% Off` : `Rs. ${coupon.discountValue} Off`;
                                        const expiryText = coupon.expiryDate ? coupon.expiryDate.toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) : "No Expiry";
                                    %>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors <%= isExpired ? 'opacity-70' : '' %>">
                                            <td class="px-6 py-4">
                                                <div class="flex flex-col">
                                                    <span class="<%= isExpired ? 'text-slate-400 dark:text-slate-500 line-through' : 'text-slate-900 dark:text-white' %> font-bold text-sm tracking-wide"><%= coupon.code %></span>
                                                    <span class="text-slate-500 dark:text-slate-400 text-xs"><%= coupon.description || "No description added" %></span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm"><%= discountText %></td>
                                            <td class="px-6 py-4">
                                                <div class="flex flex-col gap-1 w-32">
                                                    <div class="flex justify-between text-[10px] font-bold">
                                                        <span><%= usagePercent %>%</span>
                                                        <span class="text-slate-400"><%= usedCount %>/<%= usageLimit %></span>
                                                    </div>
                                                    <div
                                                        class="w-full bg-slate-200 dark:bg-slate-700 h-1.5 rounded-full overflow-hidden">
                                                        <div class="<%= isActive ? 'bg-primary' : 'bg-slate-400' %> h-full rounded-full" style="width: <%= usagePercent %>%"></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <% if (isActive) { %>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-[#0bda5b]">
                                                        <span class="size-1.5 rounded-full bg-green-500"></span>
                                                        <%= statusText %>
                                                    </span>
                                                <% } else { %>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                                                        <span class="size-1.5 rounded-full bg-slate-400"></span>
                                                        <%= statusText %>
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-sm <%= isExpired ? 'text-slate-400 dark:text-slate-600' : 'text-slate-600 dark:text-[#9dabb9]' %>"><%= expiryText %></td>
                                            <td class="px-6 py-4 text-right">
                                                <div class="flex justify-end gap-2">
                                                    <a href="/admin/edit-coupon/<%= coupon._id %>"
                                                        class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                            class="material-symbols-outlined text-lg">edit</span></a>
                                                    <button
                                                        class="p-1.5 text-slate-400 hover:text-red-500 transition-colors"><span
                                                            class="material-symbols-outlined text-lg">delete</span></button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="px-6 py-12 text-center text-sm text-slate-500 dark:text-slate-400">
                                            No coupons found.
                                        </td>
                                    </tr>
                                <% } %>
                                <% if (false) { %>
                                <!-- Row 1 Active -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span
                                                class="text-slate-900 dark:text-white font-bold text-sm tracking-wide">GOAL2024</span>
                                            <span class="text-slate-500 dark:text-slate-400 text-xs">Summer kickoff sale
                                                offer</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm">20% Off</td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-1 w-32">
                                            <div class="flex justify-between text-[10px] font-bold">
                                                <span>84%</span>
                                                <span class="text-slate-400">420/500</span>
                                            </div>
                                            <div
                                                class="w-full bg-slate-200 dark:bg-slate-700 h-1.5 rounded-full overflow-hidden">
                                                <div class="bg-primary h-full rounded-full" style="width: 84%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-[#0bda5b]">
                                            <span class="size-1.5 rounded-full bg-green-500"></span>
                                            Active
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-600 dark:text-[#9dabb9]">Aug 30, 2024</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                    class="material-symbols-outlined text-lg">edit</span></button>
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-red-500 transition-colors"><span
                                                    class="material-symbols-outlined text-lg">delete</span></button>
                                        </div>
                                    </td>
                                </tr>
                                <!-- Row 2 Active -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span
                                                class="text-slate-900 dark:text-white font-bold text-sm tracking-wide">FREESHIP</span>
                                            <span class="text-slate-500 dark:text-slate-400 text-xs">Free shipping on
                                                orders &gt; $50</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm">Fixed Amt</td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-1 w-32">
                                            <div class="flex justify-between text-[10px] font-bold">
                                                <span>12%</span>
                                                <span class="text-slate-400">122/∞</span>
                                            </div>
                                            <div
                                                class="w-full bg-slate-200 dark:bg-slate-700 h-1.5 rounded-full overflow-hidden">
                                                <div class="bg-primary h-full rounded-full" style="width: 12%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-[#0bda5b]">
                                            <span class="size-1.5 rounded-full bg-green-500"></span>
                                            Active
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-600 dark:text-[#9dabb9]">No Expiry</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                    class="material-symbols-outlined text-lg">edit</span></button>
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-red-500 transition-colors"><span
                                                    class="material-symbols-outlined text-lg">delete</span></button>
                                        </div>
                                    </td>
                                </tr>
                                <!-- Row 3 Expired -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors opacity-70">
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span
                                                class="text-slate-400 dark:text-slate-500 font-bold text-sm tracking-wide line-through">WINTER23</span>
                                            <span class="text-slate-500 dark:text-slate-500 text-xs">Holiday season
                                                special</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm">15% Off</td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-1 w-32">
                                            <div class="flex justify-between text-[10px] font-bold">
                                                <span>100%</span>
                                                <span class="text-slate-400">1000/1000</span>
                                            </div>
                                            <div
                                                class="w-full bg-slate-200 dark:bg-slate-700 h-1.5 rounded-full overflow-hidden">
                                                <div class="bg-slate-400 h-full rounded-full" style="width: 100%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                                            <span class="size-1.5 rounded-full bg-slate-400"></span>
                                            Expired
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-400 dark:text-slate-600">Jan 01, 2024</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                    class="material-symbols-outlined text-lg">history</span></button>
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                    class="material-symbols-outlined text-lg">content_copy</span></button>
                                        </div>
                                    </td>
                                </tr>
                                <!-- Row 4 Scheduled -->
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span
                                                class="text-slate-900 dark:text-white font-bold text-sm tracking-wide">BLACKFRIDAY</span>
                                            <span class="text-slate-500 dark:text-slate-400 text-xs">Upcoming massive
                                                sale event</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm">40% Off</td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-1 w-32">
                                            <div class="flex justify-between text-[10px] font-bold">
                                                <span>0%</span>
                                                <span class="text-slate-400">0/5000</span>
                                            </div>
                                            <div
                                                class="w-full bg-slate-200 dark:bg-slate-700 h-1.5 rounded-full overflow-hidden">
                                                <div class="bg-primary h-full rounded-full" style="width: 0%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 dark:bg-primary/10 text-primary">
                                            <span class="size-1.5 rounded-full bg-primary"></span>
                                            Scheduled
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-600 dark:text-[#9dabb9]">Nov 24, 2024</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors"><span
                                                    class="material-symbols-outlined text-lg">edit</span></button>
                                            <button
                                                class="p-1.5 text-slate-400 hover:text-red-500 transition-colors"><span
                                                    class="material-symbols-outlined text-lg">delete</span></button>
                                        </div>
                                    </td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination Footer -->
                    <div
                        class="px-6 py-4 bg-slate-50 dark:bg-[#283039]/30 flex flex-wrap justify-between items-center border-t border-slate-200 dark:border-slate-800">
                        <p class="text-xs text-slate-500 dark:text-[#9dabb9]">Showing <span class="font-bold"><%= coupons.length ? `1-${coupons.length}` : "0" %></span>
                            of <span class="font-bold"><%= coupons.length %></span> coupons</p>
                        <div class="flex items-center gap-2">
                            <button
                                class="px-3 py-1.5 rounded border border-slate-200 dark:border-slate-700 text-xs font-bold disabled:opacity-50"
                                disabled="">Previous</button>
                            <div class="flex gap-1">
                                <button class="size-8 rounded bg-primary text-white text-xs font-bold">1</button>
                                <button
                                    class="size-8 rounded hover:bg-slate-100 dark:hover:bg-slate-800 text-xs font-bold transition-colors">2</button>
                                <button
                                    class="size-8 rounded hover:bg-slate-100 dark:hover:bg-slate-800 text-xs font-bold transition-colors">3</button>
                            </div>
                            <button
                                class="px-3 py-1.5 rounded border border-slate-200 dark:border-slate-700 text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>

</html>
