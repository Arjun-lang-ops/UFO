<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Dashboard Overview - Football Accessories</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .active-nav {
            background-color: #137fec;
            color: white;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #283039;
            border-radius: 10px;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex">
        <%- include('partials/sidebar', { activePage: 'dashboard' }) %>
    <main class="ml-64 flex-1 flex flex-col min-h-screen">
        <header
            class="sticky top-0 z-40 bg-white dark:bg-[#111418]/80 backdrop-blur-md border-b border-slate-200 dark:border-[#283039] px-8 py-3 flex items-center justify-between">
            <div class="flex items-center gap-4 flex-1">
                <div class="relative w-full max-w-md">
                    <span
                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
                    <input
                        class="w-full bg-slate-100 dark:bg-[#283039] border-none rounded-lg py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-primary dark:text-white dark:placeholder-[#9dabb9]"
                        placeholder="Search orders, products, customers..." type="text" />
                </div>
            </div>

        </header>
        <div class="p-8">
            <div class="flex flex-wrap justify-between items-end gap-4 mb-8">
                <div>
                    <h2 class="text-3xl font-black tracking-tight dark:text-white">Dashboard Overview</h2>
                    <p class="text-slate-500 dark:text-[#9dabb9] mt-1">Welcome back, here's what's happening with your
                        store today.</p>
                </div>
                
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white dark:bg-[#111418] p-6 rounded-xl border border-slate-200 dark:border-[#3b4754]">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2 bg-primary/10 rounded-lg text-primary">
                            <span class="material-symbols-outlined">payments</span>
                        </div>
                        <span
                            class="text-[#0bda5b] text-xs font-bold bg-[#0bda5b]/10 px-2 py-1 rounded-full">+12.5%</span>
                    </div>
                    <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-semibold uppercase tracking-wider">Total
                        Sales</p>
                    <p class="text-2xl font-black dark:text-white mt-1">₹<%= typeof totalSales !== 'undefined' ? totalSales.toFixed(2) : '0.00' %></p>
                    <div class="mt-4 h-1 w-full bg-slate-100 dark:bg-[#283039] rounded-full overflow-hidden">
                        <div class="h-full bg-primary" style="width: 75%"></div>
                    </div>
                </div>
                <div class="bg-white dark:bg-[#111418] p-6 rounded-xl border border-slate-200 dark:border-[#3b4754]">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2 bg-orange-500/10 rounded-lg text-orange-500">
                            <span class="material-symbols-outlined">shopping_cart</span>
                        </div>
                        <span
                            class="text-[#0bda5b] text-xs font-bold bg-[#0bda5b]/10 px-2 py-1 rounded-full">+8.2%</span>
                    </div>
                    <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-semibold uppercase tracking-wider">Total
                        Orders</p>
                    <p class="text-2xl font-black dark:text-white mt-1"><%= typeof totalOrders !== 'undefined' ? totalOrders : '0' %></p>
                    <div class="mt-4 h-1 w-full bg-slate-100 dark:bg-[#283039] rounded-full overflow-hidden">
                        <div class="h-full bg-orange-500" style="width: 45%"></div>
                    </div>
                </div>
                <div class="bg-white dark:bg-[#111418] p-6 rounded-xl border border-slate-200 dark:border-[#3b4754]">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2 bg-green-500/10 rounded-lg text-green-500">
                            <span class="material-symbols-outlined">person_add</span>
                        </div>
                        <span class="text-red-500 text-xs font-bold bg-red-500/10 px-2 py-1 rounded-full">-2.1%</span>
                    </div>
                    <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-semibold uppercase tracking-wider">Active
                        Users</p>
                    <p class="text-2xl font-black dark:text-white mt-1"><%= typeof activeUsers !== 'undefined' ? activeUsers : '0' %></p>
                    <div class="mt-4 h-1 w-full bg-slate-100 dark:bg-[#283039] rounded-full overflow-hidden">
                        <div class="h-full bg-green-500" style="width: 60%"></div>
                    </div>
                </div>
                
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-1 gap-6 mb-8">
                <div
                    class="lg:col-span-2 bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#3b4754] p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="font-bold text-lg dark:text-white">Revenue Over Time</h3>
                            <div class="flex items-center gap-2">
                                <span class="text-2xl font-black dark:text-white">Sales Analysis</span>
                            </div>
                        </div>
                        <select id="chartFilter"
                            class="bg-slate-50 dark:bg-[#283039] border-none text-xs font-bold rounded-lg focus:ring-primary dark:text-[#9dabb9]">
                            <option value="weekly">Last 7 Days</option>
                            <option value="monthly">Last 30 Days</option>
                            <option value="yearly">This Year</option>
                        </select>
                    </div>
                    <div class="h-64">
    <canvas id="revenueChart"></canvas>
</div>
                </div>
               
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Best Selling Products -->
                <div class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#3b4754] overflow-hidden p-6 flex flex-col">
                    <div class="flex items-center justify-between mb-4 border-b border-slate-100 dark:border-[#283039] pb-3">
                        <h3 class="font-bold text-lg dark:text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">workspace_premium</span>
                            Best Selling Products (Top 5)
                        </h3>
                    </div>
                    <div class="overflow-x-auto flex-1">
                        <table class="w-full text-left">
                            <thead class="bg-slate-50 dark:bg-[#283039] text-slate-500 dark:text-[#9dabb9] text-xs uppercase font-bold tracking-wider">
                                <tr>
                                    <th class="px-4 py-2">Product</th>
                                    <th class="px-4 py-2 text-center">Qty Sold</th>
                                    <th class="px-4 py-2 text-right">Revenue</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-[#283039]">
                                <% if (typeof bestSellingProducts !== 'undefined' && bestSellingProducts.length > 0) { %>
                                    <% bestSellingProducts.forEach((item, index) => { %>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-[#1c242e] transition-colors">
                                            <td class="px-4 py-3 flex items-center gap-3">
                                                <% 
                                                   let imgUrl = "";
                                                   if (item.productDetails.variants && item.productDetails.variants[0] && item.productDetails.variants[0].images && item.productDetails.variants[0].images[0]) {
                                                       imgUrl = item.productDetails.variants[0].images[0];
                                                       if (!imgUrl.startsWith("http") && !imgUrl.startsWith("/")) {
                                                           imgUrl = "/" + imgUrl.replace(/\\/g, '/');
                                                       }
                                                   }
                                                %>
                                                <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-[#283039] overflow-hidden flex items-center justify-center border border-slate-200 dark:border-slate-700 shrink-0">
                                                    <% if (imgUrl) { %>
                                                        <img src="<%= imgUrl %>" class="object-cover w-full h-full" alt="<%= item.productDetails.name %>">
                                                    <% } else { %>
                                                        <span class="material-symbols-outlined text-slate-400">image</span>
                                                    <% } %>
                                                </div>
                                                <div class="min-w-0">
                                                    <span class="text-sm font-bold dark:text-white block truncate max-w-[180px]" title="<%= item.productDetails.name %>"><%= item.productDetails.name %></span>
                                                    <span class="text-xs text-slate-500 dark:text-[#9dabb9]">Rank #<%= index + 1 %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-3 text-center text-sm font-semibold dark:text-white">
                                                <%= item.totalQuantity %>
                                            </td>
                                            <td class="px-4 py-3 text-right text-sm font-bold text-primary">
                                                ₹<%= item.totalRevenue.toFixed(2) %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-500">No product sales data available</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Best Selling Categories -->
                <div class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#3b4754] overflow-hidden p-6 flex flex-col">
                    <div class="flex items-center justify-between mb-4 border-b border-slate-100 dark:border-[#283039] pb-3">
                        <h3 class="font-bold text-lg dark:text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-orange-500">category</span>
                            Best Selling Categories (Top 5)
                        </h3>
                    </div>
                    <div class="overflow-x-auto flex-1">
                        <table class="w-full text-left">
                            <thead class="bg-slate-50 dark:bg-[#283039] text-slate-500 dark:text-[#9dabb9] text-xs uppercase font-bold tracking-wider">
                                <tr>
                                    <th class="px-4 py-2">Category</th>
                                    <th class="px-4 py-2 text-center">Qty Sold</th>
                                    <th class="px-4 py-2 text-right">Revenue</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-[#283039]">
                                <% if (typeof bestSellingCategories !== 'undefined' && bestSellingCategories.length > 0) { %>
                                    <% bestSellingCategories.forEach((item, index) => { %>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-[#1c242e] transition-colors">
                                            <td class="px-4 py-3">
                                                <div class="flex flex-col">
                                                    <span class="text-sm font-bold dark:text-white truncate max-w-[180px]"><%= item.categoryDetails.name %></span>
                                                    <span class="text-xs text-slate-500 dark:text-[#9dabb9]">Rank #<%= index + 1 %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-3 text-center text-sm font-semibold dark:text-white">
                                                <%= item.totalQuantity %>
                                            </td>
                                            <td class="px-4 py-3 text-right text-sm font-bold text-orange-500">
                                                ₹<%= item.totalRevenue.toFixed(2) %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-500">No category sales data available</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>
    </div>


    <script>

const labels = <%- JSON.stringify(labels || []) %>;
const revenue = <%- JSON.stringify(revenue || []) %>;

const ctx = document.getElementById('revenueChart').getContext('2d');

const revenueChart = new Chart(ctx, {
    type: 'line',
    data: {
        labels: labels,
        datasets: [{
            label: 'Revenue',
            data: revenue,
            borderColor: '#137fec',
            backgroundColor: 'rgba(19,127,236,0.2)',
            tension: 0.4,
            fill: true,
            pointRadius: 4,
            pointHoverRadius: 6
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: true
            }
        },
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});

const filterSelect = document.getElementById('chartFilter');
if (filterSelect) {
    filterSelect.addEventListener('change', async (e) => {
        const filter = e.target.value;
        try {
            const response = await fetch(`/admin/dashboard/chart-data?filter=${filter}`);
            const data = await response.json();
            if (data.success) {
                revenueChart.data.labels = data.labels;
                revenueChart.data.datasets[0].data = data.revenue;
                revenueChart.update();
            }
        } catch (err) {
            console.error('Error fetching chart data:', err);
        }
    });
}

</script>
</body>





</html>