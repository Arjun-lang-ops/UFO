<!DOCTYPE html>
<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Admin Login | FootieAdmin</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#137fec",
                "background-light": "#f6f7f8",
                "background-dark": "#101922",
              },
              fontFamily: {
                "display": ["Inter"]
              },
              borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
            },
          },
        }
    </script>
<style type="text/tailwindcss">
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .bg-pattern {
            background-image: radial-gradient(#137fec 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.05;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-white min-h-screen flex flex-col">
<div class="fixed inset-0 bg-pattern pointer-events-none"></div>
<div class="relative flex h-full grow flex-col">
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-b-gray-200 dark:border-b-[#283039] px-6 lg:px-10 py-3 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md z-10">
<div class="flex items-center gap-4 text-primary">
<div class="size-6">
<svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M12.0799 24L4 19.2479L9.95537 8.75216L18.04 13.4961L18.0446 4H29.9554L29.96 13.4961L38.0446 8.75216L44 19.2479L35.92 24L44 28.7521L38.0446 39.2479L29.96 34.5039L29.9554 44H18.0446L18.04 34.5039L9.95537 39.2479L4 28.7521L12.0799 24Z" fill="currentColor" fill-rule="evenodd"></path>
</svg>
</div>
<h2 class="text-gray-900 dark:text-white text-lg font-bold leading-tight tracking-[-0.015em]">Urban Football</h2>
</div>
<div class="flex flex-1 justify-end gap-4 lg:gap-8">
<div class="flex items-center gap-4">
<a class="text-gray-600 dark:text-gray-300 text-sm font-medium leading-normal hover:text-primary transition-colors" href="#">Return to Storefront</a>
</div>
<button class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
<span class="truncate">Help Center</span>
</button>
</div>
</header>
<main class="flex-1 flex items-center justify-center p-6 relative">
<div class="w-full max-w-[440px] z-10">
<div class="bg-white dark:bg-[#1c2127] rounded-xl border border-gray-200 dark:border-[#3b4754] shadow-2xl overflow-hidden">
<div class="p-8 pb-4">
<div class="flex justify-center mb-4">
<div class="bg-primary/10 p-3 rounded-full">
<span class="material-symbols-outlined text-primary text-3xl">admin_panel_settings</span>
</div>
</div>
<h1 class="text-gray-900 dark:text-white tracking-tight text-[28px] font-bold leading-tight text-center pb-2">Control Center Login</h1>
<p class="text-gray-500 dark:text-[#9dabb9] text-sm font-normal leading-normal text-center">Enter your credentials to manage the store.</p>
</div>
<form id="adminLoginForm" class="p-8 pt-0 flex flex-col gap-5">
<div class="flex flex-col gap-1.5">
<label class="text-gray-700 dark:text-white text-sm font-medium leading-normal px-1">Admin ID / Email</label>
<div class="flex w-full items-stretch rounded-lg shadow-sm">
<input id="adminEmail" class="flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-gray-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-gray-300 dark:border-[#3b4754] bg-gray-50 dark:bg-[#1c2127] h-12 placeholder:text-gray-400 dark:placeholder:text-[#9dabb9] p-[12px] rounded-r-none border-r-0 pr-2 text-base font-normal transition-all" placeholder="e.g. admin@football.com" type="email"/>
<div class="text-gray-400 dark:text-[#9dabb9] flex border border-gray-300 dark:border-[#3b4754] bg-gray-50 dark:bg-[#1c2127] items-center justify-center pr-[12px] rounded-r-lg border-l-0">
<span class="material-symbols-outlined text-[20px]">person</span>
</div>
</div>
</div>
<p id="emailError" class="text-red-500 text-xs mt-1 hidden"></p>
<div class="flex flex-col gap-1.5">
<div class="flex justify-between items-center px-1">
<label class="text-gray-700 dark:text-white text-sm font-medium leading-normal">Password</label>
</div>
<div class="flex w-full items-stretch rounded-lg shadow-sm">
<input id="adminPassword" class="flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-gray-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-gray-300 dark:border-[#3b4754] bg-gray-50 dark:bg-[#1c2127] h-12 placeholder:text-gray-400 dark:placeholder:text-[#9dabb9] p-[12px] rounded-r-none border-r-0 pr-2 text-base font-normal transition-all" placeholder="••••••••" type="password"/>
<div class="password-toggle text-gray-400 dark:text-[#9dabb9] flex border border-gray-300 dark:border-[#3b4754] bg-gray-50 dark:bg-[#1c2127] items-center justify-center pr-[12px] rounded-r-lg border-l-0 cursor-pointer hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</div>
</div>
</div>
<p id="passwordError" class="text-red-500 text-xs mt-1 hidden"></p>
<div class="flex items-center justify-between py-2">
<label class="flex items-center gap-2 cursor-pointer group">
<div class="relative flex items-center">
<input class="peer h-5 w-5 cursor-pointer appearance-none rounded border border-gray-300 dark:border-[#3b4754] bg-gray-50 dark:bg-[#1c2127] checked:bg-primary checked:border-primary focus:ring-primary focus:ring-offset-0" type="checkbox"/>
<span class="material-symbols-outlined absolute text-white opacity-0 peer-checked:opacity-100 text-sm left-1/2 -translate-x-1/2 pointer-events-none">check</span>
</div>
<span class="text-sm text-gray-600 dark:text-[#9dabb9] group-hover:text-gray-900 dark:group-hover:text-white transition-colors">Keep me logged in</span>
</label>
</div>
<button class="w-full flex h-12 cursor-pointer items-center justify-center rounded-lg bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 active:scale-[0.98] transition-all shadow-lg shadow-primary/30" type="submit">
                            Login to Admin Panel
                        </button>
</form>
<div class="bg-gray-50 dark:bg-[#131920] px-8 py-4 border-t border-gray-200 dark:border-[#3b4754] flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-green-500 text-[18px]">verified_user</span>
<span class="text-[11px] uppercase tracking-widest text-gray-400 dark:text-[#5c6d7e] font-bold">Secure 256-bit Encryption</span>
</div>
</div>
<div class="mt-8 flex flex-col items-center gap-2">
<p class="text-gray-500 dark:text-[#5c6d7e] text-xs">Access restricted to authorized personnel only.</p>
<div class="flex gap-4">
<a class="text-xs text-gray-400 dark:text-[#5c6d7e] hover:text-primary transition-colors" href="#">Privacy Policy</a>
<span class="text-gray-700 dark:text-[#3b4754]">•</span>
<a class="text-xs text-gray-400 dark:text-[#5c6d7e] hover:text-primary transition-colors" href="#">Security Standards</a>
</div>
</div>
</div>
</main>
<div class="absolute bottom-0 left-0 p-10 hidden xl:block opacity-20">
<div class="text-primary/40 text-[120px] font-black leading-none select-none">ADMIN</div>
</div>
</div>

</body>
<script src="/adminJs/loginValidation.js"></script>
<script src="/js/passwordToggle.js"></script>
</html>