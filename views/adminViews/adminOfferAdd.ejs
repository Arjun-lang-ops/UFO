<!DOCTYPE html>
<html class="dark" lang="en" style="">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Add New Offer | Urban Football Console</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&amp;family=Noto+Sans:wght@300;400;500;600&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-container": "#2c4770",
                        "on-tertiary-fixed": "#321200",
                        "error-container": "#93000a",
                        "on-surface": "#f6f7f8",
                        "tertiary-container": "#e47019",
                        "surface-container-low": "#101922",
                        "tertiary": "#ffb68c",
                        "tertiary-fixed": "#ffdbc9",
                        "surface-container-highest": "#283039",
                        "on-error-container": "#ffdad6",
                        "surface-container-lowest": "#080c11",
                        "on-tertiary-container": "#481d00",
                        "on-secondary-container": "#9bb6e5",
                        "on-primary": "#ffffff",
                        "on-tertiary-fixed-variant": "#753400",
                        "on-secondary-fixed-variant": "#2c4770",
                        "on-primary-container": "#ffffff",
                        "primary": "#137fec",
                        "on-error": "#690005",
                        "primary-container": "#137fec",
                        "secondary-fixed-dim": "#adc8f7",
                        "on-background": "#f6f7f8",
                        "on-secondary": "#123158",
                        "surface-bright": "#1c2632",
                        "primary-fixed-dim": "#a8c8ff",
                        "on-surface-variant": "#9dabb9",
                        "on-primary-fixed": "#001b3c",
                        "inverse-surface": "#f6f7f8",
                        "tertiary-fixed-dim": "#ffb68c",
                        "secondary-fixed": "#d5e3ff",
                        "on-tertiary": "#532200",
                        "inverse-primary": "#005eb4",
                        "inverse-on-surface": "#101922",
                        "background": "#101922",
                        "surface-variant": "#1c2632",
                        "surface-container-high": "#1c2632",
                        "primary-fixed": "#d5e3ff",
                        "surface-tint": "#137fec",
                        "surface-container": "#151f2a",
                        "surface-dim": "#0d141b",
                        "secondary": "#adc8f7",
                        "outline-variant": "#414753",
                        "outline": "#283039",
                        "on-secondary-fixed": "#001b3c",
                        "error": "#ffb4ab",
                        "on-primary-fixed-variant": "#004689",
                        "surface": "#101922"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Lexend"],
                        "display": ["Lexend"],
                        "body": ["Lexend"],
                        "label": ["Lexend"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        ::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
    </style>
</head>

<body class="bg-background text-on-surface font-body min-h-screen flex">
    <!-- SideNavBar Component (JSON Anchor) -->
    <aside
        class="h-screen w-64 fixed left-0 top-0 bg-surface-container dark:bg-surface-container flex flex-col py-6 px-4 z-50">
        <div class="mb-10 px-2">
            <h1 class="font-headline font-bold text-2xl tracking-tighter text-on-surface">Urban Football</h1>
            <p class="text-xs text-on-surface-variant font-medium opacity-70">Admin Console</p>
        </div>
        <nav class="flex-1 space-y-2">
            <!-- Dashboard Tab -->
            <a class="flex items-center gap-3 px-3 py-2 text-on-surface-variant font-medium hover:bg-surface-bright transition-colors duration-200 active:scale-95 transition-transform"
                href="/admin/dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-body text-label tracking-normal">Dashboard</span>
            </a>
            <!-- Products Tab -->
            <a class="flex items-center gap-3 px-3 py-2 text-on-surface-variant font-medium hover:bg-surface-bright transition-colors duration-200 active:scale-95 transition-transform"
                href="#">
                <span class="material-symbols-outlined">inventory_2</span>
                <span class="font-body text-label tracking-normal">Products</span>
            </a>
            <!-- Promotions Tab (ACTIVE) -->
            <a class="flex items-center gap-3 px-3 py-2 text-primary font-bold border-r-2 border-primary hover:bg-surface-bright transition-colors duration-200 active:scale-95 transition-transform"
                href="#"><span class="material-symbols-outlined"
                    style="font-variation-settings: &quot;FILL&quot; 1;">local_offer</span><span
                    class="font-body text-label tracking-normal">Offers</span></a>
            <!-- Categories Tab -->
            <a class="flex items-center gap-3 px-3 py-2 text-on-surface-variant font-medium hover:bg-surface-bright transition-colors duration-200 active:scale-95 transition-transform"
                href="#">
                <span class="material-symbols-outlined">category</span>
                <span class="font-body text-label tracking-normal">Categories</span>
            </a>
            <!-- Settings Tab -->
            <a class="flex items-center gap-3 px-3 py-2 text-on-surface-variant font-medium hover:bg-surface-bright transition-colors duration-200 active:scale-95 transition-transform"
                href="#">
                <span class="material-symbols-outlined">settings</span>
                <span class="font-body text-label tracking-normal">Settings</span>
            </a>
        </nav>

    </aside>
    <!-- Main Content Canvas -->
    <main class="ml-64 flex-1 min-h-screen relative overflow-hidden">
        <!-- Header Shell -->
        <header
            class="flex justify-between items-center h-16 px-8 sticky top-0 z-40 backdrop-blur-md bg-surface-dim shadow-lg">
            <div class="flex items-center gap-4">
                <a href="/admin/offers"
                    class="flex items-center text-on-surface-variant hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <h2 class="font-headline text-xl tracking-tight text-on-surface">Offer Engine</h2>
            </div>
            <div class="flex items-center gap-6">
                <div class="relative hidden lg:block">
                    <input
                        class="bg-surface-container-highest border-none rounded-full px-5 py-1.5 text-sm w-64 focus:ring-1 focus:ring-primary placeholder:text-on-surface-variant/50"
                        placeholder="Search parameters..." type="text">
                    <span
                        class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg">search</span>
                </div>
                <div class="flex items-center gap-4 text-on-surface-variant">
                    <span
                        class="material-symbols-outlined cursor-pointer hover:text-primary transition-colors">notifications</span>
                    <div
                        class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container cursor-pointer overflow-hidden">
                        <img alt="Admin User Profile" class="w-full h-full object-cover"
                            data-alt="A professional portrait of a tech-savvy administrator in a high-tech office environment. The background features blurred digital screens and modern lighting. The aesthetic is clean and corporate, matching the deep blue and slate tones of the Midnight Pitch design system. High resolution, professional studio lighting."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvXyDNTtOIdaQx1nw6R5EKiUAQrFKOgtg6IOI702zfRLz2f3BYyPs9c4qpN6T4hLx0nl4-TB52SyDEDaTXNGcy40hVe7kWQPxNPq_d0e-A-4LUpoEq0CzybnQOOT9T85zbfNHJ-WRfB9BCFRTDJmKsVxiwdx_doO_eEvmw-5NUCjZbKUgehe7lbmZXgWVFEhzejxlNt5zhj2zlgeXGfSBoZQr1YIEWZ33wuArDZ52akOiLjlAfQ8udp9qVHNaJR9rap_mZeJn64Oc">
                    </div>
                </div>
            </div>
        </header>
        <!-- Form Section -->
        <div class="p-8 lg:p-12 max-w-5xl mx-auto">
            <div class="mb-8">
                <h3 class="font-display text-4xl font-extrabold tracking-tight mb-2">Add New Offer</h3>
                <p class="text-on-surface-variant">Create an offer template that can be assigned from product or
                    category management.</p>
            </div>
            <!-- Bento Grid Form Layout -->
            <form class="grid grid-cols-1 md:grid-cols-12 gap-6" id="offerForm">
                <!-- Primary Information -->
                <div class="md:col-span-8 bg-surface-container-high rounded-xl p-8 transition-all hover:shadow-2xl">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-widest"
                                for="offer_name">Offer Name</label>
                            <input
                                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all placeholder:opacity-30 font-medium"
                                id="offer_name" placeholder="e.g. Summer Kickoff 2024" type="text">
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-widest"
                                    for="offer_type">Offer Type</label>
                                <div class="relative">
                                    <select
                                        class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary appearance-none cursor-pointer"
                                        id="offer_type">
                                        <option value="" disabled="" selected="">Select Type</option>
                                        <option value="Product">Product</option>
                                        <option value="Category">Category</option>
                                    </select>
                                    <span
                                        class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">expand_more</span>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-widest"
                                    for="discount_type">Discount Type</label>
                                <div class="flex bg-surface-container-highest p-1 rounded-lg">
                                    <button
                                        class="flex-1 py-3 px-4 rounded font-bold text-sm transition-all bg-primary text-on-primary"
                                        id="btn-percentage" onclick="setDiscountType('percentage')"
                                        type="button">Percentage</button>
                                    <button
                                        class="flex-1 py-3 px-4 rounded font-bold text-sm transition-all text-on-surface-variant hover:text-on-surface"
                                        id="btn-flat" onclick="setDiscountType('flat')" type="button">Flat</button>
                                </div>
                                <input id="discount_type" type="hidden" value="Percentage">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-widest"
                                    for="discount_value">Discount Value</label>
                                <div class="relative">
                                    <input
                                        class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary placeholder:opacity-30"
                                        id="discount_value" placeholder="0" type="number">
                                    <span
                                        class="absolute right-4 top-1/2 -translate-y-1/2 font-bold text-on-surface-variant"
                                        id="discount-unit">%</span>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2 uppercase tracking-widest"
                                    for="max_discount">Maximum Discount Value</label>
                                <div class="relative">
                                    <input
                                        class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary placeholder:opacity-30"
                                        id="max_discount" placeholder="0.00" type="number">
                                    <span
                                        class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-on-surface-variant">Rs</span>
                                    <style>
                                        #max_discount {
                                            padding-left: 2.5rem;
                                        }
                                    </style>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Validity & Status -->
                <div class="md:col-span-4 space-y-6">
                    <div class="bg-surface-container-high rounded-xl p-6 transition-all">
                        <h4
                            class="text-sm font-bold text-primary mb-4 uppercase tracking-widest flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">toggle_on</span>
                            Offer Status
                        </h4>
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-on-surface">Active</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="is_active" class="sr-only peer" checked>
                                <div
                                    class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-on-surface after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary">
                                </div>
                            </label>
                        </div>
                        <p class="text-[10px] text-on-surface-variant mt-3 opacity-70">Toggle to enable or disable this
                            offer across the storefront.</p>
                    </div>
                    <div class="bg-surface-container-high rounded-xl p-6 transition-all">
                        <h4
                            class="text-sm font-bold text-primary mb-4 uppercase tracking-widest flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">event</span>
                            Offer Validity
                        </h4>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-medium text-on-surface-variant mb-1"
                                    for="start_date">Start Date</label>
                                <input
                                    class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-sm text-on-surface focus:ring-2 focus:ring-primary"
                                    id="start_date" type="date">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-on-surface-variant mb-1" for="end_date">End
                                    Date</label>
                                <input
                                    class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-sm text-on-surface focus:ring-2 focus:ring-primary"
                                    id="end_date" type="date">
                            </div>
                        </div>
                    </div>

                   
                </div>
                <!-- Action Footer -->
                <div class="md:col-span-12 flex items-center justify-end gap-4 mt-4 pt-8 border-t border-outline/30">
                    <a href="/admin/offers">
                        <button
                            class="px-8 py-3 rounded text-on-surface-variant font-bold hover:text-on-surface hover:bg-surface-bright transition-all active:scale-95"
                            type="button">
                            Cancel
                        </button>
                    </a>
                    <button
                        class="px-12 py-3 rounded bg-primary text-on-primary font-extrabold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all active:scale-95"
                        type="submit">
                        Save Offer
                    </button>
                </div>
            </form>
        </div>
        <!-- Background Atmospheric Element -->
        <div class="fixed -bottom-32 -right-32 w-96 h-96 bg-primary/10 rounded-full blur-[120px] pointer-events-none">
        </div>
        <div
            class="fixed top-1/4 -left-20 w-64 h-64 bg-secondary-container/5 rounded-full blur-[100px] pointer-events-none">
        </div>
    </main>
    <script>
        function setDiscountType(type) {
            const btnPercentage = document.getElementById('btn-percentage');
            const btnFlat = document.getElementById('btn-flat');
            const unitLabel = document.getElementById('discount-unit');
            const hiddenInput = document.getElementById('discount_type');

            if (type === 'percentage') {
                btnPercentage.classList.add('bg-primary', 'text-on-primary');
                btnPercentage.classList.remove('text-on-surface-variant');
                btnFlat.classList.remove('bg-primary', 'text-on-primary');
                btnFlat.classList.add('text-on-surface-variant');
                unitLabel.textContent = '%';
                hiddenInput.value = 'Percentage';
            } else {
                btnFlat.classList.add('bg-primary', 'text-on-primary');
                btnFlat.classList.remove('text-on-surface-variant');
                btnPercentage.classList.remove('bg-primary', 'text-on-primary');
                btnPercentage.classList.add('text-on-surface-variant');
                unitLabel.textContent = 'Rs';
                hiddenInput.value = 'Flat';
            }
        }

        // Form Submission and Validation Logic
        document.getElementById('offerForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const btn = e.target.querySelector('button[type="submit"]');

            // Gather values
            const name = document.getElementById('offer_name').value.trim();
            const offerType = document.getElementById('offer_type').value;
            const discountType = document.getElementById('discount_type').value; // 'Percentage' or 'Flat'
            const discountValueRaw = document.getElementById('discount_value').value;
            const maxDiscountRaw = document.getElementById('max_discount').value;
            const startDateVal = document.getElementById('start_date').value;
            const endDateVal = document.getElementById('end_date').value;
            const isActive = document.getElementById('is_active').checked;

            // Validation Helper
            const showError = (msg) => {
                Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: msg,
                    confirmButtonColor: '#137fec'
                });
            };

            // 1. Name Validation
            if (!name) {
                return showError("Offer Name is required.");
            }
            if (name.length < 3) {
                return showError("Offer Name must be at least 3 characters.");
            }

            // 2. Offer Type Validation
            if (!offerType) {
                return showError("Please select an Offer Type (Product or Category).");
            }

            // 3. Discount Value Validation
            const discountValue = parseFloat(discountValueRaw);
            if (isNaN(discountValue) || discountValue <= 0) {
                return showError("Discount Value must be a number greater than 0.");
            }

            if (discountType === 'Percentage') {
                if (discountValue < 1 || discountValue > 90) {
                    return showError("Percentage discount must be between 1 and 90.");
                }
            }

            // 4. Max Discount Validation
            const maxDiscount = parseFloat(maxDiscountRaw);
            if (maxDiscountRaw && (isNaN(maxDiscount) || maxDiscount < 0)) {
                return showError("Maximum Discount Value must be a non-negative number.");
            }

            // 5. Dates Validation
            if (!startDateVal) {
                return showError("Please select a Start Date.");
            }
            if (!endDateVal) {
                return showError("Please select an End Date.");
            }

            const start = new Date(startDateVal);
            const end = new Date(endDateVal);
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (start < today) {
                return showError("Start Date cannot be in the past.");
            }

            if (start >= end) {
                return showError("End Date must be strictly after the Start Date.");
            }

            // If valid, format payload
            const payload = {
                name,
                offerType,
                offerMode: discountType.toUpperCase(), // Map "Percentage" / "Flat" to "PERCENTAGE" / "FLAT"
                discountValue,
                product: null,
                category: null,
                startDate: startDateVal,
                endDate: endDateVal,
                isActive
            };

            const originalText = btn.textContent;
            btn.textContent = 'Saving...';
            btn.disabled = true;
            btn.classList.add('opacity-50');

            try {
                const response = await fetch('/admin/offers/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || 'Failed to add offer.');
                }

                await Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: result.message || 'Offer added successfully!',
                    confirmButtonColor: '#137fec'
                });

                window.location.href = '/admin/offers';

            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: error.message,
                    confirmButtonColor: '#d33'
                });
            } finally {
                btn.textContent = originalText;
                btn.disabled = false;
                btn.classList.remove('opacity-50');
            }
        });

        // Micro-interactions for inputs
        document.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('focus', () => {
                el.parentElement.closest('.bg-surface-container-high')?.classList.add('ring-1', 'ring-primary/30');
            });
            el.addEventListener('blur', () => {
                el.parentElement.closest('.bg-surface-container-high')?.classList.remove('ring-1', 'ring-primary/30');
            });
        });
    </script>


</body>

</html>
