<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Order Details #ORD-1024 - ProKick Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .fill-icon {
            font-variation-settings: 'FILL' 1;
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex h-screen overflow-hidden">
        <aside
            class="w-64 flex flex-col border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark shrink-0">
            <div class="p-6 flex items-center gap-3">
                <div class="size-10 bg-primary rounded-lg flex items-center justify-center text-white">
                    <span class="material-symbols-outlined text-2xl">sports_soccer</span>
                </div>
                <div>
                    <h1 class="text-base font-bold leading-tight">Urban Football Admin</h1>
                    <p class="text-slate-500 dark:text-slate-400 text-xs">Accessory Store</p>
                </div>
            </div>
            <nav class="flex-1 px-4 space-y-1 mt-4">
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/dashboard">
                    <span class="material-symbols-outlined">grid_view</span>
                    <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/products">
                    <span class="material-symbols-outlined">inventory_2</span>
                    <span class="text-sm font-medium">Products</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 bg-primary text-white rounded-lg shadow-lg shadow-primary/20"
                    href="/admin/orderManagement">
                    <span class="material-symbols-outlined fill-icon">shopping_cart</span>
                    <span class="text-sm font-medium">Orders</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/userManagement">
                    <span class="material-symbols-outlined">group</span>
                    <span class="text-sm font-medium">Customers</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="#">
                    <span class="material-symbols-outlined">bar_chart</span>
                    <span class="text-sm font-medium">Analytics</span>
                </a>
                
            </nav>
            
        </aside>
        <main class="flex-1 flex flex-col overflow-hidden">
            <header
                class="h-16 flex items-center justify-between px-8 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark shrink-0">
                <div class="flex items-center gap-4">
                    <a class="text-slate-400 hover:text-primary transition-colors" href="/admin/ordermanagement">
                        <span class="material-symbols-outlined">arrow_back</span>
                    </a>
                    <h2 class="text-xl font-bold tracking-tight">Order Details <span class="text-slate-400 font-normal">
                            <%=order.orderNumber%>
                        </span></h2>
                </div>
                <div class="flex items-center gap-3">
                    <a href="/admin/invoice/<%=order._id%>/download">
                        <button
                        class="h-10 px-4 flex items-center gap-2 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg font-bold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                        <span class="material-symbols-outlined text-lg">print</span>
                        Print Invoice
                    </button>
                    </a>
                    <button
                        class="h-10 px-4 flex items-center gap-2 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg font-bold text-sm hover:bg-red-100 dark:hover:bg-red-900/40 transition-all">
                        <span class="material-symbols-outlined text-lg">undo</span>
                        Refund
                    </button>
                    <div class="h-8 w-px bg-slate-200 dark:border-slate-700 mx-2"></div>
                    <form id="orderStatusForm" data-order-id="<%= order._id %>" data-current-status="<%= order.orderStatus %>" class="flex items-center gap-2">
                        <div class="relative">

                            <select id="orderStatus" name="orderStatus" class="h-10 min-w-36 appearance-none rounded-lg
      border border-slate-200 dark:border-slate-700
      bg-slate-100 dark:bg-slate-800
      py-0 pl-3 pr-9 text-sm font-semibold">

                                <%
                                    const orderStatuses = ["Pending", "Confirmed", "Shipped", "Delivered", "Cancelled", "Returned"];
                                    const shipmentStatusFlow = ["Pending", "Confirmed", "Shipped", "Delivered"];
                                    const terminalOrderStatuses = ["Cancelled", "Returned"];
                                    const currentStatusIndex = shipmentStatusFlow.indexOf(order.orderStatus);
                                    const isCurrentTerminalStatus = terminalOrderStatuses.includes(order.orderStatus);
                                %>

                                    <% orderStatuses.forEach(status=> { %>
                                        <%
                                            const statusIndex = shipmentStatusFlow.indexOf(status);
                                            const isRollbackStatus = currentStatusIndex !== -1 && statusIndex !== -1 && statusIndex < currentStatusIndex;
                                            const isDisabledStatus = status !== order.orderStatus && (isRollbackStatus || isCurrentTerminalStatus);
                                        %>

                                        <option value="<%= status %>" <%=order.orderStatus===status ? "selected" : "" %>
                                            <%= isDisabledStatus ? "disabled" : "" %>
                                            >
                                            <%= status %>
                                        </option>

                                        <% }) %>

                            </select>

                        </div>

                        <button type="submit" class="h-10 px-4 bg-primary text-white rounded-lg font-bold text-sm">
                            Update Status
                        </button>
                    </form>
                </div>
            </header>
            <section class="flex-1 overflow-y-auto p-8 bg-slate-50 dark:bg-slate-900/30">
                <div class="max-w-7xl mx-auto space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-4">
                            <div class="size-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">calendar_today</span>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Order Date</p>
                                <p class="text-sm font-bold">
    <%= new Date(order.orderedAt).toLocaleString("en-IN", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
    }) %>
</p>
                            </div>
                        </div>
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-4">
                            <div
                                class="size-12 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 flex items-center justify-center">
                                <span class="material-symbols-outlined">local_shipping</span>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 dark:text-slate-400">
                                    Order Status
                                </p>

                                <span id="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full
        text-[10px] font-bold uppercase tracking-wide
        bg-blue-100 dark:bg-blue-900/30
        text-blue-600 dark:text-blue-400">

                                    <%= order.orderStatus %>

                                </span>
                            </div>
                        </div>
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-4">
                            <div
                                class="size-12 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 flex items-center justify-center">
                                <span class="material-symbols-outlined">payments</span>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Payment Status</p>
                                <span
                                    class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">
                                    <%=order.paymentStatus%>
                                </span>
                            </div>
                        </div>
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-4">
                            <div
                                class="size-12 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-600 flex items-center justify-center">
                                <span class="material-symbols-outlined">shopping_bag</span>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Total Amount</p>
                                <p class="text-sm font-bold">₹<%=order.totalAmount%>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2 space-y-6">
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div
                                    class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-100">Order Items (
                                        <%=order.items.length%>)
                                    </h3>
                                </div>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-left">
                                        <thead>
                                            <tr
                                                class="bg-slate-50 dark:bg-slate-900/50 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                                <th class="px-6 py-4">Product</th>
                                                <th class="px-6 py-4">Price</th>
                                                <th class="px-6 py-4">Qty</th>
                                                <th class="px-6 py-4 text-right">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-slate-200 dark:divide-slate-800">

                                            <% if (order.items && order.items.length) { %>

                                                <% order.items.forEach(item=> { %>
                                                    <% const product=item.product; const
                                                        selectedVariant=product?.variants?.find(variant=>
                                                        String(variant._id) === String(item.variant)
                                                        );
                                                        const fallbackVariant = product?.variants?.[0];
                                                        const productImage = selectedVariant?.images?.[0]
                                                        || fallbackVariant?.images?.[0]
                                                        || "";
                                                        const itemReturnStatus = item.returnStatus || "Pending";
                                                        const itemCancelStatus = item.cancelStatus || "Pending";
                                                        %>

                                                        <tr>

                                                            <!-- product -->
                                                            <td class="px-6 py-4">

                                                                <div class="flex items-center gap-3">

                                                                    <div class="size-12 rounded bg-slate-100 dark:bg-slate-800
              flex items-center justify-center border
              border-slate-200 dark:border-slate-700
              shrink-0 overflow-hidden">

                                                                        <% if (productImage) { %>
                                                                            <img src="<%= productImage %>"
                                                                                alt="<%= product?.name || 'Product image' %>"
                                                                                class="object-cover size-full" />
                                                                            <% } else { %>
                                                                                <span
                                                                                    class="material-symbols-outlined text-slate-400">inventory_2</span>
                                                                                <% } %>

                                                                    </div>

                                                                    <div>

                                                                        <p class="text-sm font-bold">
                                                                            <%= product?.name || "Product unavailable"
                                                                                %>
                                                                        </p>

                                                                        <% if (selectedVariant?.size) { %>
                                                                            <p class="text-xs text-slate-500">
                                                                                Size: <%= selectedVariant.size %>
                                                                            </p>
                                                                            <% } %>

                                                                                <% if (selectedVariant?.sku) { %>
                                                                                    <p class="text-xs text-slate-500">
                                                                                        SKU: <%= selectedVariant.sku %>
                                                                                    </p>
                                                                                    <% } %>

                                                                                        <% if (item.returnRequest) { %>
                                                                                            <span class="mt-1 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide <%= itemReturnStatus === 'Approved' ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : itemReturnStatus === 'Rejected' ? 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400' %>">
                                                                                                Return <%= itemReturnStatus %>
                                                                                            </span>
                                                                                        <% } %>
                                                                                        <% if (item.cancelRequest) { %>
                                                                                            <span class="mt-1 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide <%= itemCancelStatus === 'Approved' ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : itemCancelStatus === 'Rejected' ? 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400' %>">
                                                                                                Cancel <%= itemCancelStatus %>
                                                                                            </span>
                                                                                        <% } %>

                                                                    </div>

                                                                </div>

                                                            </td>

                                                            <!-- price -->
                                                            <td class="px-6 py-4 text-sm font-medium">

                                                                ₹<%= item.price.toLocaleString("en-IN") %>

                                                            </td>

                                                            <!-- qty -->
                                                            <td class="px-6 py-4 text-sm">

                                                                <%= item.returnQuantity %>

                                                            </td>

                                                            <!-- total -->
                                                            <td class="px-6 py-4 text-sm font-bold text-right">

                                                                ₹<%= (item.price * item.quantity)
                                                                    .toLocaleString("en-IN") %>

                                                            </td>

                                                        </tr>

                                                        <% }) %>

                                                            <% } else { %>

                                                                <tr>
                                                                    <td colspan="4"
                                                                        class="px-6 py-8 text-center text-sm text-slate-500">
                                                                        No products found
                                                                    </td>
                                                                </tr>

                                                                <% } %>

                                        </tbody>
                                    </table>
                                </div>
                                <div
                                    class="p-6 bg-slate-50 dark:bg-slate-900/50 border-t border-slate-200 dark:border-slate-800">
                                    <div class="flex flex-col items-end space-y-2">
                                        <div class="flex justify-between w-64 text-sm">
                                            <span class="text-slate-500">Subtotal</span>
                                            <span class="font-medium">₹<%= order.subTotal %></span>
                                        </div>
                                        <div class="flex justify-between w-64 text-sm">
                                            <span class="text-slate-500">Shipping (Standard)</span>
                                            <span class="font-medium text-emerald-500">₹<%= order.shippingCharge
                                                    || "Free" %></span>
                                        </div>
                                        <div class="flex justify-between w-64 text-sm">
                                            <span class="text-slate-500">Estimated Tax</span>
                                            <span class="font-medium">₹0.00</span>
                                        </div>
                                        <div class="flex justify-between w-64 text-sm">
                                            <span class="text-slate-500">Discount</span>

                                            <span class="font-medium text-emerald-500">
                                                -₹<%= order.discount %>
                                            </span>
                                        </div>

                                        <div class="flex justify-between w-64 text-sm">
                                            <span class="text-slate-500">Delivery Charge</span>

                                            <span class="font-medium text-emerald-500">
                                                +₹<%= order.deliveryCharge %>
                                            </span>
                                        </div>
                                        <div
                                            class="pt-2 mt-2 border-t border-slate-200 dark:border-slate-700 flex justify-between w-64">
                                            <span class="font-bold">Total</span>
                                            <span class="font-bold text-lg text-primary"> ₹<%= order.totalAmount%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
                                <h3 class="font-bold text-slate-800 dark:text-slate-100 mb-6">Order Timeline</h3>
                                <div
                                    class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary before:via-primary before:to-transparent">
                                    <div class="relative flex items-center gap-6">
                                        <div
                                            class="absolute left-0 size-10 rounded-full bg-primary border-4 border-white dark:border-background-dark flex items-center justify-center text-white z-10 shadow-lg shadow-primary/20">
                                            <span class="material-symbols-outlined text-sm fill-icon">check</span>
                                        </div>
                                        <div class="ml-14">
                                            <p class="text-sm font-bold">Shipped Out</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">October 14, 2023 -
                                                02:30 PM</p>
                                            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 italic">Handed
                                                over to FedEx. Tracking: #FEDEX-99210044</p>
                                        </div>
                                    </div>
                                    <div class="relative flex items-center gap-6">
                                        <div
                                            class="absolute left-0 size-10 rounded-full bg-primary border-4 border-white dark:border-background-dark flex items-center justify-center text-white z-10">
                                            <span class="material-symbols-outlined text-sm fill-icon">check</span>
                                        </div>
                                        <div class="ml-14">
                                            <p class="text-sm font-bold">Order Packaged</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">October 13, 2023 -
                                                11:15 AM</p>
                                        </div>
                                    </div>
                                    <div class="relative flex items-center gap-6">
                                        <div
                                            class="absolute left-0 size-10 rounded-full bg-primary border-4 border-white dark:border-background-dark flex items-center justify-center text-white z-10">
                                            <span class="material-symbols-outlined text-sm fill-icon">check</span>
                                        </div>
                                        <div class="ml-14">
                                            <p class="text-sm font-bold">Payment Confirmed</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">October 12, 2023 -
                                                10:46 AM</p>
                                        </div>
                                    </div>
                                    <div class="relative flex items-center gap-6">
                                        <div
                                            class="absolute left-0 size-10 rounded-full bg-primary border-4 border-white dark:border-background-dark flex items-center justify-center text-white z-10">
                                            <span
                                                class="material-symbols-outlined text-sm fill-icon">shopping_cart</span>
                                        </div>
                                        <div class="ml-14">
                                            <p class="text-sm font-bold">Order Placed</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">October 12, 2023 -
                                                10:45 AM</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-100">Customer Details</h3>
                                </div>
                                <div class="p-6">
                                    <div class="flex items-center gap-4 mb-6">
                                        <div
                                            class="size-14 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xl font-bold">
                                            <%=order.address.fullname[0]%>
                                        </div>
                                        <div>
                                            <h4 class="font-bold">
                                                <%=order.address.fullname%>
                                            </h4>
                                            <p class="text-sm text-slate-500">Customer since Oct 2022</p>
                                        </div>
                                    </div>
                                    <div class="space-y-4">
                                        <div>
                                            <p
                                                class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">
                                                Email Address</p>
                                            <p class="text-sm font-medium">
                                                <%=order.user.email%>
                                            </p>
                                        </div>
                                        <div>
                                            <p
                                                class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">
                                                Phone Number</p>
                                            <p class="text-sm font-medium">
                                                <%=order.address.phone%>
                                            </p>
                                        </div>
                                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <p
                                                class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">
                                                Shipping Address</p>
                                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                                                <%=order.address.apartment%>
                                                    <%=order.address.street%><br />
                                                        <%=order.address.state%>, <%=order.address.pincode%><br />
                                                                <%=order.address.country%>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-100">Payment Details</h3>
                                </div>
                                <div class="p-6">
                                    <div class="space-y-4">
                                        <div class="flex items-center justify-between">
                                            <p class="text-xs text-slate-500 dark:text-slate-400">Payment Method</p>
                                            <div class="flex items-center gap-2">
                                                <div
                                                    class="h-6 w-10 bg-slate-100 dark:bg-slate-800 rounded border border-slate-200 dark:border-slate-700 flex items-center justify-center overflow-hidden">
                                                    <img alt="Visa"
                                                        class="h-2 object-contain grayscale dark:invert opacity-70"
                                                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBO11Yw7Hg1Q-XK0-XBiLs96Vx5H2X1H3nmlQ4Q3gFMKY-tf9TraG1_wm6ofbgEOxJ85sUwVnbn1t0fqL7MJFnfBjUoYkYDWz78Ht_VNywd3hBLIxFRUoolt-Rhwu8Tpo9m0g-9snl-4avkwSwgbAavwR34JsE1YW_SZny0xJf4WysIb-dNIzHUgSP81Ua3mw_NzjuSEpk6tjOLvv7kv-sbwp1v-pKRmTHFerXn_ShgSh8Aw5U0tuDhDjYvOpGu0sZ98Eb0sIPUpqo" />
                                                </div>
                                                <span class="text-sm font-medium"><%=order.paymentMethod%></span>
                                            </div>
                                        </div>
                                        
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-100">Return Requests</h3>
                                    <span
                                        class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400">
                                        <%= typeof returnItems !== "undefined" ? returnItems.length : (order.items || []).filter(item => item.returnRequest).length %> Requests
                                    </span>
                                </div>
                                <div class="p-6 space-y-4">
                                    <%
                                        const requestedReturnItems = typeof returnItems !== "undefined"
                                            ? returnItems
                                            : (order.items || []).filter(item => item.returnRequest);
                                        const returnReasonLabels = {
                                            wrong_size: "Size didn't fit",
                                            defective: "Item defective or damaged",
                                            wrong_item: "Received wrong item",
                                            not_liked: "Did not like the style",
                                            other: "Other"
                                        };
                                    %>

                                    <% if (requestedReturnItems.length) { %>
                                        <% requestedReturnItems.forEach(item => { %>
                                            <%
                                                const product = item.product;
                                                const selectedVariant = product?.variants?.find(variant =>
                                                    String(variant._id) === String(item.variant)
                                                );
                                                const fallbackVariant = product?.variants?.[0];
                                                const itemImage = selectedVariant?.images?.[0] || fallbackVariant?.images?.[0] || "";
                                                const reasonText = returnReasonLabels[item.returnReason] || item.returnReason || "Not provided";
                                                const returnStatus = item.returnStatus || "Pending";
                                            %>
                                            <div class="return-request-item rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-4 space-y-4"
                                                data-order-id="<%= order._id %>"
                                                data-item-id="<%= item._id %>">
                                                <div class="flex gap-3">
                                                    <% if (itemImage) { %>
                                                        <img src="<%= itemImage %>"
                                                            alt="<%= product?.name || 'Product image' %>"
                                                            class="size-14 rounded-lg border border-slate-200 dark:border-slate-700 object-cover shrink-0" />
                                                    <% } else { %>
                                                        <div class="size-14 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark flex items-center justify-center shrink-0">
                                                            <span class="material-symbols-outlined text-slate-400">inventory_2</span>
                                                        </div>
                                                    <% } %>

                                                    <div class="min-w-0 flex-1">
                                                        <div class="flex items-start justify-between gap-3">
                                                            <div>
                                                                <p class="text-sm font-bold text-slate-800 dark:text-slate-100">
                                                                    <%= product?.name || "Product unavailable" %>
                                                                </p>
                                                                <p class="text-xs text-slate-500 dark:text-slate-400">
                                                                    Return qty: <%= item.returnQuantity || 1 %> of <%= item.quantity %>
                                                                </p>
                                                                <% if (selectedVariant?.size || selectedVariant?.color) { %>
                                                                    <p class="text-xs text-slate-500 dark:text-slate-400">
                                                                        <% if (selectedVariant?.size) { %>Size: <%= selectedVariant.size %><% } %>
                                                                        <% if (selectedVariant?.size && selectedVariant?.color) { %> | <% } %>
                                                                        <% if (selectedVariant?.color) { %>Color: <%= selectedVariant.color %><% } %>
                                                                    </p>
                                                                <% } %>
                                                            </div>
                                                            <span data-return-status
                                                                class="inline-flex shrink-0 items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide <%= returnStatus === 'Approved' ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : returnStatus === 'Rejected' ? 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400' %>">
                                                                <%= returnStatus %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="grid grid-cols-1 gap-3">
                                                    <div>
                                                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Return Reason</p>
                                                        <p class="text-sm font-medium text-slate-800 dark:text-slate-100"><%= reasonText %></p>
                                                    </div>
                                                    <div>
                                                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Customer Comments</p>
                                                        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                                                            <%= item.returnDescription || "No additional comments provided." %>
                                                        </p>
                                                    </div>
                                                </div>

                                                <div data-return-note
                                                    class="hidden rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark p-3 text-sm font-medium">
                                                </div>

                                                <% if (returnStatus === "Pending") { %>
                                                <div class="grid grid-cols-2 gap-3 pt-1">
                                                    <button type="button" data-return-decision="Approved"
                                                        class="return-decision-btn h-10 rounded-lg bg-emerald-600 text-white text-sm font-bold hover:bg-emerald-700 transition-colors flex items-center justify-center gap-2">
                                                        <span class="material-symbols-outlined text-lg">check_circle</span>
                                                        Approve
                                                    </button>
                                                    <button type="button" data-return-decision="Rejected"
                                                        class="return-decision-btn h-10 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm font-bold hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors flex items-center justify-center gap-2">
                                                        <span class="material-symbols-outlined text-lg">cancel</span>
                                                        Reject
                                                    </button>
                                                </div>
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-4 text-sm text-slate-500 dark:text-slate-400">
                                            No return requests for this order.
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                                    <h3 class="font-bold text-slate-800 dark:text-slate-100">Internal Notes</h3>
                                </div>
                                <div class="p-6">
                                    <textarea
                                        class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-primary outline-none min-h-[100px]"
                                        placeholder="Add a note about this order..."></textarea>
                                    <button
                                        class="w-full mt-3 bg-slate-100 dark:bg-slate-800 py-2 rounded-lg text-xs font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">Save
                                        Note</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

</body>
<script>
document
  .getElementById("orderStatusForm")
  .addEventListener("submit", async function (e) {

    e.preventDefault();

    const orderId =
      this.dataset.orderId;

    const orderStatus =
      document.getElementById(
        "orderStatus"
      ).value;

    try {

      const response =
        await fetch(
          `/admin/orders/${orderId}/status`,
          {
            method: "POST",

            headers: {
              "Content-Type":
                "application/json",
            },

            body: JSON.stringify({
              orderStatus,
            }),
          }
        );

      const data =
        await response.json();

      if (data.success) {

        document.getElementById(
          "statusBadge"
        ).textContent =
          orderStatus;

        Swal.fire({
          icon: "success",
          title:
            "Status Updated",
          text:
            "Order status updated successfully",
          timer: 1800,
          showConfirmButton: false,
        });

      } else {

        Swal.fire({
          icon: "error",
          title: "Oops...",
          text:
            data.message ||
            "Update failed",
        });

      }

    } catch (error) {

      console.error(error);

      Swal.fire({
        icon: "error",
        title:
          "Server Error",
        text:
          "Something went wrong",
      });

    }

});

document.querySelectorAll(".return-decision-btn").forEach(button => {
  button.addEventListener("click", async function () {
    const decision = this.dataset.returnDecision;
    const isApproved = decision === "Approved";
    const returnItem = this.closest(".return-request-item");
    const orderId = returnItem.dataset.orderId;
    const itemId = returnItem.dataset.itemId;
    const statusBadge = returnItem.querySelector("[data-return-status]");
    const note = returnItem.querySelector("[data-return-note]");
    const actionButtons = returnItem.querySelectorAll(".return-decision-btn");

    actionButtons.forEach(actionButton => {
      actionButton.disabled = true;
      actionButton.classList.add("opacity-50", "cursor-not-allowed");
    });

    try {
      const response = await fetch(`/admin/orders/${orderId}/return/${itemId}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          status: decision,
        }),
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        throw new Error(data.message || "Return request update failed");
      }

    statusBadge.textContent = decision;
    statusBadge.className = isApproved
      ? "inline-flex shrink-0 items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400"
      : "inline-flex shrink-0 items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400";

    note.textContent = `Return request ${decision.toLowerCase()} successfully.`;
    note.classList.remove("hidden", "text-emerald-600", "text-red-600");
    note.classList.add(isApproved ? "text-emerald-600" : "text-red-600");

      Swal.fire({
        icon: "success",
        title: isApproved ? "Return approved" : "Return rejected",
        timer: 1600,
        showConfirmButton: false,
      });
    } catch (error) {
      actionButtons.forEach(actionButton => {
        actionButton.disabled = false;
        actionButton.classList.remove("opacity-50", "cursor-not-allowed");
      });

      Swal.fire({
        icon: "error",
        title: "Update failed",
        text: error.message || "Something went wrong",
      });
    }
  });
});

</script>

</html>
