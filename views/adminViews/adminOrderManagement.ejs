<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Order Management - Urban Football</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .fill-icon {
            font-variation-settings: 'FILL' 1;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar Navigation -->
        <aside
            class="w-64 flex flex-col border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark shrink-0">
            <div class="p-6 flex items-center gap-3">
                <div class="size-10 bg-primary rounded-lg flex items-center justify-center text-white">
                    <span class="material-symbols-outlined text-2xl">sports_soccer</span>
                </div>
                <div>
                    <h1 class="text-base font-bold leading-tight">Urban football Admin</h1>
                    <p class="text-slate-500 dark:text-slate-400 text-xs">Accessory Store</p>
                </div>
            </div>
            <nav class="flex-1 px-4 space-y-1 mt-4">
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/dashboard">
                    <span class="material-symbols-outlined">grid_view</span>
                    <span class="text-sm font-medium">Dashboard</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/products">
                    <span class="material-symbols-outlined">inventory_2</span>
                    <span class="text-sm font-medium">Products</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 bg-primary text-white rounded-lg shadow-lg shadow-primary/20"
                    href="#">
                    <span class="material-symbols-outlined fill-icon">shopping_cart</span>
                    <span class="text-sm font-medium">Orders</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/userManagement">
                    <span class="material-symbols-outlined">group</span>
                    <span class="text-sm font-medium">Customers</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="#">
                    <span class="material-symbols-outlined">bar_chart</span>
                    <span class="text-sm font-medium">Analytics</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="text-sm font-medium">Settings</span>
                </a>
            </nav>
            <div class="p-4 border-t border-slate-200 dark:border-slate-800">
                <div class="flex items-center gap-3 p-2">
                    <div class="size-9 rounded-full bg-center bg-no-repeat bg-cover"
                        data-alt="Admin user avatar portrait"
                        style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDKp96vogJKX9-XA_mf92j--qQRwdJ3vbcZbGhdWJVkp9MYuYBvRBgc0KmQjl2aTyMej4CxVOiiCzItKSf45Uatlgg6HRzCqV7aORuQAS9VveTVwjx5Awm4cQFNSrC0MDWRZN3Eu_xeMSCAWItkf-H6n7lho17-IfzTHYGV2B-OIPoHguAOnNFJcyFaVK5e2RjehnnMVsWv54pEwFjyQ627SMwfy7kOiP0j3tRbTikZZYi_bsWKD7HbPJnV6NJBFr4KUKlTQyWZliE')">
                    </div>
                    <div class="flex-1 overflow-hidden">
                        <p class="text-sm font-semibold truncate">Alex Johnson</p>
                        <p class="text-xs text-slate-500 truncate">Super Admin</p>
                    </div>
                </div>
                <button
                    class="w-full mt-3 flex items-center justify-center gap-2 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-lg text-sm font-bold transition-colors">
                    <span class="material-symbols-outlined text-sm">help</span>
                    Support
                </button>
            </div>
        </aside>
        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Navbar -->
            <header
                class="h-16 flex items-center justify-between px-8 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark shrink-0">
                <div class="flex items-center gap-4">
                    <h2 class="text-xl font-bold tracking-tight">Order Management</h2>
                </div>
                <div class="flex items-center gap-6">
                    <div class="relative w-64">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
                        <input
                            class="w-full bg-slate-100 dark:bg-slate-800 border-none rounded-lg py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-primary transition-all"
                            placeholder="Global search..." type="text" />
                    </div>
                    <div class="flex items-center gap-2">
                        <button
                            class="size-10 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors relative">
                            <span class="material-symbols-outlined">notifications</span>
                            <span
                                class="absolute top-2 right-2 size-2 bg-red-500 rounded-full border-2 border-white dark:border-background-dark"></span>
                        </button>
                        <button
                            class="h-10 px-4 flex items-center gap-2 bg-primary text-white rounded-lg font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">
                            <span class="material-symbols-outlined text-lg">download</span>
                            Export CSV
                        </button>
                    </div>
                </div>
            </header>
            <!-- Content Area -->
            <section class="flex-1 overflow-y-auto p-8 space-y-6">
                <!-- Filter Section -->
                <div
                    class="bg-white dark:bg-background-dark rounded-xl p-4 border border-slate-200 dark:border-slate-800 flex flex-wrap items-center justify-between gap-4 shadow-sm">
                    <div class="flex flex-wrap items-center gap-3">
                        <div class="relative min-w-[300px]">
                            <div class="flex flex-wrap items-center gap-3">

    <!-- Search -->
    <form
        action="/admin/orderManagement"
        method="GET"
        class="flex items-center gap-2"
    >

        <div class="relative min-w-[320px]">

            <span
                class="material-symbols-outlined
                absolute left-3 top-1/2 -translate-y-1/2
                text-slate-400 text-xl"
            >
                search
            </span>

            <input
                type="text"
                name="search"
                value="<%= orderData.search || '' %>"
                placeholder="Search by Order ID or Customer..."
                class="w-full bg-slate-50 dark:bg-slate-900
                border border-slate-200 dark:border-slate-700
                rounded-lg py-2 pl-10 pr-4 text-sm
                focus:ring-2 focus:ring-primary outline-none"
            />

        </div>

        <!-- Search button -->
        <button
            type="submit"
            class="px-4 py-2 rounded-lg
            bg-primary text-white text-sm font-semibold
            hover:bg-primary/90 transition"
        >
            Search
        </button>

        <!-- Clear button -->
        <% if(orderData.search){ %>

            <a
                href="/admin/orderManagement"
                class="px-4 py-2 rounded-lg
                border border-slate-300 dark:border-slate-700
                bg-white dark:bg-slate-900
                text-sm font-semibold
                hover:bg-slate-100 dark:hover:bg-slate-800
                transition"
            >
                Clear
            </a>

        <% } %>

    </form>

</div>
                        </div>
                        <div class="flex gap-2">
                            <button
                                class="flex items-center gap-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 px-3 py-2 rounded-lg text-sm font-medium hover:border-primary transition-colors">
                                <span class="material-symbols-outlined text-lg">filter_list</span>
                                All Orders
                                <span class="material-symbols-outlined text-lg">expand_more</span>
                            </button>
                            <button
                                class="flex items-center gap-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 px-3 py-2 rounded-lg text-sm font-medium hover:border-primary transition-colors">
                                Status: Any
                                <span class="material-symbols-outlined text-lg">expand_more</span>
                            </button>
                            <button
                                class="flex items-center gap-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 px-3 py-2 rounded-lg text-sm font-medium hover:border-primary transition-colors">
                                Date Range
                                <span class="material-symbols-outlined text-lg">calendar_today</span>
                            </button>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                        <span>Showing 1-10 of 1,240 results</span>
                    </div>
                </div>
                <!-- Chips Row -->
                <div class="flex gap-2 pb-2 overflow-x-auto no-scrollbar">
                    <button
                        class="px-4 py-1.5 rounded-full bg-primary text-white text-xs font-semibold whitespace-nowrap">All</button>
                    <button
                        class="px-4 py-1.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-semibold whitespace-nowrap hover:border-primary">Pending</button>
                    <button
                        class="px-4 py-1.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-semibold whitespace-nowrap hover:border-primary">Processing</button>
                    <button
                        class="px-4 py-1.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-semibold whitespace-nowrap hover:border-primary">Shipped</button>
                    <button
                        class="px-4 py-1.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-semibold whitespace-nowrap hover:border-primary">Delivered</button>
                    <button
                        class="px-4 py-1.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-semibold whitespace-nowrap hover:border-primary text-red-500">Cancelled</button>
                </div>
                <!-- Table Section -->
                <div
                    class="bg-white dark:bg-background-dark rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-200 dark:border-slate-800">
                                    <th class="px-6 py-4">
                                        <input
                                            class="rounded text-primary focus:ring-primary bg-transparent border-slate-300 dark:border-slate-700"
                                            type="checkbox" />
                                    </th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Order ID</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Customer</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Date</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Total</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Payment</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                                        Status</th>
                                    <th
                                        class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">
                                        Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">

<% if (orderData.orders.length > 0) { %>

    <% orderData.orders.forEach(order => { %>

<tr class="hover:bg-slate-50 dark:hover:bg-slate-900/40">

    <td class="px-6 py-4">
        <input type="checkbox">
    </td>

    <!-- order number -->
    <td class="px-6 py-4 text-sm font-semibold text-primary">
        <%= order.orderNumber %>
    </td>

    <!-- customer -->
    <td class="px-6 py-4">

        <div class="flex items-center gap-3">

            

            <span class="text-sm font-medium">

                <%= order.user?.fullname || "Guest" %>

            </span>

        </div>

    </td>

    <!-- date -->
    <td class="px-6 py-4 text-sm">

        <%= new Date(
            order.createdAt
        ).toLocaleDateString() %>

    </td>

    <!-- total -->
    <td class="px-6 py-4 text-sm font-bold">

        ₹<%= order.subTotal %>

    </td>

    <!-- payment -->
    <td class="px-6 py-4">

        <span
            class="px-2 py-1 rounded-full text-[10px] font-bold
            <%= order.paymentStatus === 'PAID'
                ? 'bg-emerald-100 text-emerald-600'
                : 'bg-amber-100 text-amber-600'
            %>">

            <%= order.paymentStatus %>

        </span>

    </td>

    <!-- order status -->
    <td class="px-6 py-4">

        <span
            class="px-2 py-1 rounded-full text-[10px] font-bold
            <%= order.orderStatus === 'DELIVERED'
                ? 'bg-emerald-100 text-emerald-600'
                : order.orderStatus === 'CANCELLED'
                ? 'bg-red-100 text-red-600'
                : 'bg-blue-100 text-blue-600'
            %>">

            <%= order.orderStatus %>

        </span>

    </td>

    <!-- action -->
    <td class="px-6 py-4 text-right">

        <a
            href="/admin/orderManagement/<%= order._id %>"

            class="text-slate-400 hover:text-primary">

            <span
                class="material-symbols-outlined">

                visibility

            </span>

        </a>

    </td>

</tr>

    <% }) %>

<% } else { %>

<tr>

<td colspan="8"
    class="text-center py-10">

    No orders found

</td>

</tr>

<% } %>

</tbody>
                        </table>
                    </div>
                    <!-- Pagination Footer -->
                   <!-- Pagination -->
<!-- Pagination -->
<div class="flex items-center justify-center gap-2 mt-12">

<%
    const currentPage = orderData.currentPage;
    const totalPages = orderData.totalPages;

    const params = new URLSearchParams();

    if (orderData.search) {
        params.set("search", orderData.search);
    }

    const groupSize = 3;

    const startPage =
        Math.floor((currentPage - 1) / groupSize) * groupSize + 1;

    const endPage =
        Math.min(
            startPage + groupSize - 1,
            totalPages
        );
%>


<!-- Previous -->
<% if (startPage > 1) { %>

    <%
        params.set("page", startPage - 1);
    %>

    <a
        href="?<%= params.toString() %>"
        class="size-10 flex items-center justify-center rounded-lg
        bg-slate-100 dark:bg-slate-800
        text-slate-500 hover:text-white
        hover:bg-primary transition-colors">

        <span class="material-symbols-outlined">
            chevron_left
        </span>

    </a>

<% } else { %>

    <button
        disabled
        class="size-10 flex items-center justify-center rounded-lg
        bg-slate-100 dark:bg-slate-800
        opacity-40 cursor-not-allowed">

        <span class="material-symbols-outlined">
            chevron_left
        </span>

    </button>

<% } %>



<!-- Only 3 page buttons -->
<% for (let i = startPage; i <= endPage; i++) { %>

    <%
        params.set("page", i);
    %>

    <% if (i === currentPage) { %>

        <span
            class="size-10 flex items-center justify-center
            rounded-lg bg-primary text-white font-bold">

            <%= i %>

        </span>

    <% } else { %>

        <a
            href="?<%= params.toString() %>"
            class="size-10 flex items-center justify-center rounded-lg
            bg-slate-100 dark:bg-slate-800
            text-slate-500 hover:text-white
            hover:bg-primary transition-colors">

            <%= i %>

        </a>

    <% } %>

<% } %>



<!-- Next -->
<% if (endPage < totalPages) { %>

    <%
        params.set("page", endPage + 1);
    %>

    <a
        href="?<%= params.toString() %>"
        class="size-10 flex items-center justify-center rounded-lg
        bg-slate-100 dark:bg-slate-800
        text-slate-500 hover:text-white
        hover:bg-primary transition-colors">

        <span class="material-symbols-outlined">
            chevron_right
        </span>

    </a>

<% } else { %>

    <button
        disabled
        class="size-10 flex items-center justify-center rounded-lg
        bg-slate-100 dark:bg-slate-800
        opacity-40 cursor-not-allowed">

        <span class="material-symbols-outlined">
            chevron_right
        </span>

    </button>

<% } %>

</div>
                </div>
            </section>
        </main>
    </div>
</body>

</html>