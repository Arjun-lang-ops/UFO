<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Admin Product Inventory - Football Accessories</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex">
    <!-- Sidebar Navigation -->
    <aside
        class="w-64 border-r border-slate-200 dark:border-slate-800 flex flex-col bg-white dark:bg-background-dark shrink-0">
        <div class="p-6 flex flex-col gap-6 h-full">
            <div class="flex items-center gap-3">
                <div class="bg-primary rounded-lg p-2 text-white">
                    <span class="material-symbols-outlined">sports_soccer</span>
                </div>
                <div class="flex flex-col">
                    <h1 class="text-base font-bold leading-none">Urban Football</h1>
                    <p class="text-slate-500 dark:text-slate-400 text-xs">Admin</p>
                </div>
            </div>
            <nav class="flex flex-col gap-2 grow">
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    href="/admin/dashboard">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="text-sm font-medium">Dashboard</span>
                </a>

                <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    href="/admin/orderManagement">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span class="text-sm font-medium">Orders</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/10 text-primary transition-colors"
                    href="#">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">inventory_2</span>
                    <span class="text-sm font-bold">Products</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    href="/admin/userManagement">
                    <span class="material-symbols-outlined">group</span>
                    <span class="text-sm font-medium">Users</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    href="/admin/categories">
                    <span class="material-symbols-outlined">analytics</span>
                    <span class="text-sm font-medium">categories</span>
                </a>
            </nav>

        </div>
    </aside>
    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden">
        <!-- Header -->
        <header
            class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-8 py-4">
            <div class="flex items-center gap-4 w-full max-w-md">
                <div class="relative w-full">

                    <!-- Icon -->
                    <span
                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">
                        search
                    </span>

                    <form action="/admin/products" method="GET">

                        <!-- Input -->
                        <input name="search" id="searchInput"
                            class="w-full pl-10 pr-10 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-slate-100"
                            placeholder="Search by Product..." type="text" value="<%=search||''%>" />

                        <!-- Clear button -->
                        <button id="clearSearch" type="button"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9dabb9] hover:text-white hidden">
                            ✕
                        </button>

                    </form>
                </div>
            </div>
            <div class="flex items-center gap-4">




            </div>
        </header>
        <!-- Content Area -->
        <div class="flex-1 overflow-y-auto p-8 bg-slate-50 dark:bg-background-dark/50">
            <!-- Page Heading Section -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div>
                    <h2 class="text-3xl font-black tracking-tight mb-1">Product Inventory</h2>
                    <p class="text-slate-500 dark:text-slate-400">Manage all football gear, stock levels, and store
                        pricing.</p>
                </div>
                <div class="flex items-center gap-3">

                    <a href="/admin/product-add">
                        <button
                            class="flex items-center gap-2 px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-bold shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">
                            <span class="material-symbols-outlined text-lg">add</span>
                            Add New Product
                        </button>
                    </a>
                </div>
            </div>
            <!-- Stats Overview -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div
                    class="bg-white dark:bg-slate-800 p-5 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
                    <p class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Total Products</p>
                    <h3 class="text-2xl font-bold">
                        <%=totalProducts%>
                    </h3>
                </div>

            </div>
            <!-- Filter Controls -->
            <div class="flex flex-wrap items-center gap-3 mb-6">
                <button
                    class="px-4 py-1.5 bg-primary/10 text-primary border border-primary/20 rounded-full text-xs font-bold">All
                    Products</button>


            </div>
            <!-- Table Section -->
            <div
                class="bg-white dark:bg-background-dark border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm overflow-hidden @container">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr
                            class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs font-bold uppercase tracking-wider">

                            <th class="px-6 py-4">Product Name &amp; SKU</th>
                            <th class="px-6 py-4">Category</th>

                            <th class="px-6 py-4">Price</th>
                            <th class="px-6 py-4">Offer Type</th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        <% if(!product||product.length===0) { %>
                            <tr>
                                <td colspan="6" class="text-center py-6 text-slate-500">
                                    No Product found
                                </td>
                            </tr>
                            <% } %>
                                <% product.forEach(item=>{%>
                                    <!-- Row 1 -->
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">

                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-bold">
                                                    <%=item.name%>
                                                </span>
                                                <span class="text-xs text-slate-500">
                                                    <%=item.variants[0]?.sku%>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-xs font-medium text-slate-600 dark:text-slate-400">
                                                <%=item.category?.name%>
                                            </span>
                                        </td>

                                        <td class="px-6 py-4">
                                            <span class="text-sm font-bold">
                                                <%=item.variants[0]?.price%>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <select
                                                class="w-44 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-3 py-2 text-xs font-medium text-slate-700 dark:text-slate-200 focus:ring-2 focus:ring-primary focus:border-primary"
                                                data-product-id="<%= item._id %>">
                                                <option value="">No offer</option>
                                                <% if (typeof productOffers !== 'undefined' && productOffers.length > 0) { %>
                                                    <% productOffers.forEach(offer => { %>
                                                        <option value="<%= offer._id %>" <%= item.offer && item.offer._id.toString() === offer._id.toString() ? 'selected' : '' %>>
                                                            <%= offer.name %> - <%= offer.offerMode === 'PERCENTAGE' ? offer.discountValue + '%' : 'Rs ' + offer.discountValue %>
                                                        </option>
                                                    <% }) %>
                                                <% } else { %>
                                                    <option value="" disabled>No active product offers</option>
                                                <% } %>
                                            </select>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (item.isActive) { %>
                                                <span
                                                    class="inline-flex items-center px-2 py-1 rounded-md text-[10px] font-bold bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-500 uppercase">
                                                    Listed
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        class="inline-flex items-center px-2 py-1 rounded-md text-[10px] font-bold bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-500 uppercase">
                                                        Unlisted
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/admin/product-edit/<%= item._id %>">
                                                    <button
                                                        class="p-1.5 text-slate-400 hover:text-primary transition-colors">
                                                        <span class="material-symbols-outlined text-lg">edit</span>
                                                    </button>
                                                </a>

                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Row 2 -->

                                    </tr>
                                    <%})%>
                    </tbody>
                </table>
                <!-- Pagination -->
                <div
                    class="px-6 py-4 bg-slate-50 dark:bg-slate-800/30 flex items-center justify-between border-t border-slate-100 dark:divide-slate-800">

                    <!-- ✅ Showing X to Y of Z -->
                    <p class="text-xs text-slate-500">
                        <% const start=(currentPage - 1) * 4 + 1; const end=Math.min(currentPage * 4, totalProducts); %>

                            Showing
                            <span class="font-bold text-slate-900 dark:text-slate-100">
                                <%= totalProducts===0 ? 0 : start %>
                            </span>
                            to
                            <span class="font-bold text-slate-900 dark:text-slate-100">
                                <%= end %>
                            </span>
                            of
                            <span class="font-bold text-slate-900 dark:text-slate-100">
                                <%= totalProducts %>
                            </span>
                            results
                    </p>

                    <!-- ✅ Pagination -->
                    <div class="flex items-center gap-2">

                        <!-- Prev Button -->
                        <% if (currentPage> 1) { %>
                            <a href="?page=<%= currentPage - 1 %>&search=<%= search %>"
                                class="p-1.5 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-400">
                                <span class="material-symbols-outlined text-lg">chevron_left</span>
                            </a>
                            <% } %>

                                <!-- Page Numbers -->
                                <% for (let i=1; i <=totalPages; i++) { %>

                                    <% if (i===currentPage) { %>
                                        <span
                                            class="px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg shadow-sm">
                                            <%= i %>
                                        </span>
                                        <% } else { %>
                                            <a href="?page=<%= i %>&search=<%= search %>"
                                                class="px-3 py-1 text-slate-500 text-xs font-bold rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                                                <%= i %>
                                            </a>
                                            <% } %>

                                                <% } %>

                                                    <!-- Next Button -->
                                                    <% if (currentPage < totalPages) { %>
                                                        <a href="?page=<%= currentPage + 1 %>&search=<%= search %>"
                                                            class="p-1.5 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-400">
                                                            <span
                                                                class="material-symbols-outlined text-lg">chevron_right</span>
                                                        </a>
                                                        <% } %>

                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
<script>
    const input = document.getElementById("searchInput");
    const clearBtn = document.getElementById("clearSearch");

    // Show/hide logic
    function toggleClear() {
        if (input.value.trim() !== "" && document.activeElement === input) {
            clearBtn.classList.remove("hidden");
        } else {
            clearBtn.classList.add("hidden");
        }
    }

    input.addEventListener("focus", toggleClear);
    input.addEventListener("input", toggleClear);
    input.addEventListener("blur", () => {
        setTimeout(toggleClear, 150);
    });

    // Clear action
    clearBtn.addEventListener("click", () => {
        input.value = "";
        input.focus();

        const url = new URL(window.location.href);
        url.searchParams.delete("search");
        url.searchParams.set("page", 1);

        window.location.href = url.toString();
    });

    document.querySelectorAll('select[data-product-id]').forEach(select => {
    select.addEventListener('change', async () => {
        const previousValue = select.dataset.previousValue || '';
        const productId = select.dataset.productId;
        const offerId = select.value;

        select.disabled = true;

        try {
            const response = await fetch(`/admin/product/${productId}/offer`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ offerId })
            });

            const result = await response.json();

            if (!response.ok || !result.success) {
                throw new Error(result.message || 'Failed to update product offer');
            }

            select.dataset.previousValue = offerId;

            Swal.fire({
                icon: 'success',
                title: 'Offer Updated',
                text: 'Product offer updated successfully.',
                timer: 1500,
                showConfirmButton: false
            });

        } catch (error) {
            select.value = previousValue;

            Swal.fire({
                icon: 'error',
                title: 'Update Failed',
                text: error.message
            });

        } finally {
            select.disabled = false;
        }
    });

    select.dataset.previousValue = select.value;
});
</script>

</html>
