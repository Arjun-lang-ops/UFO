<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #283039;
        border-radius: 10px;
    }
</style>

<aside
    class="fixed left-0 top-0 h-screen w-64 bg-white dark:bg-[#111418] border-r border-slate-200 dark:border-[#283039] flex flex-col z-50">
    <div class="p-6">
        <div class="flex items-center gap-3 text-primary">
            <span class="material-symbols-outlined text-3xl font-bold">sports_soccer</span>
            <div>
                <h1 class="text-lg font-bold leading-none dark:text-white">Urban Football Admin</h1>
                <p
                    class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-[#9dabb9] mt-1 font-semibold">
                    Football Pro</p>
            </div>
        </div>
    </div>
    <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto custom-scrollbar">
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'dashboard' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>" href="/admin/dashboard">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="text-sm font-medium">Dashboard</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'orders' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/orderManagement">
            <span class="material-symbols-outlined">shopping_bag</span>
            <span class="text-sm font-medium">Orders</span>
        </a>
        
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'products' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/products">
            <span class="material-symbols-outlined">inventory_2</span>
            <span class="text-sm font-medium">Products</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'customers' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/userManagement">
            <span class="material-symbols-outlined">group</span>
            <span class="text-sm font-medium">Customers</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'analytics' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/analytics">
            <span class="material-symbols-outlined">analytics</span>
            <span class="text-sm font-medium">Analytics</span>
        </a>
        <div class="pt-4 pb-2">
            <p class="px-3 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Marketing</p>
        </div>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'coupons' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/coupon">
            <span class="material-symbols-outlined">confirmation_number</span>
            <span class="text-sm font-medium">Coupons</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'categories' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/categories">
            <span class="material-symbols-outlined">category</span>
            <span class="text-sm font-medium">Categories</span>
        </a>
        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all <%= activePage === 'offers' ? 'bg-primary text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-100 dark:hover:bg-[#283039]' %>"
            href="/admin/offers">
            <span class="material-symbols-outlined">campaign</span>
            <span class="text-sm font-medium">Offers</span>
        </a>
        
        <div class="pt-4 pb-2">
            <p class="px-3 text-[11px] font-bold text-slate-400 uppercase tracking-widest">System</p>
        </div>
    </nav>
    <a href="/admin/logout" class="block">
        <div class="p-4 border-t border-slate-200 dark:border-[#283039]">
            <button
                class="flex w-full items-center gap-3 px-3 py-2.5 rounded-lg text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all">
                <span class="material-symbols-outlined">logout</span>
                <span class="text-sm font-medium">Logout</span>
            </button>
        </div>
    </a>
</aside>
