<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= statusCode || 404 %> - <%= title || 'Page Not Found' %> | Urban Football</title>
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#137fec",
            "background-dark": "#101922",
          },
          fontFamily: { "display": ["Lexend", "sans-serif"] },
        },
      },
    }
  </script>
  <style>
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #101922; }
    ::-webkit-scrollbar-thumb { background: #283039; border-radius: 4px; }

    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      33% { transform: translateY(-18px) rotate(3deg); }
      66% { transform: translateY(-8px) rotate(-2deg); }
    }
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(19,127,236,0.15); }
      50%  { box-shadow: 0 0 50px rgba(19,127,236,0.45), 0 0 80px rgba(19,127,236,0.15); }
    }
    @keyframes slide-up {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    .animate-float       { animation: float 5s ease-in-out infinite; }
    .animate-pulse-glow  { animation: pulse-glow 3s ease-in-out infinite; }
    .animate-slide-up    { animation: slide-up 0.7s ease-out forwards; }
    .animate-fade-in     { animation: fade-in 1s ease-out forwards; }
    .animate-spin-slow   { animation: spin-slow 12s linear infinite; }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-600 { animation-delay: 0.6s; }
    .delay-800 { animation-delay: 0.8s; }

    .grid-bg {
      background-image:
        linear-gradient(rgba(19,127,236,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(19,127,236,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
    }
  </style>
</head>
<body class="bg-[#101922] text-white font-display min-h-screen flex flex-col overflow-x-hidden">

  <!-- Grid background -->
  <div class="fixed inset-0 grid-bg opacity-60 pointer-events-none"></div>
  <!-- Radial glow blob -->
  <div class="fixed inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 55% at 50% 15%, rgba(19,127,236,0.09) 0%, transparent 70%);"></div>

  <!-- Header -->
  <header class="relative z-10 flex items-center justify-between px-6 md:px-10 py-4 border-b border-[#283039]/80 bg-[#101922]/80 backdrop-blur-md">
    <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
      <div class="size-9 flex items-center justify-center rounded-lg bg-[#137fec]/20 text-[#137fec]">
        <span class="material-symbols-outlined" style="font-size:22px;">sports_soccer</span>
      </div>
      <h2 class="text-lg font-bold tracking-tight hidden sm:block">Urban Football</h2>
    </a>
    <nav class="flex items-center gap-5">
      <a href="/product" class="text-sm text-[#9dabb9] hover:text-white transition-colors flex items-center gap-1.5">
        <span class="material-symbols-outlined" style="font-size:16px;">store</span>
        <span class="hidden sm:inline">Shop</span>
      </a>
      <a href="/" class="text-sm text-[#9dabb9] hover:text-white transition-colors flex items-center gap-1.5">
        <span class="material-symbols-outlined" style="font-size:16px;">home</span>
        <span class="hidden sm:inline">Home</span>
      </a>
    </nav>
  </header>

  <!-- Main content -->
  <main class="relative z-10 flex-1 flex flex-col items-center justify-center px-6 py-16 text-center">

    <!-- Floating icon -->
    <div class="mb-8 animate-float opacity-0 animate-fade-in delay-100">
      <div class="size-32 md:size-40 rounded-full bg-[#1c2127] border border-[#283039] flex items-center justify-center animate-pulse-glow mx-auto relative">
        <div class="absolute inset-0 rounded-full border-2 border-dashed border-[#137fec]/30 animate-spin-slow"></div>
        <span class="material-symbols-outlined text-[#137fec]" style="font-size:72px;">
          <%= (statusCode && statusCode >= 500) ? 'error' : 'search_off' %>
        </span>
      </div>
    </div>

    <!-- Error code -->
    <div class="opacity-0 animate-slide-up delay-100">
      <div class="relative inline-block mb-2">
        <span class="text-[6rem] md:text-[9rem] font-black leading-none tracking-tighter"
              style="background: linear-gradient(135deg,#137fec 0%,#60a5fa 50%,#a78bfa 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
          <%= statusCode || 404 %>
        </span>
        <span class="absolute -top-2 -right-3 size-3 rounded-full bg-[#137fec] opacity-70 animate-pulse"></span>
        <span class="absolute bottom-4 -left-3 size-2 rounded-full bg-purple-400 opacity-50 animate-pulse delay-300"></span>
      </div>
    </div>

    <!-- Title -->
    <div class="opacity-0 animate-slide-up delay-200">
      <h1 class="text-2xl md:text-4xl font-bold text-white mb-3 tracking-tight">
        <%= title || 'Page Not Found' %>
      </h1>
    </div>

    <!-- Description -->
    <div class="opacity-0 animate-slide-up delay-300 max-w-md mx-auto">
      <p class="text-[#9dabb9] text-base leading-relaxed mb-8">
        <%= message || "Looks like this page has gone offside. The URL you entered doesn't exist or may have been moved." %>
      </p>
    </div>

    <!-- Action buttons -->
    <div class="opacity-0 animate-slide-up delay-400 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/"
         class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-[#137fec] hover:bg-[#137fec]/90 text-white font-bold text-sm transition-all shadow-lg shadow-[#137fec]/20 hover:shadow-[#137fec]/40 hover:-translate-y-0.5 active:scale-[0.98]">
        <span class="material-symbols-outlined" style="font-size:18px;">home</span>
        Go to Home
      </a>
      <a href="/product"
         class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-[#1c2127] hover:bg-[#283039] border border-[#283039] hover:border-[#3b4754] text-white font-bold text-sm transition-all hover:-translate-y-0.5 active:scale-[0.98]">
        <span class="material-symbols-outlined" style="font-size:18px;">store</span>
        Browse Products
      </a>
      <button onclick="history.back()"
         class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-transparent hover:bg-[#1c2127] border border-[#283039] text-[#9dabb9] hover:text-white font-bold text-sm transition-all hover:-translate-y-0.5 active:scale-[0.98] cursor-pointer">
        <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
        Go Back
      </button>
    </div>

    <!-- Quick links -->
    <div class="opacity-0 animate-fade-in delay-800 mt-16 w-full max-w-lg">
      <div class="flex items-center gap-4 mb-5">
        <div class="flex-1 h-px bg-[#283039]"></div>
        <span class="text-[#9dabb9] text-xs uppercase tracking-wider">Quick Links</span>
        <div class="flex-1 h-px bg-[#283039]"></div>
      </div>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-2">
        <a href="/product"     class="text-sm text-[#9dabb9] hover:text-[#137fec] transition-colors flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px;">sports_soccer</span> All Products</a>
        <span class="text-[#283039]">•</span>
        <a href="/cart"        class="text-sm text-[#9dabb9] hover:text-[#137fec] transition-colors flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px;">shopping_cart</span> My Cart</a>
        <span class="text-[#283039]">•</span>
        <a href="/profile"     class="text-sm text-[#9dabb9] hover:text-[#137fec] transition-colors flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px;">account_circle</span> Profile</a>
        <span class="text-[#283039]">•</span>
        <a href="/orderHistory" class="text-sm text-[#9dabb9] hover:text-[#137fec] transition-colors flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px;">receipt_long</span> Orders</a>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="relative z-10 py-4 text-center border-t border-[#283039]/60">
    <p class="text-[#9dabb9] text-xs">© 2026 Urban Football. All rights reserved.</p>
  </footer>

</body>
</html>