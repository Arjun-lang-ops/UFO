<aside class="w-full lg:w-[280px] shrink-0">
  <div class="flex flex-col gap-4 bg-white dark:bg-[#111418] p-4 rounded-xl border border-slate-200 dark:border-[#283039] h-full shadow-sm">
    <div class="flex gap-3 items-center pb-4 border-b border-slate-100 dark:border-[#283039]">
      <div class="flex flex-col">
        <h2 class="text-slate-900 dark:text-white text-base font-bold leading-normal">
          <%= user?.fullname || "User" %>
        </h2>
        <div class="flex items-center gap-1">
          <span class="material-symbols-outlined text-primary text-[14px]">verified</span>
          <p class="text-slate-500 dark:text-[#9dabb9] text-xs font-medium leading-normal">Pro Member</p>
        </div>
      </div>
    </div>
    <nav class="flex flex-col gap-1">

      <a href="/profile"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'profile' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">person</span>
        <span class="text-sm font-semibold leading-normal">Personal Info</span>
      </a>

      <a href="/orderHistory"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'orders' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">package_2</span>
        <span class="text-sm font-semibold leading-normal">My Orders</span>
      </a>

      <a href="/profile/address"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'addresses' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">location_on</span>
        <span class="text-sm font-semibold leading-normal">Addresses</span>
      </a>

      <a href="/wishlist"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'wishlist' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">favorite</span>
        <span class="text-sm font-semibold leading-normal">Wishlist</span>
      </a>

      <a href="/wallet"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'wallet' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">credit_card</span>
        <span class="text-sm font-semibold leading-normal">Wallet</span>
      </a>

      <a href="/profile/changePassword"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'changePassword' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">lock</span>
        <span class="text-sm font-semibold leading-normal">Security</span>
      </a>

      <!-- ✅ Fixed: activePage === 'referral' -->
      <a href="/profile/refer-and-earn"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= activePage === 'referral' ? 'bg-primary/10 text-primary dark:bg-primary dark:text-white' : 'text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white group' %>">
        <span class="material-symbols-outlined text-[20px]">share</span>
        <span class="text-sm font-semibold leading-normal">Refer and Earn</span>
      </a>

      <div class="h-px bg-slate-100 dark:bg-[#283039] my-1"></div>

      <a href="/logout"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-600 dark:hover:text-red-400 transition-colors group">
        <span class="material-symbols-outlined text-[20px]">logout</span>
        <span class="text-sm font-semibold leading-normal">Sign Out</span>
      </a>

    </nav>
  </div>
</aside>