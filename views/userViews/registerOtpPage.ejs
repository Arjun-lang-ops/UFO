<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Verify Your Account - Urban Football</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-dark": "#0a0c10",
            },
            fontFamily: {
              display: ["Lexend", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              "2xl": "1rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
    <style type="text/tailwindcss">
      @layer utilities {
        .otp-input {
          @apply w-12 h-14 md:w-14 md:h-16 text-center text-2xl font-bold border rounded-xl bg-white dark:bg-[#111418] border-slate-200 dark:border-[#3b4754] text-slate-900 dark:text-white focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all outline-none;
        }
      }
    </style>
  </head>
  <body
    class="bg-background-dark font-display text-white antialiased min-h-screen flex flex-col"
  >
    <div class="fixed inset-0 z-0">
      <div
        class="absolute inset-0 bg-gradient-to-b from-black/60 via-background-dark/80 to-background-dark z-10"
      ></div>
      <div
        class="w-full h-full bg-cover bg-center bg-no-repeat grayscale-[20%] opacity-40"
        style="
          background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuAQPk5_OhqJalti4ncqzWctUFh8ERBbRosSS58Yu2StS9EvU4BrqaBwMsILTv6KBqeMYPzPzYT9SVNUm0DJmuCKuTeA10Rp-LKduAUZjYE_121Fsd3W6UWrFVbfSHsVtkZruKvNy5YNzvWGd55gu1pk95dIBoGn_KOCKxStXUEIRlsORPRF8y5pZa0XOZoJ6wCxj1xTBp7Y2bjKAcEzKjK_ZjbgfD9qxRsH5SR1xg3W74zO5C_j6WZsrm838W3P_qiibWZGVnWZLdA&quot;);
        "
      ></div>
    </div>
    <header
      class="relative z-20 flex items-center justify-between px-6 md:px-10 py-6"
    >
      <a class="flex items-center gap-2 text-slate-900 dark:text-white cursor-pointer hover:opacity-80 transition-opacity" href="/">
        <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
        <h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
      </a>
    </header>
    <main class="flex-grow flex items-center justify-center relative z-20 p-4">
      <div
        class="w-full max-w-[480px] bg-[#1c2127]/95 backdrop-blur-md rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] border border-[#283039] overflow-hidden"
      >
        <div class="px-8 pt-10 pb-8 flex flex-col items-center text-center">
          <div
            class="size-16 bg-primary/20 rounded-full flex items-center justify-center text-primary mb-6 ring-8 ring-primary/5"
          >
            <span class="material-symbols-outlined text-[32px]"
              >mark_email_read</span
            >
          </div>
          <h1
            class="text-white tracking-tight text-3xl font-bold leading-tight mb-3"
          >
            Verify Your Account
          </h1>
          <p
            class="text-[#9dabb9] text-base font-normal leading-relaxed max-w-xs"
          >
            We've sent a 6-digit verification code to
            <span id="userEmail" class="text-white font-medium"
              >user@example.com</span
            >
          </p>
        </div>
        <form id="otpForm" class="px-8 pb-10 flex flex-col gap-8">
          <div class="flex justify-between gap-2 md:gap-3">
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
            <input
              class="otp-input"
              maxlength="1"
              placeholder=""
              type="text"
              name="otp[]"
            />
          </div>
          <div
            id="otpError"
            class="text-red-500 text-sm text-center hidden"
          ></div>
          <button
            class="flex w-full cursor-pointer items-center justify-center rounded-xl h-14 px-4 bg-primary hover:bg-blue-600 transition-all text-white text-base font-bold leading-normal tracking-wide shadow-lg shadow-primary/30"
            type="submit"
          >
            Verify &amp; Continue
          </button>
          <div class="flex flex-col items-center gap-2">
            <p class="text-[#637588] text-sm">Didn't receive the code?</p>
            <div class="flex items-center gap-2">
              <button
                id="resendBtn"
                class="text-primary font-semibold text-sm hover:underline disabled:opacity-50 disabled:no-underline disabled:cursor-not-allowed"
                type="button"
                disabled
              >
                Resend Code
              </button>
              <span
                id="timer"
                class="text-[#9dabb9] text-sm font-mono bg-[#283039] px-2 py-0.5 rounded"
                >01:00</span
              >
            </div>
          </div>
        </form>
      </div>
    </main>
    <script src="/js/otpHandler.js"></script>
    <footer class="relative z-20 py-10 flex flex-col items-center gap-6">
      <div class="flex items-center gap-2 opacity-60">
        <div class="size-6 text-white">
          <svg
            class="w-full h-full"
            fill="none"
            viewBox="0 0 48 48"
            xmlns="http://www.w3.org/2000/svg"
          >
