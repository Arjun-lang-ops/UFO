<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Change Password - FootGear</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
            },
            fontFamily: {
              display: ["Lexend", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
    <style>
      .dark ::-webkit-scrollbar {
        width: 8px;
      }
      .dark ::-webkit-scrollbar-track {
        background: #101922;
      }
      .dark ::-webkit-scrollbar-thumb {
        background: #283039;
        border-radius: 4px;
      }
      .dark ::-webkit-scrollbar-thumb:hover {
        background: #374151;
      }
    </style>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white"
  >
    <div
      class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden"
    >
      <header
        class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-white dark:bg-[#111418] px-4 py-3 lg:px-10 sticky top-0 z-50"
      >
        <div class="flex items-center gap-8">
          <div class="flex items-center gap-4 text-slate-900 dark:text-white">
            <div class="size-8 flex items-center justify-center rounded bg-primary/20 text-primary"><span class="material-symbols-outlined" style="font-size: 24px;">sports_soccer</span></div>
            <h2
              class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-[-0.015em]"
            >
              Urban Football
            </h2>
          </div>
          <div class="hidden lg:flex items-center gap-9">
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Shop</a
            >
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Leagues</a
            >
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Sale</a
            >
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Support</a
            >
          </div>
        </div>
        <div class="flex flex-1 justify-end gap-4 sm:gap-8">
          <div class="hidden sm:flex flex-col min-w-40 !h-10 max-w-64">
            <div
              class="flex w-full flex-1 items-stretch rounded-lg h-full border border-slate-200 dark:border-none"
            >
              <div
                class="text-slate-400 dark:text-[#9dabb9] flex bg-white dark:bg-[#283039] items-center justify-center pl-4 rounded-l-lg border-r-0"
              >
                <span class="material-symbols-outlined text-[20px]"
                  >search</span
                >
              </div>
              <input
                class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-white dark:bg-[#283039] focus:border-none h-full placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] px-4 rounded-l-none border-l-0 pl-2 text-sm font-normal leading-normal"
                placeholder="Search gear..."
                value=""
              />
            </div>
          </div>
          <div class="flex gap-2">
            <button
              class="flex items-center justify-center overflow-hidden rounded-lg size-10 bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-[#3e4a56] transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]"
                >shopping_cart</span
              >
            </button>
            <button
              class="flex items-center justify-center overflow-hidden rounded-lg size-10 bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-[#3e4a56] transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]"
                >notifications</span
              >
            </button>
            <div
              class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border border-slate-200 dark:border-[#3e4a56] cursor-pointer"
              data-alt="User profile avatar small"
              style="
                background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuAOe8dOzynzR_8mQ2G0YbbIh0QHIrRROTfOtOox9QC0rRHgcZfV0GbJJ2aFVaq-NYlgfylMAuD9WQfieAM_A68WVWcSXgr_aXQ0qlnvvfXnPuO7lajocByOYbPcmxqPvGOzHaATQS-a2kMlt2wuxFBeaV_7n_Vv6COqGMJSbMlgZtUEvRROBQvk2AZujQRQOdZgPSxRCs5kYZIcTDAGTUVKOuUmr3lJLgBWwEW8UsN_uKZ8jGsBcWUfNss6xWae-7sRJFDuMGtP3bA&quot;);
              "
            ></div>
          </div>
        </div>
      </header>
      <main
        class="layout-container flex h-full grow flex-col py-5 px-4 sm:px-6 lg:px-40"
      >
        <div class="flex flex-1 justify-center">
          <div
            class="layout-content-container flex flex-col max-w-[1200px] flex-1 w-full"
          >
            <div class="flex items-center gap-2 pb-6 pt-2">
              <a
                class="text-slate-500 hover:text-primary transition-colors"
                href="/profile"
              >
                <span class="material-symbols-outlined align-middle"
                  >arrow_back</span
                >
              </a>
              <h1
                class="text-slate-900 dark:text-white tracking-tight text-[32px] font-bold leading-tight"
              >
                Change Password
              </h1>
            </div>
            <div class="flex flex-col lg:flex-row gap-6">
              <%- include('partials/userSidebar', { activePage: 'changePassword' }) %>
              <div class="flex-1 flex flex-col gap-6">
                <section
                  class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm"
                >
                  <div
                    class="px-6 py-4 border-b border-slate-100 dark:border-[#283039]"
                  >
                    <h3
                      class="text-slate-900 dark:text-white text-lg font-bold"
                    >
                      Update Account Password
                    </h3>
                  </div>
                  <div class="p-6">
                    <form class="max-w-xl flex flex-col gap-6">
                      <div class="flex flex-col gap-1.5">
                        <label
                          class="text-slate-600 dark:text-[#9dabb9] text-sm font-medium"
                          >Current Password</label
                        >
                        <div class="relative">
                          <span
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors"
                          >
                            <span class="material-symbols-outlined text-[20px]"
                              >lock</span
                            >
                          </span>
                          <input
                            class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[48px] py-[15px] text-base font-normal leading-normal transition-all"
                            placeholder="••••••••"
                            type="password"
                            value=""
                            id="currentPassword"
                            name="currenPassword"
                          />
                          <button
                            class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 dark:text-[#9dabb9] hover:text-primary transition-colors cursor-pointer"
                            type="button"
                          >
                            <span class="material-symbols-outlined text-[20px]"
                              >visibility</span
                            >
                          </button>
                        </div>
                      </div>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-1.5">
                          <label
                            class="text-slate-600 dark:text-[#9dabb9] text-sm font-medium"
                            >New Password</label
                          >
                          <div class="relative">
                            <span
                              class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors"
                            >
                              <span
                                class="material-symbols-outlined text-[20px]"
                                >lock</span
                              >
                            </span>
                            <input
                              class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[48px] py-[15px] text-base font-normal leading-normal transition-all"
                              placeholder="••••••••"
                              type="password"
                              value=""
                              name="newPassword"
                              id="newPassword"
                            />
                            <button
                              class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 dark:text-[#9dabb9] hover:text-primary transition-colors cursor-pointer"
                              type="button"
                            >
                              <span
                                class="material-symbols-outlined text-[20px]"
                                >visibility</span
                              >
                            </button>
                          </div>
                          <p
                            class="text-[10px] text-slate-500 mt-1 uppercase tracking-wider font-semibold"
                          >
                            Security Strength:
                            <span class="text-green-500">Strong</span>
                          </p>
                        </div>
                        <div class="flex flex-col gap-1.5">
                          <label
                            class="text-slate-600 dark:text-[#9dabb9] text-sm font-medium"
                            >Confirm New Password</label
                          >
                          <div class="relative">
                            <span
                              class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors"
                            >
                              <span
                                class="material-symbols-outlined text-[20px]"
                                >lock</span
                              >
                            </span>
                            <input
                              class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[48px] py-[15px] text-base font-normal leading-normal transition-all"
                              placeholder="••••••••"
                              type="password"
                              value=""
                              name="confirmPassword"
                              id="confirmPassword"
                            />
                            <button
                              class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 dark:text-[#9dabb9] hover:text-primary transition-colors cursor-pointer"
                              type="button"
                            >
                              <span
                                class="material-symbols-outlined text-[20px]"
                                >visibility</span
                              >
                            </button>
                          </div>
                        </div>
                      </div>
                      <div
                        class="mt-4 flex flex-col sm:flex-row items-center gap-4"
                      >
                        <button
                          class="w-full sm:w-auto bg-primary hover:bg-blue-600 text-white font-bold py-2.5 px-8 rounded-lg shadow-lg shadow-blue-500/20 transition-all flex items-center justify-center gap-2"
                          type="submit"
                        >
                          <span class="material-symbols-outlined text-[20px]"
                            >check_circle</span
                          >
                          Update Password
                        </button>
                        <a
                          class="text-slate-500 dark:text-[#9dabb9] hover:text-slate-900 dark:hover:text-white text-sm font-medium transition-colors"
                          href="/profile"
                        >
                          Cancel
                        </a>
                      </div>
                    </form>
                  </div>
                </section>
                <section
                  class="bg-blue-50 dark:bg-blue-900/10 rounded-xl border border-blue-100 dark:border-blue-900/30 p-6"
                >
                  <div class="flex gap-4">
                    <div
                      class="bg-blue-100 dark:bg-blue-900/30 p-2 rounded-lg h-fit text-blue-600 dark:text-blue-400"
                    >
                      <span class="material-symbols-outlined block">info</span>
                    </div>
                    <div class="flex flex-col gap-2">
                      <h4
                        class="text-blue-900 dark:text-blue-200 font-bold text-sm"
                      >
                        Security Recommendation
                      </h4>
                      <p
                        class="text-blue-800/80 dark:text-blue-300/80 text-xs leading-relaxed"
                      >
                        A secure password should contain at least 8 characters,
                        including a mix of letters (both uppercase and
                        lowercase), numbers, and symbols. Avoid using personal
                        information or common dictionary words.
                      </p>
                    </div>
                  </div>
                </section>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>

  <script src="/js/changePassword.js"></script>
</html>
