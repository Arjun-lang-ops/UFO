<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Checkout Booking - ProKicks</title>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
</head>

<body
    class="bg-background-light dark:bg-background-dark font-display text-[#111418] dark:text-white overflow-x-hidden transition-colors duration-200">
    <div class="flex flex-col min-h-screen">
        <!-- Top Navigation -->
        <header
            class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 dark:border-[#283039] bg-background-light dark:bg-background-dark px-6 py-4 lg:px-10">
            <div class="flex items-center gap-4 text-[#111418] dark:text-white">
                <div class="size-8 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined !text-[32px]">sports_soccer</span>
                </div>
                <a href="/home">
                    <h2 class="text-xl font-bold leading-tight tracking-[-0.015em]">Urban Football</h2>
                </a>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden sm:flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400">
                    <span class="material-symbols-outlined !text-lg text-primary">lock</span>
                    Secure Checkout
                </div>
            </div>
        </header>
        <main class="flex-grow flex justify-center py-8 px-4 sm:px-6 lg:px-8">
            <div class="w-full max-w-7xl flex flex-col gap-8">
                <!-- Breadcrumbs / Progress Stepper -->
                <nav class="flex flex-wrap items-center gap-2 text-sm sm:text-base">
                    <a class="text-gray-500 hover:text-primary transition-colors font-medium flex items-center gap-1"
                        href="/cart">
                        <span class="material-symbols-outlined !text-lg">shopping_cart</span> Cart
                    </a>
                    <span class="material-symbols-outlined !text-lg text-gray-400">chevron_right</span>
                    <span class="text-primary font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined !text-lg">info</span> Information
                    </span>
                    <span class="material-symbols-outlined !text-lg text-gray-400">chevron_right</span>
                    <span class="text-gray-400 font-medium">Payment</span>
                    <span class="material-symbols-outlined !text-lg text-gray-400">chevron_right</span>
                    <span class="text-gray-400 font-medium">Complete</span>
                </nav>
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
                    <!-- Left Column: Forms & Input -->
                    <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-8">
                        <!-- Page Heading -->
                        <div>
                            <h1 class="text-3xl font-bold tracking-tight text-[#111418] dark:text-white">Checkout</h1>
                            <p class="text-gray-500 dark:text-gray-400 mt-2">Please fill in your details to complete the
                                order.</p>
                        </div>
                        <!-- Delivery Address Section -->
                        <section
                            class="bg-white dark:bg-[#1c232d] rounded-xl p-6 shadow-sm border border-gray-100 dark:border-[#283039]">
                            <div class="flex items-center justify-between mb-6">
                                <h3 class="text-lg font-bold flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">location_on</span>
                                    Delivery Address
                                </h3>
                                <button id="openAddAddressModal" type="button"
                                    class="text-primary text-sm font-bold hover:underline flex items-center gap-1">
                                    <span class="material-symbols-outlined !text-lg">add</span>
                                    Add New
                                </button>
                            </div>
                            <% const checkoutAddresses=checkoutData.addresses || []; %>
                                <% if (checkoutAddresses.length> 0) { %>
                                    <label class="mb-4 flex flex-col gap-2">
                                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Select
                                            delivery address</span>
                                        <select id="checkoutAddressSelect"
                                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white">
                                            <% checkoutAddresses.forEach(address=> { %>
                                                <option value="<%= address._id %>"
                                                    <%=checkoutData?.defaultAddress?._id?.toString()===address._id.toString()
                                                    ? 'selected' : '' %>>
                                                    <%= address.fullname %> - <%= address.street %>, <%= address.state
                                                                %>
                                                                <%= address.isDefault ? '(Default)' : '' %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </label>
                                    <% } %>
                                        <div id="selectedAddress"
                                            class="rounded-xl border border-gray-200 dark:border-[#3b4754] p-5 flex justify-between items-start">
                                            <div class="flex flex-col gap-1">
                                                <%if(checkoutData.defaultAddress){%>
                                                    <h4 id="checkoutAddressName"
                                                        class="text-lg font-bold text-[#111418] dark:text-white">
                                                        <%=checkoutData?.defaultAddress?.fullname%>
                                                    </h4>
                                                    <div class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5">
                                                        <p id="checkoutAddressStreet">
                                                            <%=checkoutData?.defaultAddress?.street%>
                                                        </p>
                                                        <p id="checkoutAddressLocation">
                                                            <%= checkoutData?.defaultAddress?.apartment %>,
                                                                <%= checkoutData?.defaultAddress?.state %> -
                                                                    <%= checkoutData?.defaultAddress?.pincode %>
                                                        </p>
                                                    </div>
                                                    <p
                                                        class="mt-3 text-sm font-medium text-[#111418] dark:text-gray-300">
                                                        Phone:
                                                        <span id="checkoutAddressPhone">
                                                            <%=checkoutData?.defaultAddress?.phone%>
                                                        </span>
                                                    </p>
                                                    <%}else{%>
                                                        <p class="text-red-500">
                                                            No default address found
                                                        </p>

                                                        <% } %>
                                            </div>
                                            <button id="openEditAddressModal" type="button"
                                                data-id="<%= checkoutData?.defaultAddress?._id %>"
                                                data-fullname="<%= checkoutData?.defaultAddress?.fullname %>"
                                                data-phone="<%= checkoutData?.defaultAddress?.phone %>"
                                                data-country="<%= checkoutData?.defaultAddress?.country %>"
                                                data-state="<%= checkoutData?.defaultAddress?.state %>"
                                                data-street="<%= checkoutData?.defaultAddress?.street %>"
                                                data-apartment="<%= checkoutData?.defaultAddress?.apartment %>"
                                                data-pincode="<%= checkoutData?.defaultAddress?.pincode %>"
                                                data-is-default="<%= checkoutData?.defaultAddress?.isDefault ? 'true' : 'false' %>"
                                                class="<%= checkoutData?.defaultAddress ? '' : 'hidden ' %>flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-primary transition-colors">

                                                <span class="material-symbols-outlined !text-lg">edit</span>
                                                Edit

                                            </button>
                                        </div>
                        </section>
                        <!-- Shipping Method -->
                        <section
                            class="bg-white dark:bg-[#1c232d] rounded-xl p-6 shadow-sm border border-gray-100 dark:border-[#283039]">
                            <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">local_shipping</span>
                                Payment Method
                            </h3>
                            <div class="space-y-3">
                                <label
                                    class="shipping-option relative flex items-center justify-between p-4 rounded-lg border border-gray-200 dark:border-[#3b4754] hover:border-gray-400 dark:hover:border-gray-500 cursor-pointer transition-all">
                                    <div class="flex items-center gap-3">
                                        <input checked="" name="paymentMethod" value="COD"
                                            class="h-5 w-5 text-primary border-gray-300 focus:ring-primary"
                                            type="radio" />
                                        <div class="flex flex-col">
                                            <span class="text-base font-bold text-[#111418] dark:text-white">Cash On
                                                Delivery</span>
                                            <span class="text-sm text-gray-500 dark:text-gray-400">Pay when your order
                                                arrives. No wallet refund is created unless a paid order is later
                                                returned.</span>
                                        </div>
                                    </div>

                                </label>
                                <label
                                    class="shipping-option relative flex items-center justify-between p-4 rounded-lg border border-gray-200 dark:border-[#3b4754] hover:border-gray-400 dark:hover:border-gray-500 cursor-pointer transition-all">
                                    <div class="flex items-center gap-3">
                                        <input class="h-5 w-5 text-primary border-gray-300 focus:ring-primary"
                                            name="paymentMethod" value="RAZORPAY" type="radio" />
                                        <div class="flex flex-col">
                                            <span class="text-base font-bold text-[#111418] dark:text-white">Online
                                                Payment</span>
                                            <span class="text-sm text-gray-500 dark:text-gray-400">Pay securely with
                                                Razorpay using UPI, cards, net banking, or wallets.</span>
                                        </div>
                                    </div>

                                </label>
                                <label
                                    class="shipping-option relative flex items-center justify-between p-4 rounded-lg border border-gray-200 dark:border-[#3b4754] hover:border-gray-400 dark:hover:border-gray-500 cursor-pointer transition-all">
                                    <div class="flex items-center gap-3">
                                        <input class="h-5 w-5 text-primary border-gray-300 focus:ring-primary"
                                            name="paymentMethod" value="WALLET" type="radio" />
                                        <div class="flex flex-col">
                                            <span class="text-base font-bold text-[#111418] dark:text-white">Wallet
                                            </span>
                                            <span class="text-sm text-gray-500 dark:text-gray-400">Est. 5-7 business
                                                days</span>
                                        </div>
                                    </div>

                                </label>
                            </div>
                        </section>
                        <!-- Review Cart Items -->
                        <section
                            class="bg-white dark:bg-[#1c232d] rounded-xl p-6 shadow-sm border border-gray-100 dark:border-[#283039]">
                            <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">shopping_bag</span>
                                Review Items
                            </h3>
                            <div class="flex flex-col gap-6">

                                <% checkoutData.cartItems.forEach(item=> { %>

                                    <div
                                        class="flex items-start gap-4 pb-6 border-b border-gray-100 dark:border-[#283039]">

                                        <!-- IMAGE -->
                                        <div
                                            class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-lg bg-gray-200 dark:bg-gray-800">

                                            <img class="h-full w-full object-cover object-center"
                                                src="<%= item.image %>" alt="<%= item.name %>" />

                                        </div>

                                        <!-- DETAILS -->
                                        <div class="flex flex-1 flex-col">

                                            <div>

                                                <div
                                                    class="flex justify-between text-base font-medium text-[#111418] dark:text-white">

                                                    <h4>
                                                        <%= item.name %>
                                                    </h4>

                                                    <p>₹<%= item.total %>
                                                    </p>

                                                </div>

                                                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                                                    <%= item.color %>
                                                </p>

                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Size: <%= item.size %>
                                                </p>

                                            </div>

                                            <div class="flex flex-1 items-end justify-between text-sm">

                                                <p class="text-gray-500 dark:text-gray-400">
                                                    Qty <%= item.quantity %>
                                                </p>

                                            </div>

                                        </div>

                                    </div>

                                    <% }) %>
                                        <!-- Item 1 -->

                                        <!-- Item 2 -->

                            </div>
                        </section>
                    </div>
                    <!-- Right Column: Order Summary (Sticky) -->
                    <div class="lg:col-span-5 xl:col-span-4">
                        <div
                            class="sticky top-24 rounded-xl bg-white dark:bg-[#1c232d] shadow-lg border border-gray-100 dark:border-[#283039] overflow-hidden">
                            <div class="p-6">
                                <h2 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Order Summary</h2>
                                <div class="flow-root">
                                    <dl class="-my-4 divide-y divide-gray-100 dark:divide-[#283039] text-sm">
                                        <div class="flex items-center justify-between py-4">
                                            <dt class="text-gray-500 dark:text-gray-400">Subtotal</dt>
                                            <dd id="summarySubtotal" class="font-medium text-[#111418] dark:text-white">Rs.
                                                <%=checkoutData?.subtotal%>
                                            </dd>
                                        </div>
                                        <div class="flex items-center justify-between py-4">
                                            <dt class="text-gray-500 dark:text-gray-400">Shipping</dt>
                                            <dd id="summaryShipping" class="font-medium text-[#111418] dark:text-white">Rs. <%=
                                                    checkoutData?.shippingCharge %>
                                            </dd>
                                        </div>
                                        <div id="discountSummaryRow"
                                            class="hidden items-center justify-between py-4">
                                            <dt class="text-gray-500 dark:text-gray-400">Coupon Discount</dt>
                                            <dd id="summaryDiscount" class="font-medium text-green-600 dark:text-green-400">- Rs. 0</dd>
                                        </div>
                                        <div class="flex items-center justify-between py-4">
                                            <dt class="text-gray-500 dark:text-gray-400">Tax</dt>
                                            <dd class="font-medium text-[#111418] dark:text-white">Free</dd>
                                        </div>
                                        <div
                                            class="flex items-center justify-between py-4 border-t-2 border-dashed dark:border-[#3b4754] !border-b-0 mt-2">
                                            <dt class="text-base font-bold text-[#111418] dark:text-white">Total</dt>
                                            <dd id="summaryGrandTotal" class="text-xl font-bold text-primary">Rs. <%=checkoutData?.grandTotal%>
                                            </dd>
                                        </div>
                                    </dl>
                                </div>
                                <!-- Promo Code -->
                                <div class="mt-6 pt-6 border-t border-gray-100 dark:border-[#283039]">
                                    <div class="mb-3 flex items-center justify-between gap-3">
                                        <label
                                            class="block text-sm font-medium text-gray-700 dark:text-gray-300">Available
                                            Coupons</label>
                                        <button id="clearCouponSelection"
                                            class="hidden text-xs font-bold text-gray-500 hover:text-primary dark:text-gray-400"
                                            type="button">Clear</button>
                                    </div>
                                    <input
                                        class="mb-3 block w-full rounded-lg border-gray-200 dark:border-[#3b4754] bg-gray-50 dark:bg-[#121922] p-2.5 text-sm dark:text-white placeholder-gray-400 focus:border-primary focus:ring-primary"
                                        placeholder="Select a coupon below" type="text" id="couponCode" readonly />
                                    <p id="couponApplyMessage" class="mb-3 hidden text-xs font-bold"></p>
                                    <% const checkoutCoupons=checkoutData.coupons || []; %>
                                        <% if (checkoutCoupons.length> 0) { %>
                                            <div id="couponList" class="max-h-60 overflow-y-auto pr-1 space-y-3">
                                                <% checkoutCoupons.forEach(coupon=> {
                                                    const discountText = coupon.discountType === "PERCENTAGE"
                                                    ? `${coupon.discountValue}% off${coupon.maximumDiscount ? ` up to
                                                    Rs. ${coupon.maximumDiscount}` : ""}`
                                                    : `Rs. ${coupon.discountValue} off`;
                                                    const expiryText = coupon.expiryDate
                                                    ? coupon.expiryDate.toLocaleDateString("en-IN", { day: "2-digit",
                                                    month: "short", year: "numeric" })
                                                    : "";
                                                    %>
                                                    <label
                                                        class="coupon-option flex cursor-pointer items-start gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 transition-all hover:border-primary dark:border-[#3b4754] dark:bg-[#121922]"
                                                        data-code="<%= coupon.code %>">
                                                        <input
                                                            class="mt-1 h-4 w-4 border-gray-300 text-primary focus:ring-primary"
                                                            name="checkoutCoupon" value="<%= coupon.code %>"
                                                            type="radio" />
                                                        <span class="flex min-w-0 flex-1 flex-col gap-1">
                                                            <span
                                                                class="flex flex-wrap items-center justify-between gap-2">
                                                                <span
                                                                    class="font-mono text-sm font-bold uppercase tracking-wide text-[#111418] dark:text-white">
                                                                    <%= coupon.code %>
                                                                </span>
                                                                <span
                                                                    class="rounded-full bg-primary/10 px-2 py-0.5 text-xs font-bold text-primary">
                                                                    <%= discountText %>
                                                                </span>
                                                            </span>
                                                            <span class="text-xs text-gray-500 dark:text-gray-400">
                                                                <%= coupon.description
                                                                    || "Apply this coupon to your order" %>
                                                            </span>
                                                            <span
                                                                class="text-[11px] text-gray-500 dark:text-gray-400">Minimum
                                                                order Rs. <%= coupon.minimumPurchase || 0 %> · Expires
                                                                    <%= expiryText %></span>
                                                        </span>
                                                    </label>
                                                    <% }) %>
                                            </div>
                                            <% } else { %>
                                                <div
                                                    class="rounded-lg border border-dashed border-gray-200 p-4 text-center text-sm text-gray-500 dark:border-[#3b4754] dark:text-gray-400">
                                                    No coupons available for this order.
                                                </div>
                                                <% } %>
                                </div>

                                <div class="mt-3 flex gap-2">
                                    <button id="applyCouponBtn" type="button"
                                        class="rounded-lg bg-primary px-4 py-2 text-white font-medium">
                                        Apply
                                    </button>
                                </div>
                                <!-- Action Button -->
                                <div class="mt-8">
                                    <button id="placeOrderBtn" type="button"
                                        class="w-full flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-4 text-base font-bold text-white shadow-sm hover:bg-blue-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all">
                                        Place Order
                                        <span class="material-symbols-outlined">arrow_forward</span>
                                    </button>
                                    <div class="mt-4 flex justify-center items-center gap-3 opacity-60">
                                        <span class="material-symbols-outlined text-gray-400 dark:text-gray-500"
                                            title="Credit Card">credit_card</span>
                                        <span class="material-symbols-outlined text-gray-400 dark:text-gray-500"
                                            title="Lock">lock</span>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">Secure 256-bit SSL encrypted
                                            payment</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Address Modal -->
    <div id="addressModal"
        class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 px-4 py-6 opacity-0 backdrop-blur-sm transition-opacity duration-200">
        <div id="addressModalPanel"
            class="w-full max-w-2xl max-h-[92vh] overflow-y-auto rounded-xl border border-gray-200 dark:border-[#283039] bg-white dark:bg-[#1c232d] shadow-2xl scale-95 transition-transform duration-200">
            <div
                class="sticky top-0 z-10 flex items-center justify-between border-b border-gray-100 dark:border-[#283039] bg-white/95 dark:bg-[#1c232d]/95 px-6 py-4 backdrop-blur">
                <div>
                    <h3 id="addressModalTitle" class="text-xl font-bold text-[#111418] dark:text-white">Add New Address
                    </h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Enter the delivery details for this order.
                    </p>
                </div>
                <button id="closeAddressModal" type="button"
                    class="flex size-10 items-center justify-center rounded-lg text-gray-500 transition-colors hover:bg-gray-100 hover:text-[#111418] dark:text-gray-400 dark:hover:bg-[#283039] dark:hover:text-white"
                    aria-label="Close address modal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="checkoutAddressForm" class="p-6">
                <input type="hidden" id="addressId" name="addressId">
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Full Name</span>
                        <input id="addressFullname" name="fullname" type="text" placeholder="John Doe"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressFullnameError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Phone Number</span>
                        <input id="addressPhone" name="phone" type="tel" placeholder="9876543210" inputmode="numeric"
                            maxlength="10"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressPhoneError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Country</span>
                        <input id="addressCountry" name="country" type="text" placeholder="India"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressCountryError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">State / Province</span>
                        <input id="addressState" name="state" type="text" placeholder="Kerala"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressStateError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2 md:col-span-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Street Address</span>
                        <input id="addressStreet" name="street" type="text" placeholder="House name, street, locality"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressStreetError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">Apartment / City</span>
                        <input id="addressApartment" name="apartment" type="text" placeholder="Apartment, suite, city"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressApartmentError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-[#111418] dark:text-gray-200">ZIP / Pincode</span>
                        <input id="addressPincode" name="pincode" type="text" placeholder="688526" inputmode="numeric"
                            maxlength="6"
                            class="h-12 rounded-lg border-gray-200 bg-gray-50 px-4 text-sm text-[#111418] placeholder:text-gray-400 focus:border-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922] dark:text-white" />
                        <span id="addressPincodeError" class="hidden text-xs font-medium text-red-500"></span>
                    </label>
                </div>

                <label class="mt-5 flex items-center gap-3">
                    <input id="addressDefault" name="isDefault" type="checkbox"
                        class="size-4 rounded border-gray-300 text-primary focus:ring-primary dark:border-[#3b4754] dark:bg-[#121922]" />
                    <span class="text-sm text-gray-600 dark:text-gray-300">Set as default shipping address</span>
                </label>

                <div
                    class="mt-6 flex flex-col-reverse gap-3 border-t border-gray-100 pt-5 dark:border-[#283039] sm:flex-row sm:justify-end">
                    <button id="cancelAddressModal" type="button"
                        class="rounded-lg px-5 py-3 text-sm font-bold text-gray-600 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-[#283039]">
                        Cancel
                    </button>
                    <button type="submit"
                        class="rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white shadow-sm transition-colors hover:bg-blue-600">
                        Save Address
                    </button>
                </div>
            </form>
        </div>
    </div>


    <!-- Order Loading Overlay -->
    <div id="orderLoadingOverlay"
        class="fixed inset-0 z-[120] hidden items-center justify-center bg-[#101922]/90 px-4 text-center opacity-0 backdrop-blur-sm transition-opacity duration-200">
        <div
            class="flex w-full max-w-sm flex-col items-center rounded-xl border border-[#283039] bg-white p-8 shadow-2xl dark:bg-[#1c232d]">
            <div class="relative mb-6 flex size-20 items-center justify-center">
                <div class="absolute inset-0 rounded-full border-4 border-primary/20"></div>
                <div class="absolute inset-0 rounded-full border-4 border-transparent border-t-primary animate-spin">
                </div>
                <span class="material-symbols-outlined text-primary !text-4xl">shopping_bag</span>
            </div>
            <h3 class="text-xl font-bold text-[#111418] dark:text-white">Placing your order</h3>
            <p class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">Please wait while we confirm your order
                details.</p>
        </div>
    </div>

    <script>
        const addressModal = document.getElementById("addressModal");
        const addressModalPanel = document.getElementById("addressModalPanel");
        const addressModalTitle = document.getElementById("addressModalTitle");
        const checkoutAddressForm = document.getElementById("checkoutAddressForm");
        const openAddAddressModal = document.getElementById("openAddAddressModal");
        const openEditAddressModal = document.getElementById("openEditAddressModal");
        const checkoutAddressSelect = document.getElementById("checkoutAddressSelect");
        const closeAddressModal = document.getElementById("closeAddressModal");
        const cancelAddressModal = document.getElementById("cancelAddressModal");

        const addressFields = {
            fullname: document.getElementById("addressFullname"),
            phone: document.getElementById("addressPhone"),
            country: document.getElementById("addressCountry"),
            state: document.getElementById("addressState"),
            street: document.getElementById("addressStreet"),
            apartment: document.getElementById("addressApartment"),
            pincode: document.getElementById("addressPincode"),
            isDefault: document.getElementById("addressDefault")
        };

        const addressErrors = {
            fullname: document.getElementById("addressFullnameError"),
            phone: document.getElementById("addressPhoneError"),
            country: document.getElementById("addressCountryError"),
            state: document.getElementById("addressStateError"),
            street: document.getElementById("addressStreetError"),
            apartment: document.getElementById("addressApartmentError"),
            pincode: document.getElementById("addressPincodeError")
        };

        const selectedAddress = {
            name: document.getElementById("checkoutAddressName"),
            street: document.getElementById("checkoutAddressStreet"),
            location: document.getElementById("checkoutAddressLocation"),
            phone: document.getElementById("checkoutAddressPhone")
        };

        const showAddressError = (fieldName, message) => {
            const input = addressFields[fieldName];
            const error = addressErrors[fieldName];

            if (!input || !error) return;

            input.classList.add("border-red-500", "focus:border-red-500", "focus:ring-red-500");
            input.classList.remove("border-gray-200", "focus:border-primary", "focus:ring-primary", "dark:border-[#3b4754]");
            error.textContent = message;
            error.classList.remove("hidden");
        };

        const clearAddressError = (fieldName) => {
            const input = addressFields[fieldName];
            const error = addressErrors[fieldName];

            if (!input || !error) return;

            input.classList.remove("border-red-500", "focus:border-red-500", "focus:ring-red-500");
            input.classList.add("border-gray-200", "focus:border-primary", "focus:ring-primary", "dark:border-[#3b4754]");
            error.textContent = "";
            error.classList.add("hidden");
        };

        const clearAddressErrors = () => {
            Object.keys(addressErrors).forEach(clearAddressError);
        };

        const validateCheckoutAddressForm = () => {
            let isValid = true;
            clearAddressErrors();

            const values = {
                fullname: addressFields.fullname.value.trim(),
                phone: addressFields.phone.value.trim(),
                country: addressFields.country.value.trim(),
                state: addressFields.state.value.trim(),
                street: addressFields.street.value.trim(),
                apartment: addressFields.apartment.value.trim(),
                pincode: addressFields.pincode.value.trim()
            };

            const nameRegex = /^[A-Za-z\s]{3,50}$/;
            const phoneRegex = /^[0-9]{10}$/;
            const pincodeRegex = /^[0-9]{6}$/;

            if (!values.fullname) {
                showAddressError("fullname", "Full name is required");
                isValid = false;
            } else if (!nameRegex.test(values.fullname)) {
                showAddressError("fullname", "Enter a valid name with at least 3 letters");
                isValid = false;
            }

            if (!values.phone) {
                showAddressError("phone", "Phone number is required");
                isValid = false;
            } else if (!phoneRegex.test(values.phone)) {
                showAddressError("phone", "Phone number must be exactly 10 digits");
                isValid = false;
            }

            if (!values.country) {
                showAddressError("country", "Country is required");
                isValid = false;
            }

            if (!values.state) {
                showAddressError("state", "State is required");
                isValid = false;
            }

            if (!values.street) {
                showAddressError("street", "Street address is required");
                isValid = false;
            } else if (values.street.length < 5) {
                showAddressError("street", "Street address is too short");
                isValid = false;
            }

            if (!values.apartment) {
                showAddressError("apartment", "Apartment or city is required");
                isValid = false;
            }

            if (!values.pincode) {
                showAddressError("pincode", "Pincode is required");
                isValid = false;
            } else if (!pincodeRegex.test(values.pincode)) {
                showAddressError("pincode", "Pincode must be exactly 6 digits");
                isValid = false;
            }

            return isValid;
        };

        const setEditButtonAddress = (address) => {
            if (!openEditAddressModal || !address) return;

            openEditAddressModal.dataset.id = address._id;
            openEditAddressModal.dataset.fullname = address.fullname || "";
            openEditAddressModal.dataset.phone = address.phone || "";
            openEditAddressModal.dataset.country = address.country || "";
            openEditAddressModal.dataset.state = address.state || "";
            openEditAddressModal.dataset.street = address.street || "";
            openEditAddressModal.dataset.apartment = address.apartment || "";
            openEditAddressModal.dataset.pincode = address.pincode || "";
            openEditAddressModal.dataset.isDefault = address.isDefault ? "true" : "false";
            openEditAddressModal.classList.remove("hidden");
        };

        const updateSelectedAddress = (address) => {
            if (!address || !selectedAddress.name) {
                window.location.reload();
                return;
            }

            selectedAddress.name.textContent = address.fullname || "";
            selectedAddress.street.textContent = address.street || "";
            selectedAddress.location.textContent = `${address.apartment || ""}, ${address.state || ""} - ${address.pincode || ""}`;
            selectedAddress.phone.textContent = address.phone || "";
            setEditButtonAddress(address);
        };

        const showAddressModal = (mode) => {
            checkoutAddressForm.dataset.mode = mode;
            addressModalTitle.textContent = mode === "edit" ? "Edit Address" : "Add New Address";
            clearAddressErrors();

            if (mode === "edit") {
                if (!openEditAddressModal.dataset.id) {
                    alert("Please select an address first");
                    return;
                }

                document.getElementById("addressId").value =
                    openEditAddressModal.dataset.id;

                addressFields.fullname.value =
                    openEditAddressModal.dataset.fullname || "";

                addressFields.phone.value =
                    openEditAddressModal.dataset.phone || "";

                addressFields.country.value =
                    openEditAddressModal.dataset.country || "";

                addressFields.state.value =
                    openEditAddressModal.dataset.state || "";

                addressFields.street.value =
                    openEditAddressModal.dataset.street || "";

                addressFields.apartment.value =
                    openEditAddressModal.dataset.apartment || "";

                addressFields.pincode.value =
                    openEditAddressModal.dataset.pincode || "";

                addressFields.isDefault.checked =
                    openEditAddressModal.dataset.isDefault === "true";

            } else {
                checkoutAddressForm.reset();
                document.getElementById("addressId").value = "";
                addressFields.isDefault.checked = !checkoutAddressSelect;
            }

            addressModal.classList.remove("hidden");
            addressModal.classList.add("flex");
            document.body.classList.add("overflow-hidden");

            requestAnimationFrame(() => {
                addressModal.classList.remove("opacity-0");
                addressModalPanel.classList.remove("scale-95");
            });
        };

        const hideAddressModal = () => {
            clearAddressErrors();
            addressModal.classList.add("opacity-0");
            addressModalPanel.classList.add("scale-95");
            document.body.classList.remove("overflow-hidden");

            setTimeout(() => {
                addressModal.classList.add("hidden");
                addressModal.classList.remove("flex");
            }, 200);
        };

        openAddAddressModal.addEventListener("click", () => showAddressModal("add"));
        openEditAddressModal?.addEventListener("click", () => showAddressModal("edit"));
        closeAddressModal.addEventListener("click", hideAddressModal);
        cancelAddressModal.addEventListener("click", hideAddressModal);

        Object.entries(addressFields).forEach(([fieldName, input]) => {
            if (!addressErrors[fieldName]) return;

            input.addEventListener("input", () => {
                if (fieldName === "phone") {
                    input.value = input.value.replace(/\D/g, "").slice(0, 10);
                }

                if (fieldName === "pincode") {
                    input.value = input.value.replace(/\D/g, "").slice(0, 6);
                }

                clearAddressError(fieldName);
            });
        });

        checkoutAddressSelect?.addEventListener("change", async (event) => {
            try {
                const response = await fetch(`/checkout/address/select/${event.target.value}`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json"
                    }
                });

                const result = await response.json();

                if (!result.success) {
                    alert(result.message || "Failed to select address");
                    return;
                }

                updateSelectedAddress(result.address);
            } catch (error) {
                console.log(error);
                alert("Something went wrong");
            }
        });

        addressModal.addEventListener("click", (event) => {
            if (event.target === addressModal) hideAddressModal();
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && !addressModal.classList.contains("hidden")) {
                hideAddressModal();
            }
        });

        checkoutAddressForm.addEventListener("submit", async (event) => {

            event.preventDefault();

            if (!validateCheckoutAddressForm()) return;

            const mode = checkoutAddressForm.dataset.mode;

            const addressData = {

                fullname: addressFields.fullname.value.trim(),
                phone: addressFields.phone.value.trim(),
                country: addressFields.country.value.trim(),
                state: addressFields.state.value.trim(),
                street: addressFields.street.value.trim(),
                apartment: addressFields.apartment.value.trim(),
                pincode: addressFields.pincode.value.trim(),
                isDefault: addressFields.isDefault.checked

            };

            try {

                // EDIT ADDRESS
                if (mode === "edit") {

                    const addressId =
                        document.getElementById("addressId").value;

                    const response = await fetch(`/edit-address/${addressId}`, {

                        method: "PUT",

                        headers: {
                            "Content-Type": "application/json"
                        },

                        body: JSON.stringify(addressData)

                    });

                    const result = await response.json();

                    if (result.success) {

                        selectedAddress.name.textContent =
                            addressData.fullname;

                        selectedAddress.street.textContent =
                            addressData.street;

                        selectedAddress.location.textContent =
                            `${addressData.apartment}, ${addressData.state} - ${addressData.pincode}`;

                        selectedAddress.phone.textContent =
                            addressData.phone;

                        openEditAddressModal.dataset.fullname = addressData.fullname;
                        openEditAddressModal.dataset.phone = addressData.phone;
                        openEditAddressModal.dataset.country = addressData.country;
                        openEditAddressModal.dataset.state = addressData.state;
                        openEditAddressModal.dataset.street = addressData.street;
                        openEditAddressModal.dataset.apartment = addressData.apartment;
                        openEditAddressModal.dataset.pincode = addressData.pincode;
                        openEditAddressModal.dataset.isDefault = result.address?.isDefault ? "true" : String(addressData.isDefault);

                        hideAddressModal();

                    } else {

                        alert(result.message || "Failed to update address");

                    }

                }

                if (mode === "add") {

                    const response = await fetch("/checkout/address/add", {

                        method: "POST",

                        headers: {
                            "Content-Type": "application/json"
                        },

                        body: JSON.stringify(addressData)

                    });

                    const result = await response.json();

                    if (result.success) {

                        hideAddressModal();
                        window.location.reload();

                    } else {

                        alert(result.message || "Failed to add address");

                    }

                }

            } catch (error) {

                console.log(error);

                alert("Something went wrong");

            }

        });



        //label outline blue color script
        const shippingOptions = document.querySelectorAll(".shipping-option");
        const shippingRadios = document.querySelectorAll('input[name="paymentMethod"]');

        const updateShippingSelection = () => {

            shippingOptions.forEach(option => {

                option.classList.remove(
                    "border-2",
                    "border-primary",
                    "bg-blue-50/50",
                    "dark:bg-blue-900/10"
                );

                option.classList.add(
                    "border",
                    "border-gray-200",
                    "dark:border-[#3b4754]"
                );

            });

            shippingRadios.forEach(radio => {

                if (radio.checked) {

                    const selectedOption = radio.closest(".shipping-option");

                    selectedOption.classList.remove(
                        "border",
                        "border-gray-200",
                        "dark:border-[#3b4754]"
                    );

                    selectedOption.classList.add(
                        "border-2",
                        "border-primary",
                        "bg-blue-50/50",
                        "dark:bg-blue-900/10"
                    );

                }

            });

        };

        shippingRadios.forEach(radio => {
            radio.addEventListener("change", updateShippingSelection);
        });

        updateShippingSelection();

        const couponCodeInput = document.getElementById("couponCode");
        const couponOptions = document.querySelectorAll(".coupon-option");
        const couponRadios = document.querySelectorAll('input[name="checkoutCoupon"]');
        const clearCouponSelection = document.getElementById("clearCouponSelection");
        const applyCouponBtn = document.getElementById("applyCouponBtn");
        const couponApplyMessage = document.getElementById("couponApplyMessage");
        const discountSummaryRow = document.getElementById("discountSummaryRow");
        const summaryDiscount = document.getElementById("summaryDiscount");
        const summaryGrandTotal = document.getElementById("summaryGrandTotal");
        const baseGrandTotal = Number("<%= checkoutData?.grandTotal || 0 %>");
        let appliedCouponCode = "";

        const formatAmount = (amount) => `Rs. ${Number(amount || 0).toFixed(2)}`;

        const showCouponMessage = (message, isSuccess = false) => {
            couponApplyMessage.textContent = message;
            couponApplyMessage.classList.remove("hidden", "text-green-600", "text-red-500", "dark:text-green-400", "dark:text-red-400");
            couponApplyMessage.classList.add(
                isSuccess ? "text-green-600" : "text-red-500",
                isSuccess ? "dark:text-green-400" : "dark:text-red-400"
            );
        };

        const resetAppliedCoupon = () => {
            appliedCouponCode = "";
            discountSummaryRow.classList.add("hidden");
            discountSummaryRow.classList.remove("flex");
            summaryDiscount.textContent = "- Rs. 0";
            summaryGrandTotal.textContent = formatAmount(baseGrandTotal);
            couponApplyMessage.classList.add("hidden");
        };

        const updateCouponSelection = () => {
            let selectedCode = "";

            couponOptions.forEach(option => {
                option.classList.remove(
                    "border-primary",
                    "bg-blue-50",
                    "dark:bg-blue-900/10",
                    "ring-1",
                    "ring-primary"
                );

                option.classList.add(
                    "border-gray-200",
                    "dark:border-[#3b4754]",
                    "bg-gray-50",
                    "dark:bg-[#121922]"
                );
            });

            couponRadios.forEach(radio => {
                if (!radio.checked) return;

                selectedCode = radio.value;
                const selectedOption = radio.closest(".coupon-option");

                selectedOption.classList.remove(
                    "border-gray-200",
                    "dark:border-[#3b4754]",
                    "bg-gray-50",
                    "dark:bg-[#121922]"
                );

                selectedOption.classList.add(
                    "border-primary",
                    "bg-blue-50",
                    "dark:bg-blue-900/10",
                    "ring-1",
                    "ring-primary"
                );
            });

            couponCodeInput.value = selectedCode;
            clearCouponSelection?.classList.toggle("hidden", !selectedCode);
        };

        couponRadios.forEach(radio => {
            radio.addEventListener("change", () => {
                updateCouponSelection();
                resetAppliedCoupon();
            });
        });

        clearCouponSelection?.addEventListener("click", () => {
            couponRadios.forEach(radio => {
                radio.checked = false;
            });

            updateCouponSelection();
            resetAppliedCoupon();
        });

        updateCouponSelection();

        applyCouponBtn?.addEventListener("click", async () => {
            const couponCode = couponCodeInput.value.trim();

            if (!couponCode) {
                showCouponMessage("Select a coupon first");
                return;
            }

            try {
                applyCouponBtn.disabled = true;
                applyCouponBtn.textContent = "Applying...";

                const response = await fetch("/checkout/apply-coupon", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({ couponCode }),
                });

                const result = await response.json();

                if (!response.ok || !result.success) {
                    throw new Error(result.message || "Failed to apply coupon");
                }

                appliedCouponCode = result.couponCode;
                summaryDiscount.textContent = `- ${formatAmount(result.discount)}`;
                summaryGrandTotal.textContent = formatAmount(result.grandTotal);
                discountSummaryRow.classList.remove("hidden");
                discountSummaryRow.classList.add("flex");
                showCouponMessage(`${result.couponCode} applied successfully`, true);
            } catch (error) {
                appliedCouponCode = "";
                showCouponMessage(error.message || "Failed to apply coupon");
            } finally {
                applyCouponBtn.disabled = false;
                applyCouponBtn.textContent = "Apply";
            }
        });

        //place order confirm button validation
        const placeOrderBtn =
            document.getElementById(
                "placeOrderBtn"
            );
        const orderLoadingOverlay = document.getElementById("orderLoadingOverlay");

        const showOrderLoading = () => {
            orderLoadingOverlay.classList.remove("hidden");
            orderLoadingOverlay.classList.add("flex");
            document.body.classList.add("overflow-hidden");
            placeOrderBtn.disabled = true;
            placeOrderBtn.classList.add("cursor-not-allowed", "opacity-70");
            placeOrderBtn.innerHTML = `
        <span class="size-5 rounded-full border-2 border-white/40 border-t-white animate-spin"></span>
        Placing Order...
    `;

            requestAnimationFrame(() => {
                orderLoadingOverlay.classList.remove("opacity-0");
            });
        };

        const hideOrderLoading = () => {
            orderLoadingOverlay.classList.add("opacity-0");
            document.body.classList.remove("overflow-hidden");
            placeOrderBtn.disabled = false;
            placeOrderBtn.classList.remove("cursor-not-allowed", "opacity-70");
            placeOrderBtn.innerHTML = `
        Place Order
        <span class="material-symbols-outlined">arrow_forward</span>
    `;

            setTimeout(() => {
                orderLoadingOverlay.classList.add("hidden");
                orderLoadingOverlay.classList.remove("flex");
            }, 200);
        };

        placeOrderBtn.addEventListener(
            "click",
            async () => {

                //--------------------------------
                // address
                //--------------------------------

                const addressId =
                    document.getElementById(
                        "checkoutAddressSelect"
                    )?.value;

                //--------------------------------
                // payment
                //--------------------------------

                const selectedPayment =
                    document.querySelector(
                        'input[name="paymentMethod"]:checked'
                    );

                const paymentMethod =
                    selectedPayment?.value;

                //--------------------------------
                // coupon
                //--------------------------------

                const couponCode = appliedCouponCode;

                //--------------------------------
                // validation
                //--------------------------------

                if (!addressId) {

                    alert(
                        "Please select address"
                    );

                    return;
                }

                if (!paymentMethod) {

                    alert(
                        "Please choose payment method"
                    );

                    return;
                }

                showOrderLoading();

                try {

                    const response =
                        await fetch(
                            "/checkout/confirm",
                            {

                                method: "POST",

                                headers: {
                                    "Content-Type":
                                        "application/json"
                                },

                                body:
                                    JSON.stringify({

                                        addressId,

                                        paymentMethod,

                                        couponCode
                                    })
                            }
                        );

                    const result =
                        await response.json();



                    if (result.success) {

                        setTimeout(() => {
                            window.location.href =
                                `/orderConfirm/${result.orderId}`;
                        }, 2000);

                    } else {

                        hideOrderLoading();

                        alert(
                            result.message ||
                            "Failed to place order"
                        );
                    }

                } catch (error) {

                    console.log(error);
                    hideOrderLoading();

                    alert(
                        "Something went wrong"
                    );
                }
            }
        );
    </script>

</body>

</html>
