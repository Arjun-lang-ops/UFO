<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Reset Your Password - ProBaller Gear</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;family=Noto+Sans:wght@100..900&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
            },
            fontFamily: {
              display: ["Lexend", "Noto Sans", "sans-serif"],
              body: ["Lexend", "Noto Sans", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark font-display text-[#111418] dark:text-white antialiased selection:bg-primary/30"
  >
    <div class="flex min-h-screen w-full">
      <div class="hidden lg:flex w-1/2 relative bg-[#1c2127] overflow-hidden">
        <div
          class="absolute inset-0 bg-center bg-cover transition-transform duration-1000 hover:scale-105"
          style="
            background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuDDxkliawtTWdHCo8F91iMi-ao5IrQBDLESIWqMiWfamCACnsLrkBiBC1SZKmgTvylMwuuyveaP_NruFSLRtHmtOlcp_NrmQUkQnBisJeIhRtPnYKT1YhYe5FDKXEDA95Q20Gnr664_Tgsr0SNSTNNqcwVuL-lqzIG4i66FOPAw45j8wNbhebhHZwrAfkVLhW033x6eLeWOvKX-SGkagf2WpS2WAcpR2GwA7VafrtyAUxY2JgqqS9mAGMYiinXuktARQTL_hPfjtKE&quot;);
          "
        >
          <div
            class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/40 to-transparent opacity-90"
          ></div>
        </div>
        <div
          class="relative z-10 flex flex-col justify-end p-16 h-full w-full max-w-2xl mx-auto"
        >
          <div class="mb-6 flex items-center gap-2">
            <span
              class="bg-primary/20 text-primary border border-primary/30 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider backdrop-blur-sm"
              >Security Check</span
            >
          </div>
          <h2
            class="text-5xl font-bold text-white mb-6 leading-tight tracking-tight"
          >
            Stay in the Game <br /><span class="text-primary"
              >Recover Your Access.</span
            >
          </h2>
          <p class="text-lg text-gray-300 max-w-md leading-relaxed">
            Don't let a forgotten password keep you on the sidelines. Follow the
            steps to reset your credentials.
          </p>
          <div class="mt-12 flex gap-4 text-sm text-gray-400 font-medium">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-[20px]"
                >security</span
              >
              Secure Reset
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-[20px]"
                >timer</span
              >
              Instant Email
            </div>
          </div>
        </div>
      </div>
      <div
        class="w-full lg:w-1/2 flex flex-col bg-background-light dark:bg-background-dark relative h-screen overflow-y-auto"
      >
        <div
          class="w-full px-6 py-6 lg:px-12 flex justify-between items-center"
        >
          <a class="flex lg:hidden items-center gap-2 text-[#111418] dark:text-white cursor-pointer hover:opacity-80 transition-opacity" href="/">
            <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
            <h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
          </a>
          <div class="ml-auto">
            <a
              class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-1 group"
              href="#"
            >
              <span
                class="material-symbols-outlined text-[16px] -rotate-180 group-hover:-translate-x-1 transition-transform"
                >arrow_forward</span
              >
              Back to Login
            </a>
          </div>
        </div>
        <div
          class="flex-1 flex flex-col justify-center items-center px-6 lg:px-24 pb-12"
        >
          <div class="w-full max-w-[480px] flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <a
                class="hidden lg:flex items-center gap-2 text-[#111418] dark:text-white mb-6 cursor-pointer hover:opacity-80 transition-opacity" href="/"
              >
                <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
                <h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
              </a>
              <h1
                class="text-[#111418] dark:text-white tracking-tight text-[32px] font-bold leading-tight"
              >
                Reset Your Password
              </h1>
              <p
                class="text-gray-500 dark:text-[#9dabb9] text-base font-normal leading-normal"
              >
                Enter the email address associated with your account and we'll
                send you an OTP to reset your password.
              </p>
            </div>
            <form class="flex flex-col gap-5">
              <label class="flex flex-col flex-1 group">
                <p
                  class="text-[#111418] dark:text-white text-base font-medium leading-normal pb-2 group-focus-within:text-primary transition-colors"
                >
                  Email Address
                </p>
                <div class="relative">
                  <span
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors"
                  >
                    <span class="material-symbols-outlined text-[20px]"
                      >mail</span
                    >
                  </span>
                  <input
                    class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[15px] py-[15px] text-base font-normal leading-normal transition-all"
                    placeholder="captain@example.com"
                    required=""
                    type="email"
                  />
                </div>
              </label>
              <button
                class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all mt-2 active:scale-[0.99]"
                type="submit"
              >
                <span class="truncate">Send OTP</span>
              </button>
            </form>

            <div class="flex flex-col gap-4 text-center mt-2">
              <p class="text-gray-500 dark:text-[#9dabb9] text-sm">
                Remember your password?
                <a
                  class="text-primary font-bold hover:text-primary/80 transition-colors"
                  href="/login"
                  >Log In</a
                >
              </p>
            </div>
          </div>
        </div>
        <div
          class="px-6 py-8 mt-auto border-t border-gray-200 dark:border-[#1c2127]"
        >
          <div
            class="max-w-[480px] mx-auto flex justify-between items-center text-xs text-gray-500 dark:text-gray-400"
          >
            <p>© 2026 Urban Football</p>
            <div class="flex gap-4">
              <a class="hover:text-primary" href="#">Help Center</a>
              <a class="hover:text-primary" href="#">Security</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
  <script src="/js/forgotPasswordValidation.js"></script>
</html>
