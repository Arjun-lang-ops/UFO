<!DOCTYPE html>

<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Urban Football - Football Accessories</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;700;900&amp;family=Noto+Sans:wght@400;500;700&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Theme Configuration -->
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
              "surface-dark": "#1c2632", // Slightly lighter for cards
            },
            fontFamily: {
              display: ["Lexend", "sans-serif"],
              body: ["Noto Sans", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      /* Custom scrollbar hiding */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display overflow-x-hidden"
  >
    <div class="relative flex min-h-screen w-full flex-col">
      <!-- Navigation -->
      <header
        class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-md px-4 py-3 md:px-10"
      >
        <div class="flex items-center gap-4 md:gap-8">
          <div
            class="flex items-center gap-2 text-slate-900 dark:text-white cursor-pointer"
          >
            <span class="material-symbols-outlined text-primary text-3xl"
              >sports_soccer</span
            >
            <h2
              class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block"
            >
              Urban Football
            </h2>
          </div>
         
        </div>
        <div class="flex flex-1 justify-end gap-4 md:gap-8 items-center">
          <label class="hidden sm:flex flex-col min-w-40 h-10 max-w-64 flex-1">
            <div
              class="flex w-full flex-1 items-stretch rounded-lg h-full bg-slate-200 dark:bg-[#283039]"
            >
              <div
                class="text-slate-500 dark:text-[#9dabb9] flex items-center justify-center pl-4 rounded-l-lg border-r-0"
              >
                <span class="material-symbols-outlined text-[20px]"
                  >search</span
                >
              </div>
              <input
                class="flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg bg-transparent text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none h-full placeholder:text-slate-500 dark:placeholder:text-[#9dabb9] px-4 rounded-l-none border-l-0 pl-2 text-sm font-normal leading-normal"
                placeholder="Search gear..."
              />
            </div>
          </label>
          <div class="flex gap-2">
            <button
              class="sm:hidden flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors"
            >
              <span class="material-symbols-outlined">search</span>
            </button>
            <button
              class="flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors relative"
            >
              <span class="material-symbols-outlined">shopping_cart</span>
              <span
                class="absolute top-2 right-2 h-2 w-2 rounded-full bg-primary ring-2 ring-background-dark"
              ></span>
            </button>
            <a href="/profile"
              ><button
                class="flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors"
              >
                <span class="material-symbols-outlined">account_circle</span>
              </button></a
            >
          </div>
        </div>
      </header>
      <!-- Main Content -->
      <main
        class="flex flex-col w-full px-4 md:px-10 lg:px-40 py-5 gap-8 max-w-[1440px] mx-auto"
      >
        <!-- Hero Section -->
        <section class="@container">
          <div
            class="flex min-h-[480px] flex-col gap-6 bg-cover bg-center bg-no-repeat rounded-xl items-start justify-end px-6 pb-10 md:px-12 md:pb-16 shadow-2xl relative overflow-hidden group"
            data-alt="Close up action shot of soccer player kicking a ball with grass flying"
            style="
              background-image:
                linear-gradient(
                  rgba(0, 0, 0, 0) 0%,
                  rgba(0, 0, 0, 0.2) 50%,
                  rgba(0, 0, 0, 0.8) 100%
                ),
                url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuCuO_uYz-7eJzxXZn4xYYfa943wgDNQ_4WZVoP00IKxIaww_es9yBt8TMwihiP3IbRwkPLa3HG6aoZrxHeQj8-IQCY7ZF7S9jrQ1aAUEuoAnSOXNgHiG77s22jVuLeXqPEBIK_SHbtgLyLdlPhfaqFQBNT2gG18O1WNMN1B0wSYaZLeHCV3-YmvRvXzmsTeaboRhUEtjATRwJkkl9d2XA5Jg2iHTl7FbyJyPNrYlQmxIEjcii_rPESp56f4Nyn3ZT0CpyjrJYTqzSA&quot;);
            "
          >
            <div class="flex flex-col gap-2 text-left z-10 max-w-2xl">
              <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 backdrop-blur-sm border border-primary/30 w-fit mb-2"
              >
                <span
                  class="text-xs font-bold text-primary uppercase tracking-wider"
                  >New Season 2026</span
                >
              </div>
              <h1
                class="text-white text-4xl md:text-6xl font-black leading-tight tracking-[-0.033em]"
              >
                Dominate the Pitch
              </h1>
              <h2
                class="text-slate-200 text-base md:text-lg font-normal leading-relaxed max-w-lg"
              >
                Discover the elite range of 2024 boots engineered for speed,
                precision, and control.
              </h2>
            </div>
            <a href="/product">
              <button
              class="z-10 flex items-center justify-center rounded-lg h-12 px-6 bg-primary hover:bg-blue-600 text-white text-base font-bold leading-normal tracking-[0.015em] transition-all transform hover:scale-105 shadow-lg shadow-primary/30"
            >
              <span class="truncate">Shop New Arrivals</span>
            </button>
            </a>
          </div>
        </section>
        <!-- Categories -->
        
        <!-- Featured Gear Grid -->
        <section>
          <div class="flex items-center justify-between pb-4 pt-4">
            <h2 class="text-[22px] font-bold leading-tight tracking-[-0.015em]">
              Popular Right Now
            </h2>
            <div class="flex gap-2">
              <button
                class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-dark hover:bg-slate-700 transition-colors"
              >
                <span class="material-symbols-outlined text-sm"
                  >arrow_back</span
                >
              </button>
              <button 
                class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-dark hover:bg-slate-700 transition-colors"
              >
                <span class="material-symbols-outlined text-sm"
                  >arrow_forward</span
                >
              </button>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <!-- Product Card 1 -->
             <% products.forEach(product=>{
              const variant=product.variants[0]
              %>
            <div
              class="group flex flex-col gap-3 rounded-xl bg-surface-dark/50 p-3 hover:bg-surface-dark transition-all border border-transparent hover:border-slate-700/50"
            ><a href="product/<%= product._id %>">
              
              <div
                class="relative w-full aspect-[4/5] rounded-lg overflow-hidden"
              >
                <div
                  class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                  data-alt="Neon yellow soccer boots floating"
                  style="
                    background-image: url('<%= variant.images[0] %>');
                  "
                ></div>
                <div
                  class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded"
                >
                  HOT
                </div>
                <button
                  class="absolute bottom-3 right-3 h-10 w-10 bg-white dark:bg-slate-800 text-slate-900 dark:text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all shadow-lg"
                >
                  <span class="material-symbols-outlined text-[20px]"
                    >add_shopping_cart</span
                  >
                </button>
              </div>
              <div>
                <div class="flex justify-between items-start">
                  <h3 class="text-base font-bold leading-tight">
                    <%= product.name %>
                  </h3>
                            <p class="text-primary font-bold">
                      ₹<%= variant.discountedPrice || variant.price %>
                    </p>
                </div>
               
                          <p class="text-slate-500 text-sm mt-1">
                    <%= variant.color %> | <%= variant.size %>
                  </p>
              </div>
              
            </div></a>
           <% }) %>
           
        </section>
        <!-- Promo Banner -->
        <section class="w-full">
          <div
            class="relative rounded-2xl overflow-hidden bg-surface-dark min-h-[300px] flex items-center"
          >
            <div
              class="absolute inset-0 bg-cover bg-center"
              data-alt="Dark abstract pattern with blue smoke"
              style="
                background-image: url(&quot;https://lh3.googleusercontent.com/aida-public/AB6AXuB5ShMd8j2oJ03aC0cardNJHhtTJltPnmeCbAScKZrYiIyg09TxfwgqkPx2G75S8C4kqIiM4mMfzh6vo_F9w6-v8GuyFbJMiMAuF3T2rgnMfpC32ckNhJp4LjwZ4LnmgR5yGE3G8bHSnWrxTFtypaTwN4wBlnklhdhfMxJWGMDDIJo7Q_XPWT0J_TWSSYfr-aHjNrEnmrqzNGvcdxK4qOINdpUDbyuF2yaBwPdx-ihd97WY7EJQxVyHoCYMjfffWvj4Z08818WUCsI&quot;);
              "
            ></div>
            <div
              class="absolute inset-0 bg-gradient-to-r from-background-dark via-background-dark/80 to-transparent"
            ></div>
            <div
              class="relative z-10 p-8 md:p-16 max-w-2xl flex flex-col gap-6"
            >
              <h2
                class="text-3xl md:text-5xl font-black text-white leading-tight"
              >
                Training Essentials<br /><span class="text-primary"
                  >Flat 30% Off</span
                >
              </h2>
              <p class="text-slate-300 text-lg">
                Level up your game with our premium training collection. Offer
                valid until Sunday.
              </p>
              <button
                class="w-fit flex items-center justify-center rounded-lg h-12 px-8 bg-white text-background-dark hover:bg-slate-200 text-base font-bold leading-normal transition-colors"
              >
                Explore Deals
              </button>
            </div>
          </div>
        </section>
      </main>
      <!-- Footer -->
      <footer
        class="mt-auto border-t border-slate-200 dark:border-[#283039] bg-background-light dark:bg-background-dark pt-16 pb-8 px-4 md:px-10 lg:px-40"
      >
        <div class="max-w-[1440px] mx-auto flex flex-col gap-10">
          <div class="flex flex-col md:flex-row justify-between gap-10">
            <div class="flex flex-col gap-4 max-w-sm">
              <div
                class="flex items-center gap-2 text-slate-900 dark:text-white"
              >
                <span class="material-symbols-outlined text-primary text-3xl"
                  >sports_soccer</span
                >
                <h2 class="text-xl font-bold">Urban Football</h2>
              </div>
              <p class="text-slate-500 dark:text-[#9dabb9] leading-relaxed">
                The ultimate destination for football enthusiasts. Premium gear
                for every player, every position, every match.
              </p>
              <div class="flex gap-4 mt-2">
                <a class="text-slate-400 hover:text-primary" href="#"
                  ><span class="material-symbols-outlined">thumb_up</span></a
                >
                <a class="text-slate-400 hover:text-primary" href="#"
                  ><span class="material-symbols-outlined">camera_alt</span></a
                >
                <a class="text-slate-400 hover:text-primary" href="#"
                  ><span class="material-symbols-outlined"
                    >alternate_email</span
                  ></a
                >
              </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-16">
              <div class="flex flex-col gap-4">
                <h4 class="text-slate-900 dark:text-white font-bold">Shop</h4>
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >New Arrivals</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Best Sellers</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Sale</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Gift Cards</a
                >
              </div>
              <div class="flex flex-col gap-4">
                <h4 class="text-slate-900 dark:text-white font-bold">
                  Support
                </h4>
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Order Status</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Shipping &amp; Returns</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Size Guide</a
                >
                <a
                  class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm"
                  href="#"
                  >Contact Us</a
                >
              </div>
              <div class="flex flex-col gap-4 col-span-2 md:col-span-1">
                <h4 class="text-slate-900 dark:text-white font-bold">
                  Stay in the loop
                </h4>
                <div class="flex gap-2">
                  <input
                    class="bg-slate-200 dark:bg-[#1c2632] border-none rounded-lg px-4 py-2 text-sm w-full text-slate-900 dark:text-white focus:ring-1 focus:ring-primary"
                    placeholder="Enter your email"
                    type="email"
                  />
                  <button
                    class="bg-primary hover:bg-blue-600 text-white rounded-lg px-4 py-2 font-bold text-sm"
                  >
                    Join
                  </button>
                </div>
              </div>
            </div>
          </div>
          <div
            class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-slate-200 dark:border-[#283039]"
          >
            <p class="text-slate-500 dark:text-[#5a6b7c] text-sm">
              © 2026 Urban Football. All rights reserved.
            </p>
            <div class="flex gap-6">
              <a
                class="text-slate-500 dark:text-[#5a6b7c] hover:text-primary text-sm"
                href="#"
                >Privacy Policy</a
              >
              <a
                class="text-slate-500 dark:text-[#5a6b7c] hover:text-primary text-sm"
                href="#"
                >Terms of Service</a
              >
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
