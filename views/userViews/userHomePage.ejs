<!DOCTYPE html>

<html class="dark" lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Urban Football - Football Accessories</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
  <link
    href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;700;900&amp;family=Noto+Sans:wght@400;500;700&amp;display=swap"
    rel="stylesheet" />
  <!-- Material Symbols -->
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
    rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
    rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Theme Configuration -->
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#137fec",
            "background-light": "#f6f7f8",
            "background-dark": "#101922",
            "surface-dark": "#1c2632", // Slightly lighter for cards
          },
          fontFamily: {
            display: ["Lexend", "sans-serif"],
            body: ["Noto Sans", "sans-serif"],
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px",
          },
        },
      },
    };
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings:
        "FILL" 0,
        "wght" 400,
        "GRAD" 0,
        "opsz" 24;
    }

    /* Custom scrollbar hiding */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display overflow-x-hidden">
  <div class="relative flex min-h-screen w-full flex-col">
    <!-- Navigation -->
    <header
      class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-md px-4 py-3 md:px-10">
      <div class="flex items-center gap-4 md:gap-8">
        <div class="flex items-center gap-2 text-slate-900 dark:text-white cursor-pointer">
          <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
          <h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">
            Urban Football
          </h2>
        </div>

      </div>
      <div class="flex flex-1 justify-end gap-4 md:gap-8 items-center">
        <label class="hidden sm:flex flex-col min-w-40 h-10 max-w-64 flex-1">
          <form action="/home" method="GET" class="w-full h-full">
            <div class="relative flex w-full flex-1 items-stretch rounded-lg h-full bg-slate-200 dark:bg-[#283039]">

              <!-- Search Icon -->
              <div class="text-slate-500 dark:text-[#9dabb9] flex items-center justify-center pl-4 rounded-l-lg">
                <span class="material-symbols-outlined text-[20px]">
                  search
                </span>
              </div>

              <!-- Input -->
              <input id="searchInput" type="text" name="search" value="<%= query?.search || '' %>"
                placeholder="Search gear..."
                class="flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg bg-transparent text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none h-full placeholder:text-slate-500 dark:placeholder:text-[#9dabb9] px-4 rounded-l-none border-l-0 pl-2 pr-10 text-sm font-normal leading-normal" />

              <!-- Clear Button -->
              <button type="button" id="clearSearch"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 dark:text-[#9dabb9] hover:text-white hidden">
                ✕
              </button>

            </div>
          </form>
        </label>
        <div class="flex gap-2">
          <button
            class="sm:hidden flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors">
            <span class="material-symbols-outlined">search</span>
          </button>
          <a href="/cart">
            <button
              class="flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors relative">
              <span class="material-symbols-outlined">shopping_cart</span>

              <% if (cartCount> 0) { %>
                <span id="cart-count"
                  class="absolute -top-1 -right-1 bg-primary text-white text-[10px] h-4 w-4 flex items-center justify-center rounded-full">
                  <%= cartCount %>
                </span>
                <% } %>

            </button>
          </a>

          <a href="/wishlist">
            <button
              class="flex items-center justify-center rounded-lg size-10 bg-surface-dark text-white hover:bg-primary/20 hover:text-primary transition-colors">
              <span class="material-symbols-outlined text-[20px]">favorite</span>
            </button>
            <!-- Mobile Menu Toggle -->
            <button
              class="lg:hidden flex items-center justify-center rounded-lg size-10 bg-surface-dark text-white hover:bg-primary/20 hover:text-primary transition-colors">
              <span class="material-symbols-outlined text-[20px]">menu</span>
            </button>
          </a>
          <a href="/profile"><button
              class="flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors">
              <span class="material-symbols-outlined">account_circle</span>
            </button></a>
        </div>
      </div>
    </header>
    <!-- Main Content -->
    <main class="flex flex-col w-full px-4 md:px-10 lg:px-40 py-5 gap-8 max-w-[1440px] mx-auto">
      <!-- Hero Section -->
      <section class="@container">
        <div
          class="flex min-h-[480px] flex-col gap-6 bg-cover bg-center bg-no-repeat rounded-xl items-start justify-end px-6 pb-10 md:px-12 md:pb-16 shadow-2xl relative overflow-hidden group"
          data-alt="Close up action shot of soccer player kicking a ball with grass flying" style="
              background-image:
                linear-gradient(
                  rgba(0, 0, 0, 0) 0%,
                  rgba(0, 0, 0, 0.2) 50%,
                  rgba(0, 0, 0, 0.8) 100%
                ),
                url(&quot;https://images.unsplash.com/photo-1551958219-acbc608c6377?auto=format&amp;fit=crop&amp;w=2400&amp;q=95&quot;);
            ">
          <div class="flex flex-col gap-2 text-left z-10 max-w-2xl">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 backdrop-blur-sm border border-primary/30 w-fit mb-2">
              <span class="text-xs font-bold text-primary uppercase tracking-wider">New Season 2026</span>
            </div>
            <h1 class="text-white text-4xl md:text-6xl font-black leading-tight tracking-[-0.033em]">
              Dominate the Pitch
            </h1>
            <h2 class="text-slate-200 text-base md:text-lg font-normal leading-relaxed max-w-lg">
              Discover the elite range of 2024 boots engineered for speed,
              precision, and control.
            </h2>
          </div>
          <a href="/product">
            <button
              class="z-10 flex items-center justify-center rounded-lg h-12 px-6 bg-primary hover:bg-blue-600 text-white text-base font-bold leading-normal tracking-[0.015em] transition-all transform hover:scale-105 shadow-lg shadow-primary/30">
              <span class="truncate">Shop New Arrivals</span>
            </button>
          </a>
        </div>
      </section>
      <!-- Categories -->

      <!-- Featured Gear Grid -->
      <section>
        <div class="flex items-center justify-between pb-4 pt-4">
          <h2 class="text-[22px] font-bold leading-tight tracking-[-0.015em]">
            Popular Right Now
          </h2>
          <div class="flex gap-2">

          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

          <% products.forEach(product=> {
            const variant = product.variants[0];
            %>

            <div
              class="group flex flex-col gap-3 rounded-xl bg-surface-dark/50 p-3 hover:bg-surface-dark transition-all border border-transparent hover:border-slate-700/50">

              <!-- Product Link -->
              <a href="/product/<%= product._id %>">

                <div class="relative w-full aspect-[4/5] rounded-lg overflow-hidden">

                  <!-- Product Image -->
                  <div
                    class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                    style="background-image: url('<%= variant.images[0] %>');"></div>

                  <% if (product.activeOffer) { %>
                    <div
                      class="absolute top-3 left-3 bg-primary text-white text-[11px] font-bold px-2 py-1 rounded z-10 shadow-lg shadow-black/20 max-w-[85%]">
                      <span class="block truncate">
                        <%= product.activeOffer.name %>
                      </span>
                      <span class="block text-[10px] opacity-90">
                        <%= product.activeOffer.offerMode==='PERCENTAGE' ? product.activeOffer.discountValue + '% Off'
                          : 'Rs ' + product.activeOffer.discountValue + ' Off' %>
                      </span>
                    </div>
                    <% } %>

                </div>

                <!-- Product Details -->
                <div class="mt-3">

                  <div class="flex justify-between items-start">

                    <h3 class="text-base font-bold leading-tight">
                      <%= product.name %>
                    </h3>

                    <div class="flex items-center gap-2 mt-1">
                      <p class="text-primary font-bold">
                        ₹<%= variant.offerPricing ? variant.offerPricing.finalPrice : (variant.discountedPrice ||
                          variant.price) %>
                      </p>
                      <% const baseDisplayPrice=variant.offerPricing ? variant.offerPricing.finalPrice :
                        (variant.discountedPrice || variant.price); const crossedPrice=variant.offerPricing ?
                        (variant.offerPricing.basePrice> variant.offerPricing.finalPrice ?
                        variant.offerPricing.basePrice : (variant.price > variant.offerPricing.finalPrice ?
                        variant.price : null)) : (variant.price > variant.discountedPrice ? variant.price : null);
                        if (crossedPrice && crossedPrice > baseDisplayPrice) {
                        %>
                        <span class="text-slate-500 text-xs line-through">
                          ₹<%= crossedPrice %>
                        </span>
                        <% } %>
                    </div>

                  </div>

                  <p class="text-slate-500 text-sm mt-1">
                    <%= variant.color %> | <%= variant.size %>
                  </p>

                </div>

              </a>

              <div class="flex justify-end gap-2 mt-2">

                <!-- Wishlist -->
                <form class="wishlist-form">

                  <input type="hidden" name="productId" value="<%= product._id %>">

                  <input type="hidden" name="variantId" value="<%= variant._id %>">

                  <% const currentWishlistItems=typeof wishlistItems !=='undefined' ? wishlistItems : []; const
                    isWishlisted=currentWishlistItems.some(item=>
                    item.productId === product._id.toString() &&
                    item.variantId === variant._id.toString()
                    );
                    %>

                    <button type="submit"
                      class="wishlist-btn h-10 w-10 <%= isWishlisted ? 'bg-red-500 text-white' : 'bg-white dark:bg-slate-800 text-red-500' %> rounded-full flex items-center justify-center shadow-lg hover:bg-red-500 hover:text-white transition"
                      data-wishlisted="<%= isWishlisted ? 'true' : 'false' %>">
                      <span class="material-symbols-outlined text-[20px]">
                        favorite
                      </span>
                    </button>

                </form>

                <!-- Cart -->


              </div>

            </div>

            <% }) %>

        </div>

      </section>
      <!-- Promo Banner -->
      <section class="w-full">
        <div class="relative rounded-2xl overflow-hidden bg-surface-dark min-h-[300px] flex items-center">
          <div class="absolute inset-0 bg-cover bg-center" data-alt="Dark abstract pattern with blue smoke" style="
                background-image: url(&quot;https://images.unsplash.com/photo-1517466787929-bc90951d0974?auto=format&amp;fit=crop&amp;w=2200&amp;q=95&quot;);
              "></div>
          <div class="absolute inset-0 bg-gradient-to-r from-background-dark via-background-dark/80 to-transparent">
          </div>
          <div class="relative z-10 p-8 md:p-16 max-w-2xl flex flex-col gap-6">
            <h2 class="text-3xl md:text-5xl font-black text-white leading-tight">
              Training Essentials<br /><span class="text-primary">Flat 30% Off</span>
            </h2>
            <p class="text-slate-300 text-lg">
              Level up your game with our premium training collection. Offer
              valid until Sunday.
            </p>
            <button
              class="w-fit flex items-center justify-center rounded-lg h-12 px-8 bg-white text-background-dark hover:bg-slate-200 text-base font-bold leading-normal transition-colors">
              Explore Deals
            </button>
          </div>
        </div>
      </section>
    </main>
    <!-- Footer -->
    <footer
      class="mt-auto border-t border-slate-200 dark:border-[#283039] bg-background-light dark:bg-background-dark pt-16 pb-8 px-4 md:px-10 lg:px-40">
      <div class="max-w-[1440px] mx-auto flex flex-col gap-10">
        <div class="flex flex-col md:flex-row justify-between gap-10">
          <div class="flex flex-col gap-4 max-w-sm">
            <div class="flex items-center gap-2 text-slate-900 dark:text-white">
              <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
              <h2 class="text-xl font-bold">Urban Football</h2>
            </div>
            <p class="text-slate-500 dark:text-[#9dabb9] leading-relaxed">
              The ultimate destination for football enthusiasts. Premium gear
              for every player, every position, every match.
            </p>
            <div class="flex gap-4 mt-2">
              <a class="text-slate-400 hover:text-primary" href="#"><span
                  class="material-symbols-outlined">thumb_up</span></a>
              <a class="text-slate-400 hover:text-primary" href="#"><span
                  class="material-symbols-outlined">camera_alt</span></a>
              <a class="text-slate-400 hover:text-primary" href="#"><span
                  class="material-symbols-outlined">alternate_email</span></a>
            </div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-16">
            <div class="flex flex-col gap-4">
              <h4 class="text-slate-900 dark:text-white font-bold">Shop</h4>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">New Arrivals</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Best Sellers</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Sale</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Gift Cards</a>
            </div>
            <div class="flex flex-col gap-4">
              <h4 class="text-slate-900 dark:text-white font-bold">
                Support
              </h4>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Order Status</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Shipping &amp;
                Returns</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Size Guide</a>
              <a class="text-slate-500 dark:text-[#9dabb9] hover:text-primary text-sm" href="#">Contact Us</a>
            </div>

          </div>
        </div>
        <div
          class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-slate-200 dark:border-[#283039]">
          <p class="text-slate-500 dark:text-[#5a6b7c] text-sm">
            © 2026 Urban Football. All rights reserved.
          </p>
          <div class="flex gap-6">
            <a class="text-slate-500 dark:text-[#5a6b7c] hover:text-primary text-sm" href="#">Privacy Policy</a>
            <a class="text-slate-500 dark:text-[#5a6b7c] hover:text-primary text-sm" href="#">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>
  </div>
</body>
<script>
  const input = document.getElementById("searchInput");
  const clearBtn = document.getElementById("clearSearch");

  // Show/hide clear button
  function toggleClearButton() {
    if (input.value.trim() !== "") {
      clearBtn.classList.remove("hidden");
    } else {
      clearBtn.classList.add("hidden");
    }
  }

  // Initial check
  toggleClearButton();

  // Input typing
  input.addEventListener("input", toggleClearButton);

  // Clear search
  clearBtn.addEventListener("click", () => {

    input.value = "";

    // Redirect without search query
    const url = new URL(window.location.href);

    url.searchParams.delete("search");

    window.location.href = url.toString();
  });
</script>

<script>

  document.querySelectorAll('.wishlist-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const productId = form.querySelector('input[name=productId]').value;
      const variantId = form.querySelector('input[name=variantId]').value

      const button = form.querySelector(".wishlist-btn");
      const isWishlisted = button.getAttribute('data-wishlisted') === 'true';
      const endpoint = isWishlisted ? '/removeWishlist' : '/wishlist/add';

      try {

        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"

          },
          credentials: "same-origin",

          body: JSON.stringify({
            productId,
            variantId
          })
        })

        const data = await response.json();

        if (data.success) {
          if (isWishlisted) {
            button.setAttribute('data-wishlisted', 'false');
            button.classList.remove('bg-red-500', 'text-white');
            button.classList.add('bg-white', 'dark:bg-slate-800', 'text-red-500');
          } else {
            button.setAttribute('data-wishlisted', 'true');
            button.classList.add('bg-red-500', 'text-white');
            button.classList.remove('bg-white', 'dark:bg-slate-800', 'text-red-500');
          }


          Swal.fire({
            icon: 'success',
            text: data.message,
            toast: true,
            position: "top-end",
            timer: 1500,
            showConfirmButton: false
          })
        } else {
          Swal.fire({
            icon: "error",
            text: data.message
          })
        }

      } catch (error) {
        Swal.fire({
          icon: "error",
          text: 'Something went wrong'
        })
      }

    })
  })

</script>

</html>
