<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Account Login - Urban Football</title>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;family=Noto+Sans:wght@100..900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "primary": "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
            },
            fontFamily: {
              "display": ["Lexend", "Noto Sans", "sans-serif"],
              "body": ["Lexend", "Noto Sans", "sans-serif"]
            },
            borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
          },
        },
      }
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#111418] dark:text-white antialiased selection:bg-primary/30">
<!-- Main Container -->
<div class="flex min-h-screen w-full">
<!-- Left Side: Hero Image (Hidden on mobile) -->
<div class="hidden lg:flex w-1/2 relative bg-[#1c2127] overflow-hidden">
<div class="absolute inset-0 bg-center bg-cover transition-transform duration-1000 hover:scale-105" data-alt="Close up of a football player tying black cleats on green grass turf under bright stadium lights at night" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDDxkliawtTWdHCo8F91iMi-ao5IrQBDLESIWqMiWfamCACnsLrkBiBC1SZKmgTvylMwuuyveaP_NruFSLRtHmtOlcp_NrmQUkQnBisJeIhRtPnYKT1YhYe5FDKXEDA95Q20Gnr664_Tgsr0SNSTNNqcwVuL-lqzIG4i66FOPAw45j8wNbhebhHZwrAfkVLhW033x6eLeWOvKX-SGkagf2WpS2WAcpR2GwA7VafrtyAUxY2JgqqS9mAGMYiinXuktARQTL_hPfjtKE');">
<!-- Dark Overlay gradient -->
<div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/40 to-transparent opacity-90"></div>
</div>
<!-- Hero Content -->
<div class="relative z-10 flex flex-col justify-end p-16 h-full w-full max-w-2xl mx-auto">
<div class="mb-6 flex items-center gap-2">
<span class="bg-primary/20 text-primary border border-primary/30 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider backdrop-blur-sm">Match Ready</span>
</div>
<h2 class="text-5xl font-bold text-white mb-6 leading-tight tracking-tight">Dominate the Pitch <br/><span class="text-primary">Every Single Time.</span></h2>
<p class="text-lg text-gray-300 max-w-md leading-relaxed">Join thousands of professional athletes who trust ProBaller Gear for their performance needs.</p>
<div class="mt-12 flex gap-4 text-sm text-gray-400 font-medium">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-[20px]">verified</span> Premium Quality
                    </div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-[20px]">bolt</span> Fast Shipping
                    </div>
</div>
</div>
</div>
<!-- Right Side: Login Form -->
<div class="w-full lg:w-1/2 flex flex-col bg-background-light dark:bg-background-dark relative h-screen overflow-y-auto">
<!-- Navigation Header inside right panel -->
<div class="w-full px-6 py-6 lg:px-12 flex justify-between items-center">
<a class="flex lg:hidden items-center gap-2 text-[#111418] dark:text-white cursor-pointer hover:opacity-80 transition-opacity" href="/">
<span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
<h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
</a>
<div class="ml-auto">
<a class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-primary transition-colors flex items-center gap-1 group" href="#">
                        Back to Store <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
</a>
</div>
</div>
<div class="flex-1 flex flex-col justify-center items-center px-6 lg:px-24 pb-12">
<div class="w-full max-w-[480px] flex flex-col gap-8">
<!-- Title Section -->
<div class="flex flex-col gap-2">
<!-- Desktop Logo -->
<a class="hidden lg:flex items-center gap-2 text-[#111418] dark:text-white mb-6 cursor-pointer hover:opacity-80 transition-opacity" href="/">
<span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
<h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
</a>
<h1 class="text-[#111418] dark:text-white tracking-tight text-[32px] font-bold leading-tight">Welcome Back, Captain</h1>
<p class="text-gray-500 dark:text-[#9dabb9] text-base font-normal leading-normal">Get back in the game and gear up for the season.</p>
</div>
<!-- Form -->
<form class="flex flex-col gap-5">
<!-- Email -->
<label class="flex flex-col flex-1 group">
<p class="text-[#111418] dark:text-white text-base font-medium leading-normal pb-2 group-focus-within:text-primary transition-colors">Email Address</p>
<div class="relative">
<span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]">mail</span>
</span>
<input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[15px] py-[15px] text-base font-normal leading-normal transition-all" placeholder="captain@example.com" type="email" value=""/>
</div>
</label>
<!-- Password -->
<label class="flex flex-col flex-1 relative group">
<div class="flex justify-between items-center pb-2">
<p class="text-[#111418] dark:text-white text-base font-medium leading-normal group-focus-within:text-primary transition-colors">Password</p>
<a class="text-sm font-bold text-primary hover:text-primary/80 transition-colors" href="/forgotPassword">Forgot Password?</a>
</div>
<div class="relative">
<span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]">lock</span>
</span>
<input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#111418] dark:text-white focus:outline-0 focus:ring-0 border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary h-14 placeholder:text-gray-500 dark:placeholder:text-[#9dabb9] pl-[48px] pr-[48px] py-[15px] text-base font-normal leading-normal transition-all" placeholder="••••••••" type="password" value=""/>
<button class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 dark:text-[#9dabb9] hover:text-primary transition-colors cursor-pointer" type="button">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</button>
</div>
</label>
<!-- Submit -->
<button class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all mt-2 active:scale-[0.99]" type="submit">
<span class="truncate">Log In</span>
</button>
</form>
<!-- Social/Divider -->
<div class="relative flex items-center py-2">
<div class="flex-grow border-t border-gray-300 dark:border-[#3b4754]"></div>
<span class="flex-shrink-0 mx-4 text-gray-500 dark:text-[#9dabb9] text-sm font-medium">Or continue with</span>
<div class="flex-grow border-t border-gray-300 dark:border-[#3b4754]"></div>
</div>
<a href="/auth/google">
  <div class="flex gap-4">
<button class="flex flex-1 items-center justify-center gap-3 rounded-lg border border-gray-300 dark:border-[#3b4754] bg-white dark:bg-[#1c2127] h-12 px-4 hover:bg-gray-50 dark:hover:bg-[#283039] hover:border-gray-400 dark:hover:border-gray-600 transition-all">
<!-- Google SVG -->
<svg class="size-5" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.766 12.2764C23.766 11.4607 23.6999 10.6406 23.5588 9.83807H12.24V14.4591H18.7217C18.4528 15.9494 17.5885 17.2678 16.323 18.1056V21.1039H20.19C22.4608 19.0139 23.766 15.9274 23.766 12.2764Z" fill="#4285F4"></path><path d="M12.2401 24.0008C15.4766 24.0008 18.2059 22.9382 20.1945 21.1039L16.3275 18.1055C15.2517 18.8375 13.8627 19.252 12.2445 19.252C9.11388 19.252 6.45946 17.1399 5.50705 14.3003H1.5166V17.3912C3.55371 21.4434 7.7029 24.0008 12.2401 24.0008Z" fill="#34A853"></path><path d="M5.50253 14.3003C5.00236 12.8099 5.00236 11.1961 5.50253 9.70575V6.61481H1.51649C-0.18551 10.0056 -0.18551 14.0004 1.51649 17.3912L5.50253 14.3003Z" fill="#FBBC05"></path><path d="M12.2401 4.74966C13.9509 4.7232 15.6044 5.36697 16.8434 6.54867L20.2695 3.12262C18.1001 1.0855 15.2208 -0.0344664 12.2401 0.000808666C7.7029 0.000808666 3.55371 2.55822 1.5166 6.61481L5.50264 9.70575C6.45064 6.86173 9.10947 4.74966 12.2401 4.74966Z" fill="#EA4335"></path></svg>
<span class="text-[#111418] dark:text-white font-bold text-sm">Google</span>
</button>

</div>
</a>
<!-- Bottom Link -->
<div class="text-center mt-2">
<p class="text-gray-500 dark:text-[#9dabb9] text-sm">
                            New to the squad? 
                            <a class="text-primary font-bold hover:text-primary/80 transition-colors" href="/register">Create Account</a>
</p>
</div>
</div>
</div>
</div>
</div>
</body>
<script src="/js/passwordToggle.js"></script>
<script src="/js/loginValidation.js"></script>
</html>