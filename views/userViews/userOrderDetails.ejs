<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Order Details - Urban Football</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;700;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                        "surface-dark": "#1c242e",
                        "border-dark": "#283039",
                        "text-secondary": "#9dabb9"
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #101922;
        }

        ::-webkit-scrollbar-thumb {
            background: #283039;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #3e4856;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white min-h-screen flex flex-col font-display selection:bg-primary/30">
    <%
        const order = orderDetails;
        const items = order?.items || [];
        const formatDate = (date, options = {}) => date
            ? new Date(date).toLocaleDateString("en-IN", {
                day: "2-digit",
                month: "short",
                year: "numeric",
                ...options
            })
            : "";
        const formatCurrency = amount => `Rs. ${Number(amount || 0).toLocaleString("en-IN")}`;
        const currentStatus = order?.orderStatus || "Pending";
        const statusSteps = ["Pending", "Confirmed", "Shipped", "Delivered"];
        const currentStepIndex = currentStatus === "Cancelled" || currentStatus === "Returned"
            ? -1
            : statusSteps.indexOf(currentStatus);
        const progressWidth = currentStepIndex <= 0
            ? "0%"
            : currentStepIndex === 1
            ? "33%"
            : currentStepIndex === 2
            ? "66%"
            : "100%";
    %>
    <header
        class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 dark:border-border-dark px-4 lg:px-10 py-3 bg-white dark:bg-surface-dark sticky top-0 z-50">
        <div class="flex items-center gap-4 lg:gap-8">
            <div class="flex items-center gap-4 text-slate-900 dark:text-white">
                <div class="size-8 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-3xl">sports_soccer</span>
                </div>
                <h2 class="hidden md:block text-lg font-bold leading-tight tracking-[-0.015em]"> Urban Football 
                </h2>
            </div>
            <nav class="hidden md:flex items-center gap-6 lg:gap-9">
                <a class="text-sm font-medium leading-normal hover:text-primary transition-colors" href="/home">Shop</a>
                
            </nav>
        </div>
        <div class="flex flex-1 justify-end gap-4 lg:gap-8">
            <label class="hidden md:flex flex-col min-w-40 !h-10 max-w-64">
                <div class="flex w-full flex-1 items-stretch rounded-lg h-full border border-gray-200 dark:border-none">
                    <div
                        class="text-text-secondary flex border-none bg-gray-50 dark:bg-border-dark items-center justify-center pl-4 rounded-l-lg border-r-0">
                        <span class="material-symbols-outlined text-[24px]">search</span>
                    </div>
                    <input
                        class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-gray-50 dark:bg-border-dark focus:border-none h-full placeholder:text-text-secondary px-4 rounded-l-none border-l-0 pl-2 text-base font-normal leading-normal"
                        placeholder="Search products..." value="" />
                </div>
            </label>
            <div class="flex gap-2">
                <button
                    class="flex items-center justify-center rounded-lg h-10 w-10 bg-gray-50 dark:bg-border-dark text-slate-900 dark:text-white hover:bg-gray-100 dark:hover:bg-[#323b46] transition-colors">
                    <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                </button>
                <button
                    class="flex items-center justify-center rounded-lg h-10 w-10 bg-gray-50 dark:bg-border-dark text-slate-900 dark:text-white hover:bg-gray-100 dark:hover:bg-[#323b46] transition-colors">
                    <span class="material-symbols-outlined text-[20px]">notifications</span>
                </button>
                <button
                    class="flex items-center justify-center rounded-lg h-10 w-10 bg-gray-50 dark:bg-border-dark text-slate-900 dark:text-white hover:bg-gray-100 dark:hover:bg-[#323b46] transition-colors">
                    <span class="material-symbols-outlined text-[20px]">account_circle</span>
                </button>
            </div>
        </div>
    </header>
    <div class="flex-1 flex justify-center py-5 px-4 md:px-8 lg:px-12 xl:px-40">
        <div class="flex flex-col w-full max-w-[1280px] gap-8">
            <div class="flex flex-col gap-4">
                <div class="flex flex-wrap gap-2">
                    <a class="text-text-secondary text-sm font-medium hover:text-primary" href="/home">Home</a>
                    <span class="text-text-secondary text-sm font-medium">/</span>
                    <a class="text-text-secondary text-sm font-medium hover:text-primary" href="#">Account</a>
                    <span class="text-text-secondary text-sm font-medium">/</span>
                    <a class="text-text-secondary text-sm font-medium hover:text-primary" href="/orderHistory">Order History</a>
                    <span class="text-text-secondary text-sm font-medium">/</span>
                    <span class="text-slate-900 dark:text-white text-sm font-medium"><%= order.orderNumber || "Order not found" %></span>
                </div>
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                    <div class="flex flex-col gap-1">
                        <h1 class="text-3xl md:text-4xl font-black leading-tight tracking-[-0.033em]">Order
                            <%= order.orderNumber %></h1>
                        <p class="text-text-secondary text-base">Placed on <%= formatDate(order.createdAt || order.orderedAt) %> &bull; <%= items.length %> Item<%= items.length === 1 ? "" : "s" %></p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <a
  href="/invoice/<%= order._id %>/download"
  class="flex items-center gap-2 h-11 px-6 rounded-lg
         bg-white dark:bg-surface-dark
         border border-gray-200 dark:border-border-dark
         text-slate-900 dark:text-white
         text-sm font-bold"
>
    <span class="material-symbols-outlined text-lg">
        download
    </span>

    Invoice
</a>
                        <button
                            class="flex items-center gap-2 h-11 px-6 rounded-lg bg-primary text-white text-sm font-bold hover:bg-blue-600 transition-colors shadow-lg shadow-primary/20">
                            <span class="material-symbols-outlined text-lg">replay</span>
                            Buy Again
                        </button>
                    </div>
                </div>
            </div>
            <div
                class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-2xl p-6 md:p-8">
                <div class="relative">
                    <div class="absolute top-5 left-0 w-full h-1 bg-gray-200 dark:bg-border-dark rounded-full"></div>
                    <div class="absolute top-5 left-0 h-1 <%= currentStatus === 'Cancelled' || currentStatus === 'Returned' ? 'bg-red-500' : 'bg-green-500' %> rounded-full" style="width: <%= progressWidth %>"></div>
                    <div class="relative flex justify-between">
                        <% statusSteps.forEach((step, index) => { %>
                            <div class="flex flex-col items-center gap-3">
                                <div
                                    class="size-11 rounded-full <%= index <= currentStepIndex ? 'bg-green-500 text-white' : 'bg-gray-200 dark:bg-border-dark text-text-secondary' %> flex items-center justify-center ring-4 ring-white dark:ring-surface-dark">
                                    <span class="material-symbols-outlined"><%= index <= currentStepIndex ? 'check' : 'radio_button_unchecked' %></span>
                                </div>
                                <div class="text-center">
                                    <p class="text-sm font-bold"><%= step === "Pending" ? "Ordered" : step %></p>
                                    <p class="text-[10px] text-text-secondary uppercase">
                                        <%= index === 0 ? formatDate(order.createdAt || order.orderedAt, { month: "short", day: "2-digit" }) : "" %>
                                    </p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                    <% if (currentStatus === "Cancelled" || currentStatus === "Returned") { %>
                        <p class="mt-6 text-center text-sm font-bold text-red-500">Order <%= currentStatus %></p>
                    <% } %>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 flex flex-col gap-6">
                    <div
                        class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-2xl overflow-hidden">
                        <div
                            class="px-6 py-4 border-b border-gray-200 dark:border-border-dark bg-gray-50 dark:bg-white/5">
                            <h3 class="font-bold">Items in your order</h3>
                        </div>
                        <div class="divide-y divide-gray-200 dark:divide-border-dark">
                            <% items.forEach(item => { %>
                                <%
                                    const product = item.product;
                                    const selectedVariant = product?.variants?.find(variant =>
                                        String(variant._id) === String(item.variant)
                                    );
                                    const fallbackVariant = product?.variants?.[0];
                                    const itemImage = selectedVariant?.images?.[0] || fallbackVariant?.images?.[0] || "";
                                %>
                                <div class="p-6 flex gap-6">
                                    <% if (itemImage) { %>
                                        <img alt="<%= product?.name || 'Product image' %>"
                                            class="size-24 rounded-xl object-cover border border-gray-200 dark:border-border-dark bg-background-light dark:bg-background-dark"
                                            src="<%= itemImage %>" />
                                    <% } else { %>
                                        <div
                                            class="size-24 rounded-xl border border-gray-200 dark:border-border-dark bg-background-light dark:bg-background-dark flex items-center justify-center">
                                            <span class="material-symbols-outlined text-text-secondary">inventory_2</span>
                                        </div>
                                    <% } %>
                                    <div class="flex-1 flex flex-col md:flex-row justify-between gap-4">
                                        <div class="flex flex-col gap-1">
                                            <h4 class="font-bold text-lg hover:text-primary transition-colors cursor-pointer">
                                                <%= product?.name || "Product unavailable" %>
                                            </h4>
                                            <% if (selectedVariant?.color) { %>
                                                <p class="text-sm text-text-secondary">Color: <span
                                                        class="text-slate-900 dark:text-white"><%= selectedVariant.color %></span></p>
                                            <% } %>
                                            <% if (selectedVariant?.size) { %>
                                                <p class="text-sm text-text-secondary">Size: <span
                                                        class="text-slate-900 dark:text-white"><%= selectedVariant.size %></span></p>
                                            <% } %>
                                            <p class="text-sm text-text-secondary">Qty: <span
                                                    class="text-slate-900 dark:text-white"><%= item.quantity %></span></p>
                                        </div>
                                        <div class="flex flex-col md:items-end justify-between gap-3">
                                            <span class="text-lg font-bold"><%= formatCurrency(item.totalPrice || (item.price * item.quantity)) %></span>
                                            <% if (currentStatus === "Delivered") { %>
                                                <% if (item.returnRequest) { %>
                                                    <div class="flex flex-col md:items-end gap-1">
                                                        <span
                                                            class="inline-flex items-center gap-1 rounded-full bg-amber-100 dark:bg-amber-900/30 px-3 py-1 text-xs font-bold text-amber-700 dark:text-amber-300">
                                                            <span class="material-symbols-outlined text-base">assignment_return</span>
                                                            Return Requested
                                                        </span>
                                                        <% if (item.returnReason) { %>
                                                            <span class="text-xs text-text-secondary">Reason: <%= item.returnReason %></span>
                                                        <% } %>
                                                    </div>
                                                <% } else { %>
                                                    <a href="/orderReturn/<%= order._id %>"
                                                        class="text-primary text-sm font-bold hover:underline">Return Item</a>
                                                <% } %>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                            
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-8">
                    <div
                        class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-2xl p-6 flex flex-col gap-6">
                        <div>
                            <h3 class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-3">Shipping
                                Address</h3>
                            <div class="text-sm leading-relaxed">
                                <p class="font-bold"><%= order.address?.fullname %></p>
                                <p><%= order.address?.street %><%= order.address?.apartment ? `, ${order.address.apartment}` : "" %></p>
                                <p><%= order.address?.state %>, <%= order.address?.pincode %></p>
                                <p><%= order.address?.country %></p>
                                <p class="mt-2 text-text-secondary"><%= order.address?.phone %></p>
                            </div>
                        </div>
                        <div class="pt-6 border-t border-gray-100 dark:border-border-dark">
                            <h3 class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-3">Payment
                                Method</h3>
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-text-secondary"><%= order.paymentMethod === "COD" ? "payments" : "credit_card" %></span>
                                <div class="text-sm">
                                    <p class="font-bold"><%= order.paymentMethod %></p>
                                    <p class="text-text-secondary text-xs"><%= order.paymentStatus %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-2xl p-6">
                        <h3 class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-4">Order Summary
                        </h3>
                        <div class="flex flex-col gap-3">
                            <div class="flex justify-between text-sm">
                                <span class="text-text-secondary">Subtotal</span>
                                <span><%= formatCurrency(order.subTotal) %></span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-text-secondary">Shipping</span>
                                <span class="<%= Number(order.deliveryCharge || 0) === 0 ? 'text-green-500 font-medium' : '' %>">
                                    <%= Number(order.deliveryCharge || 0) === 0 ? "Free" : formatCurrency(order.deliveryCharge) %>
                                </span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-text-secondary">Discount</span>
                                <span><%= formatCurrency(order.discount) %></span>
                            </div>
                            <div class="h-px bg-gray-100 dark:bg-border-dark my-2"></div>
                            <div class="flex justify-between items-center">
                                <span class="font-bold text-lg">Total</span>
                                <span class="font-black text-xl text-primary"><%= formatCurrency(order.totalAmount) %></span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-text-secondary text-xl">help</span>
                        <a class="text-sm font-bold text-text-secondary hover:text-primary transition-colors"
                            href="#">Need help with this order?</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="mt-12 border-t border-gray-200 dark:border-border-dark bg-white dark:bg-surface-dark py-10">
        <div
            class="max-w-[1280px] mx-auto px-4 md:px-8 lg:px-12 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2 text-text-secondary">
                <span class="material-symbols-outlined">sports_soccer</span>
                <p class="text-sm">© 2023 Football Accessories Co. All rights reserved.</p>
            </div>
            <div class="flex gap-8">
                <a class="text-sm text-text-secondary hover:text-primary transition-colors" href="#">Privacy Policy</a>
                <a class="text-sm text-text-secondary hover:text-primary transition-colors" href="#">Terms of
                    Service</a>
                <a class="text-sm text-text-secondary hover:text-primary transition-colors" href="#">Cookies</a>
            </div>
        </div>
    </footer>

</body>

</html>
