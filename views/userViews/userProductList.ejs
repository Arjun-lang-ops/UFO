  <script>
const input = document.getElementById("searchInput");
const clearBtn = document.getElementById("clearSearch");

// Show/hide logic
function toggleClear() {
  if (input.value.trim() !== "" && document.activeElement === input) {
    clearBtn.classList.remove("hidden");
  } else {
    clearBtn.classList.add("hidden");
  }
}

input.addEventListener("focus", toggleClear);
input.addEventListener("input", toggleClear);
input.addEventListener("blur", () => {
  setTimeout(toggleClear, 150);
});

// Clear action
clearBtn.addEventListener("click", () => {
  input.value = "";
  input.focus();

  const url = new URL(window.location.href);
  url.searchParams.delete("search");
  url.searchParams.set("page", 1);

  window.location.href = url.toString();
});
</script>
<script>
document.querySelectorAll(".quick-add-btn").forEach(button => {

  button.addEventListener("click", async () => {

    const productId = button.dataset.productId;
    const variantId = button.dataset.variantId;

    try {

      const response = await fetch("/cart/add", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          productId,
          variantId,
          quantity: 1
        })
      });

      const data = await response.json();

      if (data.success) {
        Swal.fire({
  icon: "success",
  title: "Added to Cart",
  text: "Product added successfully",
  toast: true,
  position: "top-end",
  showConfirmButton: false,
  timer: 1500,
  background: "#1c2127",
  color: "#fff"
});

        const cartCount = document.getElementById("cart-count");

        if (cartCount) {

          cartCount.textContent = data.cartCount;

        } else {

          const badge = document.createElement("span");

          badge.id = "cart-count";

          badge.className =
            "absolute -top-1 -right-1 bg-primary text-white text-[10px] h-4 w-4 flex items-center justify-center rounded-full";

          badge.textContent = data.cartCount;

          document
            .querySelector('a[href="/cart"] button')
            .appendChild(badge);
        }

        button.textContent = "Added";
        button.disabled = true;

        setTimeout(() => {
          button.textContent = "Quick Add";
          button.disabled = false;
        }, 1500);

      } else {

        Swal.fire({
  icon: "error",
  title: "Oops...",
  text: data.message || "Failed to add to cart",
  background: "#1c2127",
  color: "#fff",
  confirmButtonColor: "#137fec"
});

      }

    } catch (error) {

      console.log(error);
      Swal.fire({
  icon: "error",
  title: "Error",
  text: "Something went wrong",
  background: "#1c2127",
  color: "#fff",
  confirmButtonColor: "#137fec"
});

    }

  });

});
</script>


<script>

document.querySelectorAll(".wishlist-form").forEach(form => {

  form.addEventListener("submit", async (e) => {

    e.preventDefault();

    const button = form.querySelector(".wishlist-btn");

    const productId = button.dataset.productId;
    const variantId = button.dataset.variantId;
    const isWishlisted = button.getAttribute("data-wishlisted") === "true";
    const endpoint = isWishlisted ? "/removeWishlist" : "/wishlist/add";

    try {

      const response = await fetch(endpoint, {

        method: "POST",

        headers: {
          "Content-Type": "application/json"
        },
        credentials:'same-origin',

        body: JSON.stringify({
          productId,
          variantId
        })

      });

      const data = await response.json();

      if (data.success) {

        if (isWishlisted) {
          button.setAttribute("data-wishlisted", "false");
          button.classList.remove("bg-red-500");
          button.classList.add("bg-black/50");
        } else {
          button.setAttribute("data-wishlisted", "true");
          button.classList.add("bg-red-500");
          button.classList.remove("bg-black/50");
        }

        Swal.fire({
          icon: "success",
          text: data.message,
          toast:true,
          position: "top-end",
          timer: 1500,
          showConfirmButton: false
        });

      } else {

        Swal.fire({
          icon: "error",
          text: data.message
        });

      }

    } catch (error) {

      console.log(error);

      Swal.fire({
        icon: "error",
        text: "Something went wrong"
      });

