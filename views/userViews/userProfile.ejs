<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>My Account - Urban Football</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#137fec",
              "background-light": "#f6f7f8",
              "background-dark": "#101922",
            },
            fontFamily: {
              display: ["Lexend", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
          },
        },
      };
    </script>
    <style>
      .dark ::-webkit-scrollbar {
        width: 8px;
      }
      .dark ::-webkit-scrollbar-track {
        background: #101922;
      }
      .dark ::-webkit-scrollbar-thumb {
        background: #283039;
        border-radius: 4px;
      }
      .dark ::-webkit-scrollbar-thumb:hover {
        background: #374151;
      }
    </style>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white"
  >
    <div
      class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden"
    >
      <header
        class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-white dark:bg-[#111418] px-4 py-3 lg:px-10 sticky top-0 z-50"
      >
        <div class="flex items-center gap-8">
          <div class="flex items-center gap-4 text-slate-900 dark:text-white">
            <div class="size-8 text-primary">
              <svg
                class="w-full h-full"
                fill="none"
                viewBox="0 0 48 48"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  clip-rule="evenodd"
                  d="M24 4C12.9543 4 4 12.9543 4 24C4 35.0457 12.9543 44 24 44C35.0457 44 44 35.0457 44 24C44 12.9543 35.0457 4 24 4ZM24 40C15.1634 40 8 32.8366 8 24C8 15.1634 15.1634 8 24 8C32.8366 8 40 15.1634 40 24C40 32.8366 32.8366 40 24 40Z"
                  fill="currentColor"
                ></path>
                <path d="M24 14L16 28H32L24 14Z" fill="currentColor"></path>
              </svg>
            </div>
            <a href="/home">
              <h2
              class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-[-0.015em]"
            >
              Urban Football
            </h2>
            </a>
          </div>
          <div class="hidden lg:flex items-center gap-9">
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="/home"
              >Shop</a
            >
            
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Sale</a
            >
            <a
              class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
              href="#"
              >Support</a
            >
          </div>
        </div>
        <div class="flex flex-1 justify-end gap-4 sm:gap-8">
          <div class="hidden sm:flex flex-col min-w-40 !h-10 max-w-64">
            <div
              class="flex w-full flex-1 items-stretch rounded-lg h-full border border-slate-200 dark:border-none"
            >
              <div
                class="text-slate-400 dark:text-[#9dabb9] flex bg-white dark:bg-[#283039] items-center justify-center pl-4 rounded-l-lg border-r-0"
              >
                <span class="material-symbols-outlined text-[20px]"
                  >search</span
                >
              </div>
              <input
                class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-white dark:bg-[#283039] focus:border-none h-full placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] px-4 rounded-l-none border-l-0 pl-2 text-sm font-normal leading-normal"
                placeholder="Search gear..."
                value=""
              />
            </div>
          </div>
          <div class="flex gap-2">
            <a href="/cart">
  <button
    class="flex items-center justify-center rounded-lg h-10 w-10 hover:bg-slate-200 dark:hover:bg-[#283039] transition-colors relative"
  >
    <span class="material-symbols-outlined">shopping_cart</span>

    <% if (cartCount > 0) { %>
      <span
        id="cart-count"
        class="absolute -top-1 -right-1 bg-primary text-white text-[10px] h-4 w-4 flex items-center justify-center rounded-full">
        <%= cartCount %>
      </span>
    <% } %>

  </button>
</a>
            <button
              class="flex items-center justify-center overflow-hidden rounded-lg size-10 bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-[#3e4a56] transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]"
                >notifications</span
              >
            </button>
            
          </div>
        </div>
      </header>
      <main
        class="layout-container flex h-full grow flex-col py-5 px-4 sm:px-6 lg:px-40"
      >
        <div class="flex flex-1 justify-center">
          <div
            class="layout-content-container flex flex-col max-w-[1200px] flex-1 w-full"
          >
            <h1
              class="text-slate-900 dark:text-white tracking-tight text-[32px] font-bold leading-tight pb-6 pt-2"
            >
              My Account
            </h1>
            <div class="flex flex-col lg:flex-row gap-6">
              <aside class="w-full lg:w-[280px] shrink-0">
                <div
                  class="flex flex-col gap-4 bg-white dark:bg-[#111418] p-4 rounded-xl border border-slate-200 dark:border-[#283039] h-full shadow-sm"
                >
                  <div
                    class="flex gap-3 items-center pb-4 border-b border-slate-100 dark:border-[#283039]"
                  >
                    
                    <div class="flex flex-col">
                      <h2
                        id="sidebar-fullname"
                        class="text-slate-900 dark:text-white text-base font-bold leading-normal"
                      >
                        Loading...
                      </h2>
                      <div class="flex items-center gap-1">
                        <span
                          class="material-symbols-outlined text-primary text-[14px]"
                          >verified</span
                        >
                        <p
                          class="text-slate-500 dark:text-[#9dabb9] text-xs font-medium leading-normal"
                        >
                          Pro Member
                        </p>
                      </div>
                    </div>
                  </div>
                  <nav class="flex flex-col gap-1">
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary dark:bg-primary dark:text-white transition-colors"
                      href="#"
                    >
                      <span class="material-symbols-outlined text-[20px] fill-1"
                        >person</span
                      >
                      <span class="text-sm font-semibold leading-normal"
                        >Personal Info</span
                      >
                    </a>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white transition-colors group"
                      href="#"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-primary transition-colors"
                        >package_2</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >My Orders</span
                      >
                      <span
                        class="ml-auto bg-slate-100 dark:bg-[#283039] text-slate-600 dark:text-white text-[10px] font-bold px-2 py-0.5 rounded-full"
                        >3</span
                      >
                    </a>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white transition-colors group"
                      href="/profile/address"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-primary transition-colors"
                        >location_on</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >Addresses</span
                      >
                    </a>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white transition-colors group"
                      href="#"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-primary transition-colors"
                        >credit_card</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >Wallet</span
                      >
                    </a>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white transition-colors group"
                      href="#"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-primary transition-colors"
                        >favorite</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >Wishlist</span
                      >
                    </a>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-slate-50 dark:hover:bg-[#283039] hover:text-slate-900 dark:hover:text-white transition-colors group"
                      href="#"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-primary transition-colors"
                        >celebration</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >Refer and Earn</span
                      >
                    </a>
                    <div class="h-px bg-slate-100 dark:bg-[#283039] my-1"></div>
                    <a
                      class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-[#9dabb9] hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-600 dark:hover:text-red-400 transition-colors group"
                      href="/logout"
                    >
                      <span
                        class="material-symbols-outlined text-[20px] group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors"
                        >logout</span
                      >
                      <span class="text-sm font-medium leading-normal"
                        >Sign Out</span
                      >
                    </a>
                  </nav>
                </div>
              </aside>
              <div class="flex-1 flex flex-col gap-6">
                <section
                  class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm p-6 relative overflow-hidden"
                >
                  <div
                    class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -mr-16 -mt-16 pointer-events-none"
                  ></div>
                  <div
                    class="flex flex-col sm:flex-row gap-6 items-start sm:items-center relative z-10"
                  >
                    <div class="relative group cursor-pointer">
                      <!-- Profile Image Upload -->
<div class="relative group cursor-pointer">

  <!-- Hidden file input -->
  <input
    type="file"
    id="profileImageInput"
    accept="image/*"
    class="hidden"
    onchange="uploadProfileImage(event)"
  />

  <!-- Profile Image -->
  <div
    onclick="document.getElementById('profileImageInput').click()"
    id="profileImagePreview"
    class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-24 border-4 border-slate-50 dark:border-[#1e293b] shadow-md"
    style="background-image: url('<%= user.profileImage?.url || "/uploads/profile/default.png" %>');"
  ></div>

  <!-- Edit Icon -->
  <div
    onclick="document.getElementById('profileImageInput').click()"
    class="absolute bottom-0 right-0 bg-primary text-white rounded-full p-1.5 border-2 border-white dark:border-[#111418] shadow-sm group-hover:bg-blue-600 transition-colors"
  >
    <span class="material-symbols-outlined text-[16px] block">
      photo_camera
    </span>
  </div>

</div>
                      <div
                        class="absolute bottom-0 right-0 bg-primary text-white rounded-full p-1.5 border-2 border-white dark:border-[#111418] shadow-sm group-hover:bg-blue-600 transition-colors"
                      >
                        <span
                          class="material-symbols-outlined text-[16px] block"
                          >edit</span
                        >
                      </div>
                    </div>
                    <div class="flex flex-col gap-1 flex-1">
                      <div class="flex items-center gap-3">
                        <h2
                          id="header-fullname"
                          class="text-slate-900 dark:text-white text-2xl font-bold"
                        >
                          Loading...
                        </h2>
                        
                      </div>
                      
                      <div class="flex gap-4 mt-2">
                        <div class="flex flex-col">
                          <span
                            class="text-slate-900 dark:text-white font-bold text-lg"
                            >12</span
                          >
                          <span
                            class="text-slate-500 dark:text-[#9dabb9] text-xs"
                            >Total Orders</span
                          >
                        </div>
                        <div
                          class="w-px h-8 bg-slate-200 dark:bg-[#283039]"
                        ></div>
                        <div class="flex flex-col">
                          <span
                            class="text-slate-900 dark:text-white font-bold text-lg"
                            >5</span
                          >
                          <span
                            class="text-slate-500 dark:text-[#9dabb9] text-xs"
                            >Wishlist</span
                          >
                        </div>
                      </div>
                    </div>
                    
                  </div>
                </section>
                <section
                  class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm"
                >
                  <div
                    class="px-6 py-4 border-b border-slate-100 dark:border-[#283039] flex justify-between items-center"
                  >
                    <h3
                      class="text-slate-900 dark:text-white text-lg font-bold"
                    >
                      Personal Details
                    </h3>
                  </div>
                  <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="flex flex-col gap-1.5 md:col-span-2">
                        <label
                          class="text-slate-600 dark:text-[#9dabb9] text-sm font-medium"
                          >Full Name</label
                        >
                        <input
                          id="full-name"
                          class="bg-slate-50 dark:bg-[#1e293b] border border-slate-200 dark:border-[#283039] text-slate-900 dark:text-white rounded-lg px-4 py-2.5 outline-none cursor-default"
                          type="text"
                          readonly
                          value=""
                        />
                      </div>
                      <div class="flex flex-col gap-1.5 md:col-span-2">
                        <div class="flex justify-between items-center">
                          <label
                            class="text-slate-600 dark:text-[#9dabb9] text-sm font-medium"
                            >Email Address</label
                          >
                          <button
                            onclick="openEmailModal()"
                            class="text-primary hover:text-blue-400 text-xs font-medium flex items-center gap-1 transition-colors"
                          >
                            <span class="material-symbols-outlined text-[14px]"
                              >edit</span
                            >
                            Edit
                          </button>
                        </div>
                        <div class="relative">
                          <input
                            id="user-email"
                            class="w-full bg-slate-50 dark:bg-[#1e293b] border border-slate-200 dark:border-[#283039] text-slate-900 dark:text-white rounded-lg pl-4 pr-10 py-2.5 outline-none cursor-default"
                            type="email"
                            readonly
                            value=""
                          />
                          <span
                            class="absolute right-3 top-2.5 material-symbols-outlined text-green-500 text-[20px]"
                            title="Verified"
                            >check_circle</span
                          >
                        </div>
                      </div>
                    </div>
                  </div>
                </section>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <section class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm flex flex-col">
  
  <div class="px-6 py-4 border-b border-slate-100 dark:border-[#283039] flex justify-between items-center">
    <h3 class="text-slate-900 dark:text-white text-lg font-bold">
      Default Address
    </h3>
    <a href="/profile/address">
      <button class="text-primary hover:text-blue-400 text-sm font-medium">
        Manage
      </button>
    </a>
  </div>

  <div class="p-6 flex-1 flex flex-col justify-between">

    <% if (defaultAddress) { %>

      <div class="flex gap-4 items-start">
        <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-[#283039] flex items-center justify-center shrink-0 text-slate-500 dark:text-[#9dabb9]">
          <span class="material-symbols-outlined">home</span>
        </div>

        <div>
          <p class="text-slate-900 dark:text-white font-medium">
            <%= defaultAddress.fullname %>
          </p>

          <p class="text-slate-500 dark:text-[#9dabb9] text-sm mt-1 leading-relaxed">
            <%= defaultAddress.street %>, <%= defaultAddress.apartment %> <br />
            <%= defaultAddress.state %> - <%= defaultAddress.pincode %> <br />
            <%= defaultAddress.country %>
          </p>

          <p class="text-slate-500 dark:text-[#9dabb9] text-sm mt-2">
            📞 <%= defaultAddress.phone %>
          </p>
        </div>
      </div>

    <% } else { %>

      <div class="text-center text-slate-500 text-sm">
        No default address found
      </div>

    <% } %>

  </div>
</section>
                  <section
                    class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm flex flex-col"
                  >
                    <div
                      class="px-6 py-4 border-b border-slate-100 dark:border-[#283039]"
                    >
                      <h3
                        class="text-slate-900 dark:text-white text-lg font-bold"
                      >
                        Security
                      </h3>
                    </div>
                    <div class="p-6 flex flex-col gap-4">
                      <div
                        class="flex justify-between items-center pb-4 border-b border-slate-100 dark:border-[#283039]"
                      >
                        <div>
                          <p class="text-slate-900 dark:text-white font-medium">
                            Password
                          </p>
                          
                        </div>
                        <a href="/profile/changePassword"
                          ><button
                            class="px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[#283039] text-slate-700 dark:text-white text-sm font-medium hover:bg-slate-50 dark:hover:bg-[#283039] transition-colors"
                          >
                            Change
                          </button></a
                        >
                      </div>
                      <div class="flex justify-between items-center">
                        <div>
                          <p class="text-slate-900 dark:text-white font-medium">
                            Secure your password
                          </p>
                          <p class="text-slate-500 dark:text-[#9dabb9] text-xs">
                            Extra security
                          </p>
                        </div>
                        
                      </div>
                    </div>
                  </section>
                </div>
                
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- ==================== EDIT EMAIL MODAL ==================== -->
    <div
      id="email-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center p-4"
    >
      <!-- Backdrop -->
      <div
        class="absolute inset-0 bg-black/60 backdrop-blur-sm"
        onclick="closeEmailModal()"
      ></div>
      <!-- Panel -->
      <div
        class="relative z-10 w-full max-w-md bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-2xl flex flex-col"
      >
        <div
          class="px-6 py-4 border-b border-slate-100 dark:border-[#283039] flex items-center justify-between"
        >
          <h3 class="text-slate-900 dark:text-white font-bold text-lg">
            Edit Email Address
          </h3>
          <button
            onclick="closeEmailModal()"
            class="text-slate-400 hover:text-slate-700 dark:hover:text-white transition-colors"
          >
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <form
          id="email-form"
          class="p-6 flex flex-col gap-5"
          onsubmit="handleEmailSubmit(event)"
        >
          <label class="flex flex-col gap-1.5">
            <span class="text-slate-700 dark:text-[#9dabb9] text-sm font-medium"
              >New Email Address <span class="text-red-500">*</span></span
            >
            <input
              type="email"
              id="edit-email-input"
              required
              placeholder="e.g. yourname@example.com"
              class="w-full h-11 rounded-lg border border-slate-200 dark:border-[#3b4754] bg-slate-50 dark:bg-[#1e293b] px-4 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-[#64748b] focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
            />
          </label>
          <p id="email-error" class="hidden text-red-500 text-sm"></p>
          <div class="flex flex-col-reverse sm:flex-row gap-3 pt-2">
            <button
              type="button"
              onclick="closeEmailModal()"
              class="flex-1 h-11 rounded-lg border border-slate-200 dark:border-[#3b4754] bg-transparent hover:bg-slate-50 dark:hover:bg-[#283039] text-slate-700 dark:text-white text-sm font-semibold transition-all"
            >
              Cancel
            </button>
            <button
              type="submit"
              id="email-submit-btn"
              class="flex-1 h-11 rounded-lg bg-primary hover:bg-blue-600 text-white text-sm font-semibold shadow shadow-blue-500/30 transition-all flex items-center justify-center gap-2"
            >
              Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>

    
  </body>
  <script src="/js/profileValidation.js"></script>
  </html>