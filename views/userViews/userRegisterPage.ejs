<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>New Account Registration - Urban Football</title>
<link rel="stylesheet" href="/css/register.css">

<!-- Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Theme Configuration -->
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased min-h-screen flex flex-col">
<!-- Header / TopNavBar -->
<header class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-white dark:bg-[#111418] px-4 md:px-10 py-3 shadow-sm">
<div class="flex items-center gap-4 text-slate-900 dark:text-white cursor-pointer">
<div class="size-8 text-primary">
<svg class="w-full h-full" fill="none" viewbox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
<path d="M39.5563 34.1455V13.8546C39.5563 15.708 36.8773 17.3437 32.7927 18.3189C30.2914 18.916 27.263 19.2655 24 19.2655C20.737 19.2655 17.7086 18.916 15.2073 18.3189C11.1227 17.3437 8.44365 15.708 8.44365 13.8546V34.1455C8.44365 35.9988 11.1227 37.6346 15.2073 38.6098C17.7086 39.2069 20.737 39.5564 24 39.5564C27.263 39.5564 30.2914 39.2069 32.7927 38.6098C36.8773 37.6346 39.5563 35.9988 39.5563 34.1455Z" fill="currentColor"></path>
<path clip-rule="evenodd" d="M10.4485 13.8519C10.4749 13.9271 10.6203 14.246 11.379 14.7361C12.298 15.3298 13.7492 15.9145 15.6717 16.3735C18.0007 16.9296 20.8712 17.2655 24 17.2655C27.1288 17.2655 29.9993 16.9296 32.3283 16.3735C34.2508 15.9145 35.702 15.3298 36.621 14.7361C37.3796 14.246 37.5251 13.9271 37.5515 13.8519C37.5287 13.7876 37.4333 13.5973 37.0635 13.2931C36.5266 12.8516 35.6288 12.3647 34.343 11.9175C31.79 11.0295 28.1333 10.4437 24 10.4437C19.8667 10.4437 16.2099 11.0295 13.657 11.9175C12.3712 12.3647 11.4734 12.8516 10.9365 13.2931C10.5667 13.5973 10.4713 13.7876 10.4485 13.8519ZM37.5563 18.7877C36.3176 19.3925 34.8502 19.8839 33.2571 20.2642C30.5836 20.9025 27.3973 21.2655 24 21.2655C20.6027 21.2655 17.4164 20.9025 14.7429 20.2642C13.1498 19.8839 11.6824 19.3925 10.4436 18.7877V34.1275C10.4515 34.1545 10.5427 34.4867 11.379 35.027C12.298 35.6207 13.7492 36.2054 15.6717 36.6644C18.0007 37.2205 20.8712 37.5564 24 37.5564C27.1288 37.5564 29.9993 37.2205 32.3283 36.6644C34.2508 36.2054 35.702 35.6207 36.621 35.027C37.4573 34.4867 37.5485 34.1546 37.5563 34.1275V18.7877ZM41.5563 13.8546V34.1455C41.5563 36.1078 40.158 37.5042 38.7915 38.3869C37.3498 39.3182 35.4192 40.0389 33.2571 40.5551C30.5836 41.1934 27.3973 41.5564 24 41.5564C20.6027 41.5564 17.4164 41.1934 14.7429 40.5551C12.5808 40.0389 10.6502 39.3182 9.20848 38.3869C7.84205 37.5042 6.44365 36.1078 6.44365 34.1455L6.44365 13.8546C6.44365 12.2684 7.37223 11.0454 8.39581 10.2036C9.43325 9.3505 10.8137 8.67141 12.343 8.13948C15.4203 7.06909 19.5418 6.44366 24 6.44366C28.4582 6.44366 32.5797 7.06909 35.657 8.13948C37.1863 8.67141 38.5667 9.3505 39.6042 10.2036C40.6278 11.0454 41.5563 12.2684 41.5563 13.8546Z" fill="currentColor" fill-rule="evenodd"></path>
</svg>
</div>
<h2 class="text-lg font-bold leading-tight tracking-[-0.015em]">Urban Football</h2>
</div>
<div class="hidden md:flex flex-1 justify-end gap-8">
<div class="flex items-center gap-9">
<a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors" href="#">Shop</a>
<a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors" href="#">Brands</a>
<a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors" href="#">Sale</a>
</div>
<div class="flex gap-2">
<a href="/login">
    <button class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary hover:bg-blue-600 transition-colors text-white text-sm font-bold leading-normal tracking-[0.015em]">
<span class="truncate">LogIn</span>
</button>
</a>
</div>
</div>
<div class="md:hidden">
<span class="material-symbols-outlined cursor-pointer text-slate-900 dark:text-white">menu</span>
</div>
</header>
<!-- Main Content -->
<main class="flex-grow flex items-center justify-center relative p-4 py-12 md:py-16">
<!-- Background Image Container -->
<div class="absolute inset-0 z-0 overflow-hidden">
<div class="absolute inset-0 bg-gradient-to-br from-black/80 via-black/60 to-background-dark/90 z-10"></div>
<!-- Background Image -->
<div class="w-full h-full bg-cover bg-center bg-no-repeat blur-[2px] opacity-60" data-alt="Blurred dark football stadium at night" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAQPk5_OhqJalti4ncqzWctUFh8ERBbRosSS58Yu2StS9EvU4BrqaBwMsILTv6KBqeMYPzPzYT9SVNUm0DJmuCKuTeA10Rp-LKduAUZjYE_121Fsd3W6UWrFVbfSHsVtkZruKvNy5YNzvWGd55gu1pk95dIBoGn_KOCKxStXUEIRlsORPRF8y5pZa0XOZoJ6wCxj1xTBp7Y2bjKAcEzKjK_ZjbgfD9qxRsH5SR1xg3W74zO5C_j6WZsrm838W3P_qiibWZGVnWZLdA');">
</div>
</div>
<!-- Registration Card -->
<div class="relative z-20 w-full max-w-[420px] bg-[#111418]/90 dark:bg-[#1c2127]/95 backdrop-blur-md rounded-2xl shadow-2xl border border-[#283039] overflow-hidden flex flex-col">
<!-- Card Header -->
<div class="px-6 pt-10 pb-2 flex flex-col items-center text-center">
<div class="size-12 bg-primary/20 rounded-full flex items-center justify-center text-primary mb-4">
<span class="material-symbols-outlined text-[28px]">sports_soccer</span>
</div>
<h1 class="text-slate-900 dark:text-white tracking-tight text-[32px] font-bold leading-tight px-4 pb-2">Join the Squad</h1>
<p class="text-slate-500 dark:text-[#9dabb9] text-base font-normal leading-normal px-4 max-w-sm">Create an account to get exclusive access to new drops.</p>
</div>
<!-- Form -->
<form id="registerForm" class="px-8 py-8 flex flex-col gap-5" method="post" action="register">

<!-- Full Name -->
<div class="flex flex-col gap-2">
<!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Full Name</label> -->
<div class="relative">
<input class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all" placeholder="Enter your full name" type="text" id="fullname" name="fullname"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] text-[20px]">person</span>
</div>
 <p id="nameError" class="text-red-500 text-xs hidden"></p>
</div>
<!-- Email -->
<div class="flex flex-col gap-2">
<!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Email Address</label> -->
<div class="relative">
<input class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all" placeholder="Enter your email" type="email" id="email" name="email"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] text-[20px]">mail</span>
</div>
 <p id="emailError" class="text-red-500 text-xs hidden"></p>
</div>
<!-- Password -->
<div class="flex flex-col gap-2">
<!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Password</label> -->
<div class="relative">
<input class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 pr-12 text-base font-normal leading-normal transition-all" placeholder="Create a password" type="password" id="password" name="password"/>
<button type="button" class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] hover:text-primary transition-colors focus:outline-none">
<span class="material-symbols-outlined text-[20px] block">visibility</span>
</button>
</div>
 <p id="passwordError" class="text-red-500 text-xs hidden"></p>
</div>
<!-- Confirm Password -->
                    <div class="flex flex-col gap-2">
                        <!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Confirm Password</label> -->
                        <div class="relative">
                            <input class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all" placeholder="Confirm your password" type="password" id="confirmPassword" name="confirmPassword"/>
                            <button type="button"
  class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] hover:text-primary transition-colors">
  <span class="material-symbols-outlined text-[20px]">
    visibility
  </span>
</button>

                        </div>
                        <p id="confirmPasswordError" class="text-red-500 text-xs hidden"></p>
                    </div>

                    <!-- General Error Message Container -->
                    <div id="generalError" class="text-red-500 text-sm text-center hidden mt-2"></div>
<!-- Terms -->
<div class="flex items-start gap-3 mt-2">
<input class="mt-1 size-4 rounded border-slate-300 dark:border-[#3b4754] text-primary focus:ring-primary dark:bg-[#1c2127]" type="checkbox"/>
<p class="text-sm text-slate-500 dark:text-[#9dabb9] leading-tight">
                        I agree to the <a class="text-primary hover:underline" href="#">Terms of Service</a> and <a class="text-primary hover:underline" href="#">Privacy Policy</a>.
                    </p>
</div>
<!-- Register Button -->
<button class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-4 bg-primary hover:bg-blue-600 transition-colors text-white text-base font-bold leading-normal tracking-[0.015em] mt-2 shadow-lg shadow-primary/30">
                    Create Account
                </button>
<div id="generalMessage" class="hidden"></div>

<!-- Footer -->
<div class="flex justify-center items-center gap-2 mt-2">
<p class="text-slate-500 dark:text-[#9dabb9] text-sm">Already a member?</p>
<a class="text-primary font-bold text-sm hover:underline" href="/login">Log In</a>
</div>
</form>
<!-- Social Proof / Footer Strip -->
<div class="bg-slate-50 dark:bg-[#181d23] border-t border-slate-200 dark:border-[#283039] p-4 flex justify-center items-center gap-6 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
<span class="material-symbols-outlined text-2xl" title="Secure">verified_user</span>
<span class="material-symbols-outlined text-2xl" title="Fast Shipping">local_shipping</span>
<span class="material-symbols-outlined text-2xl" title="Support">support_agent</span>
</div>
</div>
</main>
</body>
<script src="/js/registerValidation.js"></script>
<script src="/js/passwordToggle.js"></script>
</html>
