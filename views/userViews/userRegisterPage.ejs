<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>New Account Registration - Urban Football</title>
    <link rel="stylesheet" href="/css/register.css">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <!-- Material Symbols -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
        
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Theme Configuration -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
</head>

<body
    class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased min-h-screen flex flex-col">
    <!-- Header / TopNavBar -->
    <header
        class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-white dark:bg-[#111418] px-4 md:px-10 py-3 shadow-sm">
        <a class="flex items-center gap-2 text-slate-900 dark:text-white cursor-pointer hover:opacity-80 transition-opacity" href="/">
            <span class="material-symbols-outlined text-primary text-3xl">sports_soccer</span>
            <h2 class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block">Urban Football</h2>
        </a>
        <div class="hidden md:flex flex-1 justify-end gap-8">
            <div class="flex items-center gap-9">
                <a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors"
                    href="#">Shop</a>
                <a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors"
                    href="#">Brands</a>
                <a class="text-slate-900 dark:text-white text-sm font-medium leading-normal hover:text-primary transition-colors"
                    href="#">Sale</a>
            </div>
            <div class="flex gap-2">
                <a href="/login">
                    <button
                        class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary hover:bg-blue-600 transition-colors text-white text-sm font-bold leading-normal tracking-[0.015em]">
                        <span class="truncate">LogIn</span>
                    </button>
                </a>
            </div>
        </div>
        <div class="md:hidden">
            <span class="material-symbols-outlined cursor-pointer text-slate-900 dark:text-white">menu</span>
        </div>
    </header>
    <!-- Main Content -->
    <main class="flex-grow flex items-center justify-center relative p-4 py-12 md:py-16">
        <!-- Background Image Container -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-black/80 via-black/60 to-background-dark/90 z-10"></div>
            <!-- Background Image -->
            <div class="w-full h-full bg-cover bg-center bg-no-repeat blur-[2px] opacity-60"
                data-alt="Blurred dark football stadium at night"
                style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAQPk5_OhqJalti4ncqzWctUFh8ERBbRosSS58Yu2StS9EvU4BrqaBwMsILTv6KBqeMYPzPzYT9SVNUm0DJmuCKuTeA10Rp-LKduAUZjYE_121Fsd3W6UWrFVbfSHsVtkZruKvNy5YNzvWGd55gu1pk95dIBoGn_KOCKxStXUEIRlsORPRF8y5pZa0XOZoJ6wCxj1xTBp7Y2bjKAcEzKjK_ZjbgfD9qxRsH5SR1xg3W74zO5C_j6WZsrm838W3P_qiibWZGVnWZLdA');">
            </div>
        </div>
        <!-- Registration Card -->
        <div
            class="relative z-20 w-full max-w-[420px] bg-[#111418]/90 dark:bg-[#1c2127]/95 backdrop-blur-md rounded-2xl shadow-2xl border border-[#283039] overflow-hidden flex flex-col">
            <!-- Card Header -->
            <div class="px-6 pt-10 pb-2 flex flex-col items-center text-center">
                <div class="size-12 bg-primary/20 rounded-full flex items-center justify-center text-primary mb-4">
                    <span class="material-symbols-outlined text-[28px]">sports_soccer</span>
                </div>
                <h1 class="text-slate-900 dark:text-white tracking-tight text-[32px] font-bold leading-tight px-4 pb-2">
                    Join the Squad</h1>
                <p class="text-slate-500 dark:text-[#9dabb9] text-base font-normal leading-normal px-4 max-w-sm">Create
                    an account to get exclusive access to new drops.</p>
            </div>
            <!-- Form -->
            <form id="registerForm" class="px-8 py-8 flex flex-col gap-5" method="post" action="register">

                <!-- Full Name -->
                <div class="flex flex-col gap-2">
                    <!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Full Name</label> -->
                    <div class="relative">
                        <input
                            class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all"
                            placeholder="Enter your full name" type="text" id="fullname" name="fullname" />
                        <span
                            class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] text-[20px]">person</span>
                    </div>
                    <p id="nameError" class="text-red-500 text-xs hidden"></p>
                </div>
                <!-- Email -->
                <div class="flex flex-col gap-2">
                    <!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Email Address</label> -->
                    <div class="relative">
                        <input
                            class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all"
                            placeholder="Enter your email" type="email" id="email" name="email" />
                        <span
                            class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] text-[20px]">mail</span>
                    </div>
                    <p id="emailError" class="text-red-500 text-xs hidden"></p>
                </div>
                <!-- Password -->
                <div class="flex flex-col gap-2">
                    <!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Password</label> -->
                    <div class="relative">
                        <input
                            class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 pr-12 text-base font-normal leading-normal transition-all"
                            placeholder="Create a password" type="password" id="password" name="password" />
                        <button type="button"
                            class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] hover:text-primary transition-colors focus:outline-none">
                            <span class="material-symbols-outlined text-[20px] block">visibility</span>
                        </button>
                    </div>
                    <p id="passwordError" class="text-red-500 text-xs hidden"></p>
                </div>
                <!-- Confirm Password -->
                <div class="flex flex-col gap-2">
                    <!-- <label class="text-slate-900 dark:text-white text-sm font-medium leading-normal">Confirm Password</label> -->
                    <div class="relative">
                        <input
                            class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 text-base font-normal leading-normal transition-all"
                            placeholder="Confirm your password" type="password" id="confirmPassword"
                            name="confirmPassword" />
                        <button type="button"
                            class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">
                                visibility
                            </span>
                        </button>

                    </div>
                    <p id="confirmPasswordError" class="text-red-500 text-xs hidden"></p>
                </div>

                <!-- Referral Code (optional) -->
                <div class="flex flex-col gap-2">
                    <div class="flex items-center justify-between">
                        <span class="text-slate-900 dark:text-white text-sm font-medium">Have a referral code?</span>
                        <span
                            class="inline-flex items-center gap-1 text-xs font-medium text-primary bg-primary/10 px-2.5 py-0.5 rounded-full">
                            <span class="material-symbols-outlined !text-sm">card_giftcard</span>
                            Optional
                        </span>
                    </div>
                    <div class="relative">
                        <input
                            class="form-input flex w-full resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-slate-200 dark:border-[#3b4754] bg-white dark:bg-[#111418] focus:border-primary h-12 placeholder:text-slate-400 dark:placeholder:text-[#637588] px-4 pr-12 text-base font-normal leading-normal transition-all"
                            placeholder="Enter referral code (e.g. SQUAD2025)" type="text" id="referralCode"
                            name="referralCode" maxlength="20" autocomplete="off" />
                        <span
                            class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-[#637588] text-[20px]">group</span>
                    </div>
                    <p class="text-slate-400 dark:text-[#637588] text-xs">
                        Both you and your friend earn rewards when you sign up with their code.
                    </p>
                    <p id="referralError" class="text-red-500 text-xs hidden"></p>
                </div>

                <!-- General Error Message Container -->
                <div id="generalError" class="text-red-500 text-sm text-center hidden mt-2"></div>

                <!-- Register Button -->
                <button
                    class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-4 bg-primary hover:bg-blue-600 transition-colors text-white text-base font-bold leading-normal tracking-[0.015em] mt-2 shadow-lg shadow-primary/30">
                    Create Account
                </button>
                <div id="generalMessage" class="hidden"></div>

                <!-- Footer -->
                <div class="flex justify-center items-center gap-2 mt-2">
                    <p class="text-slate-500 dark:text-[#9dabb9] text-sm">Already a member?</p>
                    <a class="text-primary font-bold text-sm hover:underline" href="/login">Log In</a>
                </div>
            </form>
            <!-- Social Proof / Footer Strip -->
            <div
                class="bg-slate-50 dark:bg-[#181d23] border-t border-slate-200 dark:border-[#283039] p-4 flex justify-center items-center gap-6 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                <span class="material-symbols-outlined text-2xl" title="Secure">verified_user</span>
                <span class="material-symbols-outlined text-2xl" title="Fast Shipping">local_shipping</span>
                <span class="material-symbols-outlined text-2xl" title="Support">support_agent</span>
            </div>
        </div>
    </main>
</body>
<script src="/js/registerValidation.js"></script>
<script src="/js/passwordToggle.js"></script>

</html>