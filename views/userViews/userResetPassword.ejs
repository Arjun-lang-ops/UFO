              <h1
                class="text-[#111418] dark:text-white tracking-tight text-[32px] font-bold leading-tight"
              >
                Create New Password
              </h1>
              <p
                class="text-gray-500 dark:text-[#9dabb9] text-base font-normal leading-normal"
              >
                Please enter and confirm your new password below. Make sure it's
                something secure.
              </p>
            </div>
            <form class="flex flex-col gap-6">
              <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                  <label
                    class="text-sm font-semibold text-[#111418] dark:text-white"
                    for="new-password"
                    >New Password</label
                  >
                  <div class="relative">
                    <input
                      class="w-full h-12 px-4 rounded-lg border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary dark:text-white transition-all outline-none pr-12"
                      id="new-password"
                      placeholder="Enter new password"
                      required=""
                      type="password"
                    />
                    <button
                      class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-primary transition-colors"
                      type="button"
                    >
                      <span class="material-symbols-outlined text-[20px]"
                        >visibility</span
                      >
                    </button>
                  </div>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label
                    class="text-sm font-semibold text-[#111418] dark:text-white"
                    for="confirm-password"
                    >Confirm New Password</label
                  >
                  <div class="relative">
                    <input
                      class="w-full h-12 px-4 rounded-lg border border-[#dce0e5] dark:border-[#3b4754] bg-[#f0f2f4] dark:bg-[#1c2127] focus:border-primary focus:ring-1 focus:ring-primary dark:text-white transition-all outline-none pr-12"
                      id="confirm-password"
                      placeholder="Confirm your password"
                      required=""
                      type="password"
                    />
                    <button
                      class="password-toggle absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-primary transition-colors"
                      type="button"
                    >
                      <span class="material-symbols-outlined text-[20px]"
                        >visibility</span
                      >
                    </button>
                  </div>
                </div>
              </div>
              <div
                class="p-5 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl"
              >
                <h3
                  class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4"
                >
                  Password Requirements
                </h3>
                <ul class="space-y-3">
                  <li
                    class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300"
                  >
                    <span
                      class="material-symbols-outlined text-[18px] text-green-500"
                      >check_circle</span
                    >
                    At least 8 characters long
                  </li>
                  <li
                    class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300"
                  >
                    <span
                      class="material-symbols-outlined text-[18px] text-gray-400"
                      >circle</span
                    >
                    One uppercase &amp; one lowercase letter
                  </li>
                  <li
                    class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300"
                  >
                    <span
                      class="material-symbols-outlined text-[18px] text-gray-400"
                      >circle</span
                    >
                    At least one number or special character
                  </li>
                  <li
                    class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300"
                  >
                    <span
                      class="material-symbols-outlined text-[18px] text-gray-400"
                      >circle</span
                    >
                    Does not contain your name or email
                  </li>
                </ul>
              </div>
              <div class="flex flex-col gap-4">
                <button
                  class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 bg-primary text-white text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all active:scale-[0.99]"
                  type="submit"
                >
                  <span class="truncate">Update Password</span>
                </button>
              </div>
            </form>
            <div class="flex flex-col gap-4 text-center">
              <p class="text-gray-500 dark:text-[#9dabb9] text-sm">
                Remembered your password?
                <a
                  class="text-primary font-bold hover:text-primary/80 transition-colors"
                  href="/login"
                  >Log In</a
                >
              </p>
            </div>
