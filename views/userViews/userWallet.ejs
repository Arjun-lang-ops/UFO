<!DOCTYPE html>
<html class="dark" lang="en">
<% const activePage="wallet" ; %>

    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>My Wallet -Urban FootBall</title>
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap"
            rel="stylesheet" />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
            rel="stylesheet" />
        <script id="tailwind-config">
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary": "#137fec",
                            "background-light": "#f6f7f8",
                            "background-dark": "#101922",
                        },
                        fontFamily: {
                            "display": ["Lexend", "sans-serif"]
                        },
                        borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    },
                },
            }
        </script>
        <style>
            .dark ::-webkit-scrollbar {
                width: 8px;
            }

            .dark ::-webkit-scrollbar-track {
                background: #101922;
            }

            .dark ::-webkit-scrollbar-thumb {
                background: #283039;
                border-radius: 4px;
            }

            .dark ::-webkit-scrollbar-thumb:hover {
                background: #374151;
            }
        </style>
    </head>

    <body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white">
        <div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
            <header
                class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-[#283039] bg-white dark:bg-[#111418] px-4 py-3 lg:px-10 sticky top-0 z-50">
                <div class="flex items-center gap-8">
                    <div class="flex items-center gap-4 text-slate-900 dark:text-white">
                        <div class="size-8 text-primary">
                            <svg class="w-full h-full" fill="none" viewBox="0 0 48 48"
                                xmlns="http://www.w3.org/2000/svg">
                                <path clip-rule="evenodd"
                                    d="M24 4C12.9543 4 4 12.9543 4 24C4 35.0457 12.9543 44 24 44C35.0457 44 44 35.0457 44 24C44 12.9543 35.0457 44 24 44ZM24 40C15.1634 40 8 32.8366 8 24C8 15.1634 15.1634 8 24 8C32.8366 8 40 15.1634 40 24C40 32.8366 32.8366 40 24 40Z"
                                    fill="currentColor"></path>
                                <path d="M24 14L16 28H32L24 14Z" fill="currentColor"></path>
                            </svg>
                        </div>
                        <h2 class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-[-0.015em]">
                            Urban Football</h2>
                    </div>
                    <div class="hidden lg:flex items-center gap-9">
                        <a class="text-slate-600 dark:text-slate-200 hover:text-primary dark:hover:text-primary text-sm font-medium leading-normal transition-colors"
                            href="/home">Shop</a>

                    </div>
                </div>
                <div class="flex flex-1 justify-end gap-4 sm:gap-8">
                    <div class="hidden sm:flex flex-col min-w-40 !h-10 max-w-64">
                        <div
                            class="flex w-full flex-1 items-stretch rounded-lg h-full border border-slate-200 dark:border-none">
                            <div
                                class="text-slate-400 dark:text-[#9dabb9] flex bg-white dark:bg-[#283039] items-center justify-center pl-4 rounded-l-lg border-r-0">
                                <span class="material-symbols-outlined text-[20px]">search</span>
                            </div>
                            <input
                                class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-white dark:bg-[#283039] focus:border-none h-full placeholder:text-slate-400 dark:placeholder:text-[#9dabb9] px-4 rounded-l-none border-l-0 pl-2 text-sm font-normal leading-normal"
                                placeholder="Search gear..." value="" />
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <a href="/cart">
                            <button
                                class="flex items-center justify-center overflow-hidden rounded-lg size-10 bg-slate-100 dark:bg-[#283039] text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-[#3e4a56] transition-colors">
                                <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                            </button>
                        </a>

                        <a href="/profile">
                            <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border border-slate-200 dark:border-[#3e4a56] cursor-pointer"
                                data-alt="User profile avatar small"
                                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAOe8dOzynzR_8mQ2G0YbbIh0QHIrRROTfOtOox9QC0rRHgcZfV0GbJJ2aFVaq-NYlgfylMAuD9WQfieAM_A68WVWcSXgr_aXQ0qlnvvfXnPuO7lajocByOYbPcmxqPvGOzHaATQS-a2kMlt2wuxFBeaV_7n_Vv6COqGMJSbMlgZtUEvRROBQvk2AZujQRQOdZgPSxRCs5kYZIcTDAGTUVKOuUmr3lJLgBWwEW8UsN_uKZ8jGsBcWUfNss6xWae-7sRJFDuMGtP3bA");'>
                            </div>
                        </a>
                    </div>
                </div>
            </header>
            <main class="layout-container flex h-full grow flex-col py-5 px-4 sm:px-6 lg:px-40">
                <div class="flex flex-1 justify-center">
                    <div class="layout-content-container flex flex-col max-w-[1200px] flex-1 w-full">
                        <h1
                            class="text-slate-900 dark:text-white tracking-tight text-[32px] font-bold leading-tight pb-6 pt-2">
                            My Account</h1>
                        <div class="flex flex-col lg:flex-row gap-6">
                            <%- include("partials/userSidebar", { activePage }) %>
                                <div class="flex-1 flex flex-col gap-6">
                                    <section
                                        class="bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm p-6 relative overflow-hidden">
                                        <div
                                            class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -mr-16 -mt-16 pointer-events-none">
                                        </div>
                                        <div
                                            class="flex flex-col sm:flex-row gap-6 items-center justify-between relative z-10">
                                            <div class="flex flex-col gap-1">
                                                <p class="text-slate-500 dark:text-[#9dabb9] text-sm font-medium">
                                                    Available
                                                    Balance</p>
                                                <div class="flex items-baseline gap-1">
                                                    <span class="text-slate-900 dark:text-white text-4xl font-bold">Rs.
                                                        <%=wallet.balance%></span>

                                                </div>

                                            </div>

                                        </div>
                                    </section>
                                    <div class="grid grid-cols-1 xl:grid-cols-5 gap-6">
                                        <section
                                            class="xl:col-span-5 bg-white dark:bg-[#111418] rounded-xl border border-slate-200 dark:border-[#283039] shadow-sm overflow-hidden">

                                            <div class="px-6 py-4 border-b border-slate-100 dark:border-[#283039]">
                                                <h3 class="text-slate-900 dark:text-white text-lg font-bold">
                                                    Transaction History
                                                </h3>
                                            </div>

                                            <% if(wallet.transactions && wallet.transactions.length> 0) { %>

                                                <div class="divide-y divide-slate-100 dark:divide-[#283039]">

                                                    <% wallet.transactions .slice() .reverse() .forEach(transaction=> {
                                                        %>

                                                        <div
                                                            class="p-5 flex items-center justify-between hover:bg-slate-50 dark:hover:bg-[#1e293b] transition-colors">

                                                            <div class="flex items-center gap-4">

                                                                <div class="w-11 h-11 rounded-full flex items-center justify-center
              <%= transaction.type === 'credit'
                ? 'bg-green-100 text-green-600'
                : 'bg-red-100 text-red-600' %>">

                                                                    <span class="material-symbols-outlined">
                                                                        <%= transaction.type==='credit' ? 'south_west'
                                                                            : 'north_east' %>
                                                                    </span>

                                                                </div>

                                                                <div>
                                                                    <p
                                                                        class="font-medium text-slate-900 dark:text-white">

                                                                        <%= transaction.description %>

                                                                    </p>

                                                                    <div
                                                                        class="text-xs text-slate-500 dark:text-[#9dabb9] mt-1 flex gap-3">

                                                                        <span>
                                                                            <%= new
                                                                                Date(transaction.createdAt).toLocaleDateString("en-IN")
                                                                                %>
                                                                        </span>

                                                                        <% if(transaction.orderId) { %>
                                                                            <span>
                                                                                Order #<%= transaction.orderId.orderNumber
                                                                                    %>
                                                                            </span>
                                                                            <% } %>

                                                                    </div>

                                                                </div>

                                                            </div>

                                                            <div class="text-right">

                                                                <p class="
              font-bold
              <%= transaction.type === 'credit'
                ? 'text-green-500'
                : 'text-red-500' %>">

                                                                    <%= transaction.type==='credit' ? '+' : '-' %>
                                                                        ₹<%= transaction.amount.toFixed(2) %>

                                                                </p>

                                                                <p class="text-xs text-slate-500 dark:text-[#9dabb9]">
                                                                    Balance: ₹<%=
                                                                        transaction.balanceAfterTransaction.toFixed(2)
                                                                        %>
                                                                </p>

                                                            </div>

                                                        </div>

                                                        <% }) %>

                                                </div>

                                                <% } else { %>

                                                    <div class="p-12 text-center">

                                                        <span class="material-symbols-outlined text-5xl text-slate-400">
                                                            account_balance_wallet
                                                        </span>

                                                        <p class="mt-4 text-slate-500 dark:text-[#9dabb9]">
                                                            No wallet transactions yet
                                                        </p>

                                                    </div>

                                                    <% } %>

                                        </section>

                                    </div>

                                </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>

    </body>

</html>