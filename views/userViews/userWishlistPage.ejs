<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>My Wishlist - Urban Football</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;700;900&amp;family=Noto+Sans:wght@400;500;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                        "card-dark": "#1c2127",
                        "card-light": "#ffffff",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"],
                        "body": ["Noto Sans", "sans-serif"],
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white min-h-screen flex flex-col overflow-x-hidden">
    <!-- Top Navigation -->
    <header
        class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-[#283039] bg-background-light dark:bg-background-dark px-4 py-3 lg:px-10">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
            <div class="flex items-center gap-8">
                <a class="flex items-center gap-3 text-slate-900 dark:text-white hover:opacity-80 transition-opacity"
                    href="/home">
                    <div class="size-8 text-primary">
                        <svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM5.93 6.99C6.67 6.43 7.51 6.01 8.41 5.76L10.3 10.46L5.43 8.5C5.58 7.97 5.75 7.46 5.93 6.99ZM4.12 11.23L9.31 13.31L7.24 18.5C5.74 16.92 4.67 14.9 4.23 12.67C4.16 12.19 4.12 11.72 4.12 11.23ZM12.76 13.54L18.57 11.23C18.28 15.34 15.19 18.72 11.2 19.38L12.76 13.54ZM13.7 9.54L15.59 4.84C17.7 5.72 19.26 7.6 19.77 9.87C19.84 10.15 19.88 10.44 19.92 10.73L13.7 13.21L13.7 9.54Z">
                            </path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold tracking-tight">Urban Football</h2>
                </a>
                <nav class="hidden lg:flex items-center gap-6">
                    <a  class="text-sm font-medium hover:text-primary transition-colors" href="/home">Home</a>
                    
                </nav>
            </div>
            <div class="flex flex-1 items-center justify-end gap-4 lg:gap-8">
                <!-- Search -->
                <div
                    class="hidden md:flex w-full max-w-xs items-center rounded-lg bg-gray-200 dark:bg-[#283039] h-10 px-3">
                    <span class="material-symbols-outlined text-gray-500 dark:text-[#9dabb9] text-xl">search</span>
                    <input
                        class="w-full bg-transparent border-none text-sm text-slate-900 dark:text-white placeholder:text-gray-500 focus:ring-0"
                        placeholder="Search products..." />
                </div>
                <!-- Actions -->
                <div class="flex items-center gap-3">
                    <a href="/cart">
                        <button
                        class="flex size-10 items-center justify-center rounded-lg hover:bg-gray-200 dark:hover:bg-[#283039] transition-colors relative group">
                        <span class="material-symbols-outlined text-slate-900 dark:text-white">shopping_cart</span>
                        <span class="absolute top-1.5 right-1.5 size-2 rounded-full bg-primary"></span>
                    </button>
                    </a>
                    <a href="/profile">
                        <button
                        class="flex size-10 items-center justify-center rounded-lg hover:bg-gray-200 dark:hover:bg-[#283039] transition-colors">
                        <span class="material-symbols-outlined text-slate-900 dark:text-white">person</span>
                    </button>
                    </a>
                    
                </div>
            </div>
        </div>
    </header>
    <!-- Main Content -->
    <main class="flex-grow w-full px-4 py-8 lg:px-10 lg:py-10">
        <div class="mx-auto max-w-7xl flex flex-col gap-8">
            <!-- Page Heading & Filters -->
            <div class="flex flex-col gap-6">
                <!-- Heading Row -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                    <div class="flex flex-col gap-1">
                        <h1 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 dark:text-white">My
                            Wishlist</h1>
                        <p class="text-gray-500 dark:text-[#9dabb9] text-base font-normal"><%=wishlist?.products?.length||0%> items saved</p>
                    </div>
                    <button
                        class="flex items-center justify-center gap-2 rounded-lg bg-primary hover:bg-blue-600 transition-colors h-11 px-6 text-white text-sm font-bold shadow-lg shadow-blue-900/20">
                        <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                        <span>Add all to Cart</span>
                    </button>
                </div>
                <!-- Filters Row -->
                
            </div>
            <!-- Product Grid -->
           
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

    <% if(wishlist && wishlist.products && wishlist.products.length > 0){ %>

        <% wishlist.products.forEach(item => { %>

            <div
                class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-200 dark:border-[#283039] bg-white dark:bg-[#1c2127] shadow-sm hover:shadow-xl hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-300">

                <!-- Product Image -->
                <div class="relative aspect-[4/3] w-full overflow-hidden bg-gray-100 dark:bg-[#111418]">

                   <% 
   const selectedVariant = item.product.variants.find(
      v => v._id.toString() === item.variant.toString()
   );
%>

<div
  class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
 style="background-image: url('<%= selectedVariant?.images?.[0] || "" %>');">

</div>

                    <!-- Remove Wishlist Button -->
                    <div class="absolute top-3 right-3 flex gap-2">

                        <form class="remove-wishlist">
                            <input type="hidden" name="productId" value="<%= item.product._id %>">

                             <input
        type="hidden"
        name="variantId"
        value="<%= item.variant %>">

                            <button type="submit"
                                class="flex size-8 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm hover:bg-red-500 transition-colors">

                                <span class="material-symbols-outlined text-[18px]">
                                    delete
                                </span>

                            </button>
                        </form>

                    </div>

                    <!-- Stock Badge -->
                    <div class="absolute bottom-3 left-3">

                        <% if(selectedVariant?.stock > 0){ %>

                            <span
                                class="inline-flex items-center rounded-md bg-green-500/90 px-2 py-1 text-xs font-bold text-white backdrop-blur-sm">
                                In Stock
                            </span>

                        <% } else { %>

                            <span
                                class="inline-flex items-center rounded-md bg-red-500/90 px-2 py-1 text-xs font-bold text-white backdrop-blur-sm">
                                Out of Stock
                            </span>

                        <% } %>

                    </div>
                </div>

                <!-- Product Details -->
                <div class="flex flex-1 flex-col p-4">

                    <div class="flex-1">

                        <!-- Category -->
                        <p
                            class="text-gray-500 dark:text-[#9dabb9] text-xs font-medium uppercase tracking-wider mb-1">

                            <%= item.product.category.name %>

                        </p>

                        <!-- Product Name -->
                        <a href="/product/<%=item.product._id%>?variant=<%=item.variant%>"><h3
                            class="text-base font-bold leading-tight text-slate-900 dark:text-white line-clamp-2 mb-2">

                            <%= item.product.name %>

                        </h3></a>

                        <!-- Price -->
                        <div class="flex items-center gap-2 mb-4">

                            <span class="text-lg font-bold text-primary">
                                ₹<%= selectedVariant?.discountedPrice %>
                            </span>

                            <% if(selectedVariant?.price >selectedVariant?.discountedPrice ){ %>

                                <span class="text-sm text-gray-400 line-through">
                                    ₹<%= selectedVariant?.price %>
                                </span>

                            <% } %>

                        </div>

                    </div>

                    <!-- Add To Cart -->
                    <form  class="add-to-cart">

                        <input type="hidden" name="productId" value="<%= item.product._id %>">
                        <input type="hidden"
        name="variantId"
        value="<%= item.variant %>">

                        <button type="submit"
                            class="w-full flex items-center justify-center gap-2 rounded-lg bg-slate-900 dark:bg-[#283039] hover:bg-primary dark:hover:bg-primary py-2.5 text-white text-sm font-bold transition-colors">

                            <span class="material-symbols-outlined text-[18px]">
                                shopping_cart
                            </span>

                            Add to Cart

                        </button>

                    </form>

                </div>
            </div>

        <% }) %>

    <% } else { %>

        <!-- Empty Wishlist -->

        <div class="col-span-full flex flex-col items-center justify-center py-20">

            <span class="material-symbols-outlined text-7xl text-gray-400 mb-4">
                favorite
            </span>

            <h2 class="text-2xl font-bold mb-2">
                Your wishlist is empty
            </h2>

            <p class="text-gray-500 dark:text-[#9dabb9] mb-6">
                Save your favorite football products here.
            </p>

            <a href="/home"
                class="px-6 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-blue-600 transition">

                Continue Shopping

            </a>

        </div>

    <% } %>

</div>
        </div>
    </main>
    <!-- Footer -->
    <footer
        class="border-t border-gray-200 dark:border-[#283039] bg-background-light dark:bg-background-dark py-10 px-4 lg:px-10">
        <div class="mx-auto max-w-7xl">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-2 text-slate-900 dark:text-white">
                    <div class="size-6 text-primary">
                        <svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2Z">
                            </path>
                        </svg>
                    </div>
                    <span class="font-bold text-lg">Urban Football</span>
                </div>
                <div class="flex gap-8 text-sm font-medium text-gray-500 dark:text-[#9dabb9]">
                    <a class="hover:text-primary" href="#">Terms</a>
                    <a class="hover:text-primary" href="#">Privacy</a>
                    <a class="hover:text-primary" href="#">Returns</a>
                    <a class="hover:text-primary" href="#">Help Center</a>
                </div>
                <p class="text-sm text-gray-500 dark:text-[#9dabb9]">© 2024 urban Football Inc.</p>
            </div>
        </div>
    </footer>
</body>

<script>
document.querySelectorAll(".remove-wishlist")
.forEach(form => {

    form.addEventListener("submit", async (e) => {

        e.preventDefault();

        const formData = new FormData(form);

        const data = {
            productId: formData.get("productId"),
            variantId: formData.get("variantId")
        };

        const response = await fetch("/removeWishlist", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {

            Swal.fire({
                icon: "success",
                title: "Removed from wishlist",
                timer: 1200,
                showConfirmButton: false
            });

            form.closest(".group").remove();

        } else {

            Swal.fire({
                icon: "error",
                title: result.message
            });

        }

    });

});
</script>

<script>

document.querySelectorAll(".add-to-cart")
.forEach(form => {

    form.addEventListener("submit", async (e) => {

        e.preventDefault();

        const formData = new FormData(form);

        const data = {
            productId: formData.get("productId"),
            variantId: formData.get("variantId"),
            quantity: 1
        };

        try {

            // ADD TO CART

            const cartResponse = await fetch("/cart/add", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            const cartResult = await cartResponse.json();

            if (!cartResult.success) {

                return Swal.fire({
                    icon: "error",
                    title: cartResult.message
                });

            }

            // REMOVE FROM WISHLIST

            const wishlistResponse = await fetch("/removeWishlist", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    productId: data.productId,
                    variantId: data.variantId
                })
            });

            const wishlistResult = await wishlistResponse.json();

            if (wishlistResult.success) {

                Swal.fire({
                    icon: "success",
                    title: "Added to cart",
                    timer: 1200,
                    showConfirmButton: false
                });

                // REMOVE CARD FROM UI

                form.closest(".group").remove();

            }

        } catch (error) {

            console.log(error);

            Swal.fire({
                icon: "error",
                title: "Something went wrong"
            });

        }

    });

});

</script>

</html>